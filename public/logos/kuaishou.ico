        <script>
          (function() {
          try{
            var cookies = document.cookie.split(';');
            var hasDid = cookies.some(function(cookie) {
              return cookie.trim().startsWith('did=');
            });
            
            if (!hasDid) {
                var timestamp = Date.now();
                var random5Digits = Math.floor(Math.random() * 100000) + 100000; 
                var timeComponent = (random5Digits * 10000000000000 + timestamp).toString(36).slice(0, 12);
                var randomComponent = Math.random().toString(36).substr(2, 12);
                while (randomComponent.length < 12) {
                    randomComponent += Math.floor(Math.random() * 36).toString(36);
                }
                var deviceInfo = [ navigator.userAgent, navigator.language, navigator.platform, navigator.vendor, screen.width, screen.height, screen.colorDepth, screen.pixelDepth, window.devicePixelRatio ].join('')
                var hashCode = (str) => {
                    str = str + Math.random().toString()
                    let hash = 0;
                    for (let i = 0; i < str.length; i++) {
                        var char = str.charCodeAt(i);
                        hash = ((hash << 5) - hash) + char;
                        hash = hash & hash;
                    }
                    let hashStr = Math.abs(hash).toString(36);
                    while (hashStr.length < 12) {
                        hashStr += Math.floor(Math.random() * 36).toString(36);
                    }
                    return hashStr;
                };
                var deviceInfoHash = hashCode(deviceInfo);
                var did = 'web_' + timeComponent + randomComponent + deviceInfoHash;
                var domain = '.' + window.location.hostname.split('.').slice(-2).join('.');
                console.log('did', did);
                console.log('domain', domain);
                document.cookie = 'did=' + did + 
                                ';path=/' +
                                ';domain=' + domain +
                                ';max-age=2147483647' +
                                ';expires=Thu, 09 Jul 2093 10:04:46 GMT' +
                                ';secure' +
                                ';samesite=none';
            }
          } catch (e) {
            console.error('injectCookieScript error', e)
          }
          })();
        </script>
      
