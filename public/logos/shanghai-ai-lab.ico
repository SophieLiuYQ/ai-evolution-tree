    <script type="text/javascript">
        function detectUnsupport() {
            var agent = navigator.userAgent.toLowerCase() || '';
            var isIphone = agent.includes('iphone');
            var isQQ = agent.includes('qq');
            if (isIphone && isQQ) {
                alert('建议使用 Safari, Chrome, Edge 浏览器获取更好浏览体验');
            }
        }
        detectUnsupport();
    </script>
