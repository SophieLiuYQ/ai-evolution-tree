---
import "../styles/global.css";
import { DICT } from "../lib/i18n";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "An open, living tree of every meaningful advancement in ML / LLM / AI — explained for builders and for everyone else.",
} = Astro.props;

const path = Astro.url.pathname;
const isActive = (p: string) =>
  p === "/" ? path === "/" : path.startsWith(p);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {/* i18n bootstrap — must run BEFORE body paints so the chosen
        language is applied on first paint (no English flash). Reads
        `ai-tree:lang` from localStorage (default "en"), sets
        <html lang>, and defines a global __i18nApply() that walks
        every [data-i18n] / [data-i18n-title] element and swaps to the
        saved language. Runs on DOMContentLoaded + re-runs when the
        toggle button fires a `langchange` event. */}
    <script is:inline define:vars={{ DICT }}>
      (function () {
        try {
          var saved = localStorage.getItem("ai-tree:lang");
          if (saved !== "en" && saved !== "zh") saved = "en";
          document.documentElement.setAttribute("lang", saved);
          window.__i18nDict = DICT;
          window.__i18nLang = saved;
        } catch (e) {
          window.__i18nDict = DICT;
          window.__i18nLang = "en";
        }

        window.__i18nApply = function () {
          var lang = window.__i18nLang || "en";
          var d = (window.__i18nDict && window.__i18nDict[lang]) || {};
          // Translate textContent for [data-i18n]
          document.querySelectorAll("[data-i18n]").forEach(function (el) {
            var key = el.getAttribute("data-i18n");
            if (key && d[key] != null) el.textContent = d[key];
          });
          // Translate placeholder for [data-i18n-placeholder]
          document
            .querySelectorAll("[data-i18n-placeholder]")
            .forEach(function (el) {
              var key = el.getAttribute("data-i18n-placeholder");
              if (key && d[key] != null) el.setAttribute("placeholder", d[key]);
            });
          // Translate title (tooltip) for [data-i18n-title]
          document
            .querySelectorAll("[data-i18n-title]")
            .forEach(function (el) {
              var key = el.getAttribute("data-i18n-title");
              if (key && d[key] != null) el.setAttribute("title", d[key]);
            });
          // Sync active state on lang-toggle buttons
          document
            .querySelectorAll(".lang-toggle-btn")
            .forEach(function (b) {
              b.setAttribute(
                "aria-selected",
                b.getAttribute("data-lang") === lang ? "true" : "false",
              );
            });
          document.documentElement.setAttribute("lang", lang);
        };

        window.__i18nSet = function (lang) {
          if (lang !== "en" && lang !== "zh") return;
          window.__i18nLang = lang;
          try { localStorage.setItem("ai-tree:lang", lang); } catch (e) {}
          window.__i18nApply();
          window.dispatchEvent(new Event("langchange"));
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", function () {
            window.__i18nApply();
          });
        } else {
          window.__i18nApply();
        }
      })();
    </script>
  </head>
  <body class="min-h-screen">
    <header class="sticky top-0 z-20 border-b border-[var(--border)] bg-white/85 backdrop-blur">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3">
        <a href="/" class="text-lg font-semibold tracking-tight">
          🌳 <span class="text-[var(--accent)]">AI Evolution Tree</span>
        </a>
        <div class="flex items-center gap-1 text-sm">
          <a
            href="/"
            class={`rounded-md px-3 py-1.5 ${path === "/" ? "bg-[var(--accent-soft)] text-[var(--accent)] font-semibold" : "text-[var(--fg-muted)] hover:bg-slate-100"}`}
            data-i18n="nav.home">Home</a
          >
          <a
            href="/tree/"
            class={`rounded-md px-3 py-1.5 ${isActive("/tree") ? "bg-[var(--accent-soft)] text-[var(--accent)] font-semibold" : "text-[var(--fg-muted)] hover:bg-slate-100"}`}
            data-i18n="nav.graph">Graph</a
          >
          <a
            href="/timeline/"
            class={`rounded-md px-3 py-1.5 ${isActive("/timeline") ? "bg-[var(--accent-soft)] text-[var(--accent)] font-semibold" : "text-[var(--fg-muted)] hover:bg-slate-100"}`}
            data-i18n="nav.timeline">Timeline</a
          >
          <a
            href="/about/"
            class={`rounded-md px-3 py-1.5 ${isActive("/about") ? "bg-[var(--accent-soft)] text-[var(--accent)] font-semibold" : "text-[var(--fg-muted)] hover:bg-slate-100"}`}
            data-i18n="nav.about">About</a
          >
          <a
            href="https://github.com/SophieLiuYQ/ai-evolution-tree"
            class="rounded-md px-3 py-1.5 text-[var(--fg-muted)] hover:bg-slate-100"
            data-i18n="nav.github">GitHub</a
          >
          {/* Language toggle — compact EN / 中 segmented control in nav.
              A bigger, more prominent version also lives on the
              landing page. Both call window.__i18nSet() so they stay
              in sync automatically via langchange event. */}
          <div
            class="lang-toggle ml-2 inline-flex rounded-md border border-slate-300 bg-white p-0.5 text-xs font-semibold"
            role="tablist"
            aria-label="Language"
          >
            <button
              type="button"
              class="lang-toggle-btn rounded px-2 py-0.5 text-slate-600"
              data-lang="en"
              aria-selected="true"
              data-i18n="lang.en"
              data-i18n-title="lang.toggle.title"
              title="Switch language"
              onclick="window.__i18nSet('en')"
            >EN</button>
            <button
              type="button"
              class="lang-toggle-btn rounded px-2 py-0.5 text-slate-600"
              data-lang="zh"
              aria-selected="false"
              data-i18n="lang.zh"
              data-i18n-title="lang.toggle.title"
              title="Switch language"
              onclick="window.__i18nSet('zh')"
            >中</button>
          </div>
        </div>
      </nav>
    </header>

    <main class="mx-auto max-w-6xl px-6 py-8">
      <slot />
    </main>

    <footer
      class="mt-20 border-t border-[var(--border)] bg-white py-6 text-center text-sm text-[var(--fg-muted)]"
    >
      <p data-i18n="footer.license">
        Code: MIT · Content: CC-BY-SA 4.0 · A community-curated tree of AI advancements.
      </p>
    </footer>

    <style is:global>
      /* Language toggle — shared styling for the nav-corner toggle
         and the landing-page prominent toggle. Active button fills
         with accent color. */
      .lang-toggle-btn {
        border: none;
        background: transparent;
        cursor: pointer;
        letter-spacing: 0.03em;
      }
      .lang-toggle-btn[aria-selected="true"] {
        background: var(--accent);
        color: white;
      }
      .lang-toggle-btn:hover:not([aria-selected="true"]) {
        background: #f1f5f9;
      }
      /* Ensure Chinese CJK glyphs render cleanly at small sizes. */
      html[lang="zh"] {
        font-family: ui-sans-serif, system-ui, -apple-system,
          "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei",
          sans-serif;
      }
    </style>
  </body>
</html>
