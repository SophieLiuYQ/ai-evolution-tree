---
import type { Rel } from "../../lib/graph/types";
import {
  edgeStyle,
  HIDDEN_EDGE_TYPES,
  fill as orgFill,
  stroke as orgStroke,
} from "../../lib/graph/constants";

interface Props {
  /** Sorted org → count list. Sorted desc by count, alpha tiebreaker. */
  orgs: { name: string; count: number }[];
}
const { orgs } = Astro.props;

const visibleEdges = Object.entries(edgeStyle).filter(
  ([t]) => !HIDDEN_EDGE_TYPES.has(t as Rel["type"]),
);

// Node-type filter rows. `id` matches the raw category[] tag in node
// frontmatter (so node-types.ts can match against `data-cats`). Order
// here is the display order — headline types (Agent / Multimodal /
// Reasoning) first, then modality/domain, then meta. Colors mirror
// the type-tag pills in ModelSpec so a card's filter row reads as the
// same family as its detail-page tag.
const NODE_TYPES: { id: string; label: string; color: string }[] = [
  { id: "agents", label: "Agent", color: "#7c3aed" },
  { id: "multimodal", label: "Multimodal", color: "#0e7490" },
  { id: "reasoning", label: "Reasoning", color: "#b91c1c" },
  { id: "generative", label: "Generative", color: "#be185d" },
  { id: "code", label: "Code", color: "#4338ca" },
  { id: "cv", label: "Vision", color: "#047857" },
  { id: "audio", label: "Audio", color: "#a16207" },
  { id: "nlp", label: "Text / NLP", color: "#1d4ed8" },
  // "Paper" consolidates the fine-grained meta tags (theory, training,
  // architecture, safety, rl, infrastructure) into one filter row. The
  // normalizer in lib/categories.ts rewrites those 6 tags to "paper" on
  // every card's data-cats attribute, so enabling "Paper" here matches
  // all foundational/meta nodes with a single toggle.
  { id: "paper", label: "Paper", color: "#64748b" },
];
---

<aside class="edge-legend overflow-y-auto border-r border-slate-200 bg-slate-50 px-4 py-4">
  <a href="/tree/" class="block text-base font-bold leading-tight text-slate-900" title="AI Evolution Tree — back to graph">
    🌳 <span class="text-[var(--accent)]">AI Tree</span>
  </a>
  <p class="mt-1 text-[10.5px] leading-snug text-slate-500" data-i18n="tree.brandSub">
    Tech tree of ML/AI breakthroughs. Time → right.
  </p>

  {/* Search — type a model name, jump to its card on the active pane */}
  <div class="tree-search relative mt-4">
    <input
      id="tree-search-input"
      type="search"
      placeholder="Search a model…"
      data-i18n-placeholder="tree.search.placeholder"
      autocomplete="off"
      spellcheck="false"
      class="w-full rounded-md border border-slate-300 bg-white px-2.5 py-1.5 text-xs leading-none text-slate-700 placeholder-slate-400 shadow-sm focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)]"
    />
    <div
      id="tree-search-dropdown"
      class="hidden absolute left-0 right-0 z-30 mt-1 max-h-72 overflow-y-auto rounded-md border border-slate-200 bg-white shadow-lg"
      role="listbox"
      aria-label="Search results"
    ></div>
  </div>

  {/* Orient toggle */}
  <div
    class="orient-toggle mt-4 flex flex-col items-stretch gap-1 rounded-md border border-slate-300 bg-white p-1"
    role="tablist"
    aria-label="Orientation"
  >
    <button type="button" data-orient="v" class="orient-btn rounded px-2 py-2 text-xs font-medium leading-none text-slate-600" aria-selected="true" title="Vertical layout" data-i18n="tree.orient.vertical">▼ Vertical</button>
    <button type="button" data-orient="h" class="orient-btn rounded px-2 py-2 text-xs font-medium leading-none text-slate-600" aria-selected="false" title="Horizontal layout" data-i18n="tree.orient.horizontal">▶ Horizontal</button>
  </div>

  {/* Compact-view toggle — repack visible cards into a tight grid that
      drops the empty space created by filtered-out cards. Same filter
      chain applies; compact mode just changes the render surface. */}
  <button
    id="compact-toggle"
    type="button"
    class="mt-5 flex w-full items-center justify-center gap-1.5 rounded-md border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-slate-700 shadow-sm hover:border-[var(--accent)] hover:text-[var(--accent)]"
    aria-pressed="false"
    title="Pack visible cards into a compact grid"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="3" width="7" height="7" rx="1"/>
      <rect x="14" y="3" width="7" height="7" rx="1"/>
      <rect x="3" y="14" width="7" height="7" rx="1"/>
      <rect x="14" y="14" width="7" height="7" rx="1"/>
    </svg>
    <span class="compact-toggle-label" data-i18n="tree.compact.on">Compact view</span>
  </button>

  {/* Filter sections — reordered 2026-04-21 per user request: Node
      types → Company → License → Edge types (reading order matches
      "what kind of model · who built it · how is it released · how
      is it connected"). */}

  {/* Node-type filter — fades cards whose category[] doesn't intersect
      the enabled set. Same toggle/eye pattern as Edge types.
      AND/OR toggle changes the matching predicate:
        OR  → at least one enabled type matches (default; wider net)
        AND → all enabled types must match (intersection; narrow) */}
  <div class="mt-5 mb-2 flex items-baseline justify-between border-t border-slate-200 pt-3">
    <h3 class="text-[10px] font-semibold uppercase tracking-wider text-slate-500" data-i18n="filter.nodeTypes">
      Node types
    </h3>
    <div
      class="node-filter-mode inline-flex rounded-md border border-slate-300 bg-white p-0.5 text-[10px] font-semibold"
      role="tablist"
      aria-label="Filter combination mode"
    >
      <button
        type="button"
        class="node-filter-mode-btn rounded px-2 py-0.5 text-slate-600"
        data-mode="or"
        aria-selected="true"
        title="Show nodes matching ANY enabled type"
        data-i18n="filter.mode.or"
        data-i18n-title="filter.mode.or.title"
      >OR</button>
      <button
        type="button"
        class="node-filter-mode-btn rounded px-2 py-0.5 text-slate-600"
        data-mode="and"
        aria-selected="false"
        title="Show nodes matching ALL enabled types (intersection)"
        data-i18n="filter.mode.and"
        data-i18n-title="filter.mode.and.title"
      >AND</button>
    </div>
  </div>
  <ul class="space-y-1">
    {NODE_TYPES.map((nt) => (
      <li class="node-type-row" data-type={nt.id} data-on="true">
        <button
          type="button"
          class="node-type-toggle flex w-full items-center gap-2 rounded px-1 py-0.5 text-xs text-slate-700 hover:bg-slate-100"
          data-type={nt.id}
          aria-pressed="true"
          title={`Toggle ${nt.label}`}
        >
          <span
            class="node-type-swatch shrink-0"
            style={`background:${nt.color};`}
            aria-hidden="true"
          />
          <span class="flex-1 text-left font-medium" data-i18n={`nodeType.${nt.id}`}>{nt.label}</span>
          <svg
            class="node-type-eye shrink-0"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path class="eye-outline" d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
            <circle class="eye-pupil" cx="12" cy="12" r="3"/>
            <line class="eye-slash" x1="3" y1="3" x2="21" y2="21"/>
          </svg>
        </button>
      </li>
    ))}
  </ul>
  <div class="mt-2 flex gap-1.5 text-[10px]">
    <button type="button" class="bulk-node-toggle flex flex-1 items-center justify-center gap-1.5 rounded border border-slate-300 bg-white px-2 py-1 font-medium text-slate-600 hover:border-[var(--accent)] hover:text-[var(--accent)]" data-bulk="all" title="Show all node types">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
        <circle cx="12" cy="12" r="3"/>
      </svg>
      <span data-i18n="filter.showAll">Show all</span>
    </button>
    <button type="button" class="bulk-node-toggle flex flex-1 items-center justify-center gap-1.5 rounded border border-slate-300 bg-white px-2 py-1 font-medium text-slate-600 hover:border-[var(--accent)] hover:text-[var(--accent)]" data-bulk="none" title="Hide all node types">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
        <line x1="3" y1="3" x2="21" y2="21"/>
      </svg>
      <span data-i18n="filter.hideAll">Hide all</span>
    </button>
  </div>

  {/* Company filter — long list (~50 orgs in the tree). Scrollable
      max-height so the panel stays compact. Sorted by model count desc
      so the high-volume frontier labs sit at the top. AND-ed with the
      Node-types and License filters. */}
  <h3 class="mt-5 mb-2 border-t border-slate-200 pt-3 text-[10px] font-semibold uppercase tracking-wider text-slate-500">
    <span data-i18n="filter.company">Company</span>
  </h3>
  <ul class="org-filter-list space-y-0.5 overflow-y-auto pr-1">
    {orgs.map((o) => (
      <li class="org-row" data-org={o.name} data-on="true">
        <button
          type="button"
          class="org-toggle flex w-full items-center gap-2 rounded px-1 py-0.5 text-xs text-slate-700 hover:bg-slate-100"
          data-org={o.name}
          aria-pressed="true"
          title={`Toggle ${o.name}`}
        >
          <span
            class="org-swatch shrink-0"
            style={`background:${orgFill(o.name)};border-color:${orgStroke(o.name)};`}
            aria-hidden="true"
          />
          <span class="flex-1 truncate text-left font-medium">{o.name}</span>
          <span class="org-count font-mono text-[10px] text-slate-400">{o.count}</span>
          <svg
            class="org-eye shrink-0"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path class="eye-outline" d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
            <circle class="eye-pupil" cx="12" cy="12" r="3"/>
            <line class="eye-slash" x1="3" y1="3" x2="21" y2="21"/>
          </svg>
        </button>
      </li>
    ))}
  </ul>
  <div class="mt-2 flex gap-1.5 text-[10px]">
    <button type="button" class="bulk-org-toggle flex flex-1 items-center justify-center gap-1.5 rounded border border-slate-300 bg-white px-2 py-1 font-medium text-slate-600 hover:border-[var(--accent)] hover:text-[var(--accent)]" data-bulk="all" title="Show all companies">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
        <circle cx="12" cy="12" r="3"/>
      </svg>
      <span data-i18n="filter.showAll">Show all</span>
    </button>
    <button type="button" class="bulk-org-toggle flex flex-1 items-center justify-center gap-1.5 rounded border border-slate-300 bg-white px-2 py-1 font-medium text-slate-600 hover:border-[var(--accent)] hover:text-[var(--accent)]" data-bulk="none" title="Hide all companies">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
        <line x1="3" y1="3" x2="21" y2="21"/>
      </svg>
      <span data-i18n="filter.hideAll">Hide all</span>
    </button>
  </div>

  {/* License filter — two buckets, AND-ed with the Node-types filter
      above. "Open" covers open_weights / paper / no-model_spec; "Closed"
      covers api / product / demo. Mirrors the byLicense sort taxonomy. */}
  <h3 class="mt-5 mb-2 border-t border-slate-200 pt-3 text-[10px] font-semibold uppercase tracking-wider text-slate-500">
    <span data-i18n="filter.license">License</span>
  </h3>
  <ul class="space-y-1">
    {([
      { id: "open", label: "Open source", color: "#047857" },
      { id: "closed", label: "Closed source", color: "#94a3b8" },
    ] as const).map((lic) => (
      <li class="license-row" data-license={lic.id} data-on="true">
        <button
          type="button"
          class="license-toggle flex w-full items-center gap-2 rounded px-1 py-0.5 text-xs text-slate-700 hover:bg-slate-100"
          data-license={lic.id}
          aria-pressed="true"
          title={`Toggle ${lic.label}`}
        >
          <span
            class="license-swatch shrink-0"
            style={`background:${lic.color};`}
            aria-hidden="true"
          />
          <span class="flex-1 text-left font-medium" data-i18n={`license.${lic.id}`}>{lic.label}</span>
          <svg
            class="license-eye shrink-0"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path class="eye-outline" d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
            <circle class="eye-pupil" cx="12" cy="12" r="3"/>
            <line class="eye-slash" x1="3" y1="3" x2="21" y2="21"/>
          </svg>
        </button>
      </li>
    ))}
  </ul>

  {/* Edge legend — each row is a click toggle (eye indicator on the
      right). Bulk Show all / Hide all controls at the bottom of the
      list. */}
  <h3 class="mt-5 mb-2 border-t border-slate-200 pt-3 text-[10px] font-semibold uppercase tracking-wider text-slate-500">
    <span data-i18n="filter.edgeTypes">Edge types</span>
  </h3>
  <ul class="space-y-1">
    {visibleEdges.map(([t, s]) => (
      <li class="edge-type-row" data-type={t} data-on="true">
        <button
          type="button"
          class="edge-type-toggle flex w-full items-center gap-2 rounded px-1 py-0.5 text-xs text-slate-700 hover:bg-slate-100"
          data-type={t}
          aria-pressed="true"
          title={`Toggle ${s.label}`}
        >
          <svg width="32" height="10" viewBox="0 0 32 10" class="shrink-0">
            <line x1="1" x2="25" y1="5" y2="5" stroke={s.color} stroke-width="2.2" stroke-linecap="round" stroke-dasharray={s.dash ?? "none"} />
            <path d="M 25 1.5 L 31 5 L 25 8.5 z" fill={s.color} />
          </svg>
          <span class="flex-1 text-left font-medium">{s.label}</span>
          <svg
            class="edge-type-eye shrink-0"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path class="eye-outline" d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
            <circle class="eye-pupil" cx="12" cy="12" r="3"/>
            <line class="eye-slash" x1="3" y1="3" x2="21" y2="21"/>
          </svg>
        </button>
      </li>
    ))}
  </ul>
  <div class="mt-2 flex gap-1.5 text-[10px]">
    <button type="button" class="bulk-edge-toggle flex flex-1 items-center justify-center gap-1.5 rounded border border-slate-300 bg-white px-2 py-1 font-medium text-slate-600 hover:border-[var(--accent)] hover:text-[var(--accent)]" data-bulk="all" title="Show all edge types">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
        <circle cx="12" cy="12" r="3"/>
      </svg>
      <span data-i18n="filter.showAll">Show all</span>
    </button>
    <button type="button" class="bulk-edge-toggle flex flex-1 items-center justify-center gap-1.5 rounded border border-slate-300 bg-white px-2 py-1 font-medium text-slate-600 hover:border-[var(--accent)] hover:text-[var(--accent)]" data-bulk="none" title="Hide all edge types">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
        <line x1="3" y1="3" x2="21" y2="21"/>
      </svg>
      <span data-i18n="filter.hideAll">Hide all</span>
    </button>
  </div>

  <p class="mt-5 border-t border-slate-200 pt-3 text-[10.5px] leading-relaxed text-slate-500">
    Hover a card → ancestor lineage.<br/>
    <strong>zoom</strong> → 1-hop modal.<br/>
    <strong>highlight this path</strong> → pin it.
  </p>
  <div class="mt-3 flex gap-1.5 text-[10px]">
    <a href="/timeline/" class="rounded border border-slate-300 bg-white px-2 py-0.5 hover:border-[var(--accent)]">Timeline</a>
    <a href="/about/" class="rounded border border-slate-300 bg-white px-2 py-0.5 hover:border-[var(--accent)]">About</a>
  </div>
</aside>

<style>
  .edge-legend {
    width: 360px !important;
    flex: 0 0 360px;
    max-height: 100%;
    box-sizing: border-box;
  }
  .orient-btn[aria-selected="true"] {
    background: var(--accent);
    color: white;
  }
  /* Active state for Compact view toggle — fills when pressed so it
     reads as an on/off switch, not a regular button. */
  #compact-toggle[aria-pressed="true"] {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }
  /* AND/OR mode toggle next to the Node types heading. Same active-fill
     pattern as the orient toggle. */
  .node-filter-mode-btn {
    border: none;
    background: transparent;
    cursor: pointer;
    letter-spacing: 0.05em;
  }
  .node-filter-mode-btn[aria-selected="true"] {
    background: var(--accent);
    color: white;
  }
  .node-filter-mode-btn:hover:not([aria-selected="true"]) {
    background: #f1f5f9;
  }

  /* ===== Search dropdown ===== */
  #tree-search-dropdown:empty,
  #tree-search-dropdown.hidden {
    display: none;
  }
  #tree-search-dropdown :global(.search-hit) {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1px;
    width: 100%;
    padding: 6px 10px;
    border: none;
    background: transparent;
    text-align: left;
    cursor: pointer;
    font-family: ui-sans-serif, system-ui, sans-serif;
    border-bottom: 1px solid #f1f5f9;
    transition: background 0.1s ease;
  }
  #tree-search-dropdown :global(.search-hit:last-child) {
    border-bottom: none;
  }
  #tree-search-dropdown :global(.search-hit:hover),
  #tree-search-dropdown :global(.search-hit.first-hit) {
    background: var(--accent-soft, #eff6ff);
  }
  #tree-search-dropdown :global(.search-hit-title) {
    font-size: 12px;
    font-weight: 600;
    color: #0f172a;
    line-height: 1.2;
  }
  #tree-search-dropdown :global(.search-hit-org) {
    font-size: 10px;
    color: #64748b;
    font-family: ui-monospace, monospace;
  }

  /* Edge-type toggle rows */
  .edge-type-row {
    transition: opacity 0.12s ease, filter 0.12s ease;
  }
  .edge-type-row[data-on="false"] {
    opacity: 0.45;
    filter: grayscale(0.8);
  }
  /* Eye icon: pupil-on / slash-on swap by data-on. Color follows
     the parent row state (slate when on, dimmer slate when off). */
  .edge-type-row .edge-type-eye {
    color: #475569;
    transition: color 0.12s ease;
  }
  .edge-type-row[data-on="false"] .edge-type-eye {
    color: #94a3b8;
  }
  .edge-type-row[data-on="true"] .eye-slash { display: none; }
  .edge-type-row[data-on="false"] .eye-pupil { display: none; }
  .edge-type-toggle {
    border: none;
    background: transparent;
    cursor: pointer;
  }
  .edge-type-toggle:hover .edge-type-eye {
    color: #0f172a;
  }

  /* Node-type toggle rows — same swap pattern as edge-types, but with
     a colored swatch instead of an arrow line. Swatch color is set via
     inline style from the NODE_TYPES table so it matches the type-tag
     pill on the detail page. */
  .node-type-row {
    transition: opacity 0.12s ease, filter 0.12s ease;
  }
  .node-type-row[data-on="false"] {
    opacity: 0.45;
    filter: grayscale(0.8);
  }
  .node-type-toggle {
    border: none;
    background: transparent;
    cursor: pointer;
  }
  .node-type-swatch {
    width: 14px;
    height: 14px;
    border-radius: 4px;
    border: 1px solid rgba(15, 23, 42, 0.12);
  }
  .node-type-row[data-on="false"] .node-type-swatch {
    border-color: rgba(15, 23, 42, 0.06);
  }
  .node-type-row .node-type-eye {
    color: #475569;
    transition: color 0.12s ease;
  }
  .node-type-row[data-on="false"] .node-type-eye {
    color: #94a3b8;
  }
  .node-type-row[data-on="true"] .eye-slash { display: none; }
  .node-type-row[data-on="false"] .eye-pupil { display: none; }
  .node-type-toggle:hover .node-type-eye {
    color: #0f172a;
  }

  /* License toggle rows — same pattern as node-type rows. Two buckets:
     open (green swatch), closed (slate swatch). */
  .license-row {
    transition: opacity 0.12s ease, filter 0.12s ease;
  }
  .license-row[data-on="false"] {
    opacity: 0.45;
    filter: grayscale(0.8);
  }
  .license-toggle {
    border: none;
    background: transparent;
    cursor: pointer;
  }
  .license-swatch {
    width: 14px;
    height: 14px;
    border-radius: 4px;
    border: 1px solid rgba(15, 23, 42, 0.12);
  }
  .license-row[data-on="false"] .license-swatch {
