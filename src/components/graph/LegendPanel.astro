---
import type { Rel } from "../../lib/graph/types";
import { edgeStyle, HIDDEN_EDGE_TYPES } from "../../lib/graph/constants";

interface Props {
  nodeCount: number;
  edgeCount: number;
  yearCount: number;
}
const { nodeCount, edgeCount, yearCount } = Astro.props;

const visibleEdges = Object.entries(edgeStyle).filter(
  ([t]) => !HIDDEN_EDGE_TYPES.has(t as Rel["type"]),
);
---

<aside class="edge-legend shrink-0 overflow-y-auto border-r border-slate-200 bg-slate-50 px-3 py-3">
  <h1 class="mb-1.5 text-base font-bold leading-tight tracking-tight text-slate-900">
    🌳 <span class="text-[var(--accent)]">AI Evolution Tree</span>
  </h1>
  <p class="text-[10.5px] leading-snug text-slate-600">
    Community-curated tech tree of ML/AI breakthroughs. Time flows
    left → right; typed edges show what built on what.
  </p>
  <div class="mt-2 flex flex-wrap gap-1 text-[10.5px]">
    <a href="/timeline/" class="rounded border border-slate-300 bg-white px-1.5 py-0.5 hover:border-[var(--accent)]">Timeline →</a>
    <a href="/about/" class="rounded border border-slate-300 bg-white px-1.5 py-0.5 hover:border-[var(--accent)]">About</a>
  </div>

  <div
    class="orient-toggle mt-4 inline-flex w-full rounded-md border border-slate-300 bg-white p-0.5 shadow-sm"
    role="tablist"
    aria-label="Orientation"
  >
    <button type="button" data-orient="h" class="orient-btn flex-1 rounded px-1.5 py-1 text-[10.5px] font-medium text-slate-600" aria-selected="true">▶ Horiz</button>
    <button type="button" data-orient="v" class="orient-btn flex-1 rounded px-1.5 py-1 text-[10.5px] font-medium text-slate-600" aria-selected="false">▼ Vert</button>
  </div>

  <dl class="mt-2.5 grid grid-cols-3 gap-1 text-center text-[10px] text-slate-500">
    <div><dt class="text-[9px] uppercase tracking-wide">Nodes</dt><dd class="font-mono text-sm font-semibold text-slate-700">{nodeCount}</dd></div>
    <div><dt class="text-[9px] uppercase tracking-wide">Edges</dt><dd class="font-mono text-sm font-semibold text-slate-700">{edgeCount}</dd></div>
    <div><dt class="text-[9px] uppercase tracking-wide">Years</dt><dd class="font-mono text-sm font-semibold text-slate-700">{yearCount}</dd></div>
  </dl>

  <h3 class="mt-4 mb-2 border-t border-slate-200 pt-3 text-[10px] font-semibold uppercase tracking-wide text-slate-500">
    Edge types
  </h3>
  <ul class="space-y-1.5">
    {visibleEdges.map(([_, s]) => (
      <li class="flex items-center gap-2 text-[12px] text-slate-700">
        <svg width="24" height="9" viewBox="0 0 24 9" class="shrink-0">
          <line x1="1" x2="18" y1="4.5" y2="4.5" stroke={s.color} stroke-width="2" stroke-linecap="round" stroke-dasharray={s.dash ?? "none"} />
          <path d="M 18 1.5 L 23 4.5 L 18 7.5 z" fill={s.color} />
        </svg>
        <span class="font-medium">{s.label}</span>
      </li>
    ))}
  </ul>
  <p class="mt-4 border-t border-slate-200 pt-2.5 text-[10px] leading-snug text-slate-500">
    Hover a card → lineage. <strong>zoom</strong> → 1-hop modal.
    <strong>highlight this path</strong> → pin so you can scroll.
  </p>
</aside>
