---
import type { Rel } from "../../lib/graph/types";
import { edgeStyle, HIDDEN_EDGE_TYPES } from "../../lib/graph/constants";

interface Props {
  nodeCount: number;
  edgeCount: number;
  yearCount: number;
}
const { nodeCount, edgeCount, yearCount } = Astro.props;

const visibleEdges = Object.entries(edgeStyle).filter(
  ([t]) => !HIDDEN_EDGE_TYPES.has(t as Rel["type"]),
);
---

<aside class="edge-legend overflow-y-auto border-r border-slate-200 bg-slate-50 px-4 py-4">
  <a href="/" class="block text-base font-bold leading-tight text-slate-900" title="AI Evolution Tree — home">
    🌳 <span class="text-[var(--accent)]">AI Tree</span>
  </a>
  <p class="mt-1 text-[10.5px] leading-snug text-slate-500">
    Tech tree of ML/AI breakthroughs. Time → right.
  </p>

  {/* Orient toggle */}
  <div
    class="orient-toggle mt-4 flex flex-col items-stretch gap-0.5 rounded-md border border-slate-300 bg-white p-0.5"
    role="tablist"
    aria-label="Orientation"
  >
    <button type="button" data-orient="h" class="orient-btn rounded px-2 py-1.5 text-xs font-medium leading-none text-slate-600" aria-selected="true" title="Horizontal layout">▶ Horizontal</button>
    <button type="button" data-orient="v" class="orient-btn rounded px-2 py-1.5 text-xs font-medium leading-none text-slate-600" aria-selected="false" title="Vertical layout">▼ Vertical</button>
  </div>

  {/* Stats — 3 inline columns */}
  <dl class="mt-3 grid grid-cols-3 gap-1 text-center text-slate-500">
    <div title={`${nodeCount} nodes`}>
      <dd class="font-mono text-base font-semibold leading-none text-slate-700">{nodeCount}</dd>
      <dt class="mt-0.5 text-[9px] uppercase tracking-tight">nodes</dt>
    </div>
    <div title={`${edgeCount} edges`}>
      <dd class="font-mono text-base font-semibold leading-none text-slate-700">{edgeCount}</dd>
      <dt class="mt-0.5 text-[9px] uppercase tracking-tight">edges</dt>
    </div>
    <div title={`${yearCount} years`}>
      <dd class="font-mono text-base font-semibold leading-none text-slate-700">{yearCount}</dd>
      <dt class="mt-0.5 text-[9px] uppercase tracking-tight">years</dt>
    </div>
  </dl>

  {/* Edge legend — swatch + label inline */}
  <h3 class="mt-5 mb-2 border-t border-slate-200 pt-3 text-[10px] font-semibold uppercase tracking-wider text-slate-500">
    Edge types
  </h3>
  <ul class="space-y-2">
    {visibleEdges.map(([_, s]) => (
      <li class="flex items-center gap-2 text-xs text-slate-700" title={s.label}>
        <svg width="32" height="10" viewBox="0 0 32 10" class="shrink-0">
          <line x1="1" x2="25" y1="5" y2="5" stroke={s.color} stroke-width="2.2" stroke-linecap="round" stroke-dasharray={s.dash ?? "none"} />
          <path d="M 25 1.5 L 31 5 L 25 8.5 z" fill={s.color} />
        </svg>
        <span class="font-medium">{s.label}</span>
      </li>
    ))}
  </ul>

  <p class="mt-5 border-t border-slate-200 pt-3 text-[10.5px] leading-relaxed text-slate-500">
    Hover a card → ancestor lineage.<br/>
    <strong>zoom</strong> → 1-hop modal.<br/>
    <strong>highlight this path</strong> → pin it.
  </p>
  <div class="mt-3 flex gap-1.5 text-[10px]">
    <a href="/timeline/" class="rounded border border-slate-300 bg-white px-2 py-0.5 hover:border-[var(--accent)]">Timeline</a>
    <a href="/about/" class="rounded border border-slate-300 bg-white px-2 py-0.5 hover:border-[var(--accent)]">About</a>
  </div>
</aside>

<style>
  .edge-legend {
    width: 360px !important;
    flex: 0 0 360px;
    max-height: 100%;
    box-sizing: border-box;
  }
  .orient-btn[aria-selected="true"] {
    background: var(--accent);
    color: white;
  }
  @media (max-width: 720px) {
    .edge-legend {
      width: 100% !important;
      flex: 1 0 auto;
      max-height: none;
      border-right: none;
      border-bottom: 1px solid #e2e8f0;
    }
  }
</style>
