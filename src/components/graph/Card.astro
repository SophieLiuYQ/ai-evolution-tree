---
import type { Placed } from "../../lib/graph/types";
import { fill, stroke } from "../../lib/graph/constants";
import { normalizeCategories } from "../../lib/categories";
import { normalizeOrg } from "../../lib/org-display";
import {
  clip,
  fmtMonth,
  fmtSpec,
  META_MAX,
  TITLE_MAX,
} from "../../lib/graph/text";

interface Props {
  p: Placed;
}
const { p } = Astro.props;
const d = p.node.data;
const x = p.x - p.width / 2;
const y = p.y - p.height / 2;
const titleClipped = clip(d.title, TITLE_MAX);
const specText = fmtSpec(d.model_spec);
const metaText = clip(`${fmtMonth(d.date)} · ${normalizeOrg(d.org)}`, META_MAX);
// Two-bucket license signal for the LegendPanel "License" filter. Same
// rule as licenseKey() in layout.ts: missing model_spec → open
// (research papers, foundational nodes); open_weights / paper → open;
// api / product / demo → closed.
const releaseType = d.model_spec?.release_type;
const license =
  !releaseType || releaseType === "open_weights" || releaseType === "paper"
    ? "open"
    : "closed";
---

<a href={`/node/${d.slug}/`} class="node-link" data-slug={d.slug} data-cats={normalizeCategories(d.category).join(" ")} data-license={license} data-org={normalizeOrg(d.org)}>
  <g class="node" transform={`translate(${x}, ${y})`}>
    {/* Invisible hover-bay extends the link's hit area into the right gap
        so the mouse can reach the external zoom + pin buttons without
        leaving .node-link (would hide them mid-travel). */}
    <rect class="hover-bay" x="-2" y="-2" width={p.width + 150} height={p.height + 4} fill="transparent" pointer-events="all" />

    <rect class="card-border" width={p.width} height={p.height} rx="6" fill="white" stroke={stroke(p.org)} stroke-width="1.25" />
    <rect x="0" y="0" width="6" height={p.height} rx="2" fill={fill(p.org)} />
    <rect x="0" y="0" width="2" height={p.height} rx="1" fill={stroke(p.org)} />

    <text x="14" y="18" font-size="11" font-family="ui-monospace, monospace" fill={stroke(p.org)} font-weight="700">{metaText}</text>
    <text x="14" y="36" font-size="13" font-family="ui-sans-serif, system-ui" fill="#1e293b" font-weight="600">{titleClipped}</text>
    {specText && (
      <text x="14" y="53" font-size="11" font-family="ui-monospace, monospace" fill="#64748b">{specText}</text>
    )}

    {/* External action buttons (hover-revealed, see GRAPH_DESIGN.md §VII).
        fill-opacity="1" + opacity="1" defensively defeat any inherited
        opacity from the link's hover-fade JS. */}
    <g class="zoom-btn" data-zoom-slug={d.slug} transform={`translate(${p.width + 6}, ${p.height / 2 - 14})`} role="button" aria-label="Open lineage view">
      <rect x="0" y="-11" width="130" height="22" rx="11" fill="white" fill-opacity="1" stroke="#475569" stroke-width="1.2" />
      <text x="65" y="4" text-anchor="middle" font-size="11" font-family="ui-sans-serif, system-ui" font-weight="700" fill="#1e293b" fill-opacity="1" letter-spacing="0.3">zoom</text>
    </g>
    <g class="pin-btn" data-pin-slug={d.slug} transform={`translate(${p.width + 6}, ${p.height / 2 + 14})`} role="button" aria-label="Pin this lineage path">
      <rect x="0" y="-11" width="130" height="22" rx="11" fill="white" fill-opacity="1" stroke="#475569" stroke-width="1.2" />
      <text x="65" y="4" text-anchor="middle" font-size="11" font-family="ui-sans-serif, system-ui" font-weight="700" fill="#1e293b" fill-opacity="1" letter-spacing="0.2">highlight this path</text>
    </g>
  </g>
</a>

<style>
  .node-link {
    cursor: pointer;
    text-decoration: none; /* kill default <a> underline that bleeds onto SVG text */
    transition: opacity 0.15s ease, filter 0.15s ease;
  }
  /* Card filters — a card is faded (not removed) when it fails any of
     the three filter dimensions (Node types · Company · License).
     `!important` is required: hover.ts writes inline `style.opacity`
     and `style.filter` on every card during hover/clear cycles (see
     hover.ts:77,86,87) — without !important, inline styles would win
     and the filter would visually revert the moment the user hovers
     any card. The filter class must always dominate. */
  .node-link.card-filtered {
    opacity: 0.2 !important;
    filter: grayscale(0.6) !important;
    pointer-events: none !important;
  }
  /* SVG attribute trumps CSS: the inner .hover-bay rect has
     `pointer-events="all"` set as an attribute on the element, which
     overrides any inherited CSS pointer-events. Without an explicit
     override here, hovering a grayed-out card would still trigger
     mouseenter (via the bay) and draw the lineage — exactly what the
     user said shouldn't happen. Force pointer-events:none on every
     descendant of a filtered card so the bay (and any future
     interactive children) stop catching events. */
  .node-link.card-filtered * {
    pointer-events: none !important;
  }
  /* Smooth motion when sort mode swaps card positions */
  .node {
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  /* Hover emphasis: thick border on the main card rect.
     (Targeting .card-border explicitly — the invisible .hover-bay rect
     is the first child of .node, so :first-child wouldn't work.) */
  .node-link:hover .node > rect.card-border {
    stroke-width: 4;
  }

  /* Search-result pulse: when a card is jumped to from the search box,
     thicken its border + flash a glow in the card's OWN org color
     (set as --highlight-shadow on the link by search.ts). The card's
     `stroke` attribute is left alone so the border keeps its identity
     (Anthropic orange / Alibaba yellow / OpenAI green / ...). */
  .node-link.search-highlight .node > rect.card-border {
    stroke-width: 5;
    animation: search-pulse 0.7s ease-in-out 3;
  }
  @keyframes search-pulse {
    0%, 100% { filter: drop-shadow(0 0 0 transparent); }
    50% { filter: drop-shadow(0 0 12px var(--highlight-shadow, rgba(15, 23, 42, 0.45))); }
  }

  /* ===== Per-card action buttons (zoom + pin) — outside the card,
     hover-revealed via the parent .node-link. ===== */
  .zoom-btn,
  .pin-btn {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.12s ease;
  }
  .zoom-btn { cursor: zoom-in; }
  .pin-btn { cursor: pointer; }
  .node-link:hover .zoom-btn,
  .node-link:hover .pin-btn {
    opacity: 1;
    pointer-events: all;
  }
  /* Hover state: invert to dark fill */
  .zoom-btn:hover rect,
  .pin-btn:hover rect {
    fill: #1e293b;
    stroke: #1e293b;
  }
  .zoom-btn:hover text,
  .pin-btn:hover text { fill: white; }
  /* Pin active: stays visible + accent-colored even after mouseleave */
  .pin-btn.active {
    opacity: 1 !important;
    pointer-events: all;
  }
  .pin-btn.active rect {
    fill: var(--accent, #2563eb);
    stroke: var(--accent, #2563eb);
  }
  .pin-btn.active text { fill: white; }

  /* While ANY card is pinned (.has-pin on the figure), suppress the
     hover-reveal on every NON-pinned card. The pinned card keeps its
     active pin button via the rule above; user can't accidentally
     trigger zoom/pin on neighbors while studying the pinned lineage. */
  :global(.ai-tree-graph.has-pin) .node-link:not(.pinned-card):hover .zoom-btn,
  :global(.ai-tree-graph.has-pin) .node-link:not(.pinned-card):hover .pin-btn {
    opacity: 0 !important;
    pointer-events: none !important;
  }
</style>
