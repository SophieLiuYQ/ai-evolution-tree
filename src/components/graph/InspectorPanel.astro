---
// Right-side inspector panel for the /tree/ page.
// Populated by client JS when a model is selected in either tree or compact mode.
---

<aside class="tree-inspector" data-open="true" aria-label="Selected node details">
  <div class="inspector-shell">
    <section class="inspector-card inspector-card-main">
      <div class="inspector-header">
        <div>
          <div class="inspector-kicker">Selected model</div>
          <div class="inspector-title-row">
            <h2 class="inspector-title" id="inspector-title">Select a node</h2>
            <span class="inspector-badge" id="inspector-badge" hidden></span>
          </div>
          <div class="inspector-subtitle" id="inspector-subtitle">Open the compact view or click a node in the graph.</div>
        </div>
        <button class="inspector-close" type="button" aria-label="Close inspector" title="Close">
          ×
        </button>
      </div>

      <p class="inspector-desc" id="inspector-desc">
        Click a node in the graph to explore its summary, model facts, and related lineage.
      </p>

      <dl class="inspector-facts" id="inspector-facts" hidden></dl>

      <div class="inspector-actions" id="inspector-actions" hidden>
        <a class="inspector-cta" id="inspector-open" href="#">View model page</a>
        <a class="inspector-cta secondary" id="inspector-external" href="#" target="_blank" rel="noopener" hidden>
          Open source
        </a>
      </div>
    </section>

    <section class="inspector-card" id="inspector-related-section" hidden>
      <div class="inspector-section-title">Related models</div>
      <ul class="inspector-list" id="inspector-related"></ul>
      <a class="inspector-link" id="inspector-more-related" href="#" hidden>View more in model page →</a>
    </section>

    <section class="inspector-card" id="inspector-insights-section" hidden>
      <div class="inspector-section-title">Brief</div>
      <ul class="inspector-bullets" id="inspector-insights"></ul>
    </section>

    <section class="inspector-card" id="inspector-sources-section" hidden>
      <div class="inspector-section-title">Data sources</div>
      <div class="inspector-source-meta" id="inspector-source-meta"></div>
      <div class="inspector-source-links" id="inspector-source-links"></div>
    </section>
  </div>
</aside>

<style>
  .tree-inspector {
    width: 360px;
    flex: 0 0 360px;
    max-height: 100%;
    border-left: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg-soft) 92%, white 8%);
    color: var(--fg);
    display: flex;
    flex-direction: column;
    min-height: 0;
  }
  .tree-inspector[data-open="false"] {
    display: none;
  }
  .inspector-shell {
    padding: 14px;
    overflow: auto;
    min-height: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .inspector-card {
    background: rgba(255, 255, 255, 0.66);
    border: 1px solid var(--border);
    border-radius: 18px;
    box-shadow: 0 12px 28px rgba(15, 23, 42, 0.05);
    padding: 14px;
  }
  .inspector-card-main {
    background: linear-gradient(180deg, rgba(255,255,255,0.82), rgba(255,255,255,0.7));
  }
  .inspector-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }
  .inspector-kicker,
  .inspector-section-title {
    font-size: 11px;
    font-weight: 750;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }
  .inspector-title-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 8px;
  }
  .inspector-title {
    font-size: 27px;
    line-height: 1.05;
    letter-spacing: -0.03em;
    font-weight: 750;
    margin: 0;
  }
  .inspector-badge {
    display: inline-flex;
    align-items: center;
    min-height: 22px;
    padding: 0 9px;
    border-radius: 999px;
    background: #ece7ff;
    color: #5b39d3;
    font-size: 11px;
    font-weight: 700;
  }
  .inspector-subtitle {
    margin-top: 8px;
    font-size: 14px;
    color: var(--fg-muted);
  }
  .inspector-close {
    width: 32px;
    height: 32px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: rgba(255,255,255,0.8);
    color: var(--fg-muted);
    font-size: 18px;
    line-height: 1;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .inspector-close:hover {
    border-color: var(--border-strong);
    color: var(--fg);
  }
  .inspector-desc {
    margin: 14px 0 0 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--fg);
  }
  .inspector-facts {
    margin: 14px 0 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }
  .inspector-fact {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 0;
  }
  .inspector-fact dt {
    font-size: 13px;
    color: var(--fg-muted);
  }
  .inspector-fact dd {
    margin: 0;
    text-align: right;
    font-size: 13px;
    font-weight: 650;
    color: var(--fg);
  }
  .inspector-fact dd a {
    color: #5b39d3;
    text-decoration: none;
  }
  .inspector-fact dd a:hover,
  .inspector-link:hover,
  .inspector-list li a:hover,
  .inspector-source-links a:hover {
    text-decoration: underline;
  }
  .inspector-actions {
    margin-top: 16px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .inspector-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 12px;
    border-radius: 12px;
    border: 1px solid #5b39d3;
    background: linear-gradient(180deg, #6c4dff, #4d34d9);
    color: white;
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
  }
  .inspector-cta.secondary {
    border-color: #c8bcff;
    background: white;
    color: #4733a8;
  }
  .inspector-list,
  .inspector-bullets {
    list-style: none;
    padding: 0;
    margin: 10px 0 0 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .inspector-list li {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 12px;
    align-items: center;
    padding: 0;
  }
  .inspector-list li a {
    color: var(--fg);
    text-decoration: none;
    font-weight: 650;
  }
  .inspector-list .right {
    font-size: 12px;
    color: var(--fg-muted);
  }
  .inspector-link {
    display: inline-block;
    margin-top: 12px;
    font-size: 13px;
    font-weight: 650;
    color: #5b39d3;
    text-decoration: none;
  }
  .inspector-bullets li {
    position: relative;
    padding-left: 18px;
    font-size: 13px;
    line-height: 1.5;
    color: var(--fg);
  }
  .inspector-bullets li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 7px;
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: #7fcda8;
    box-shadow: 0 0 0 5px rgba(127, 205, 168, 0.12);
  }
  .inspector-source-meta {
    margin-top: 10px;
    font-size: 12px;
    color: var(--fg-muted);
  }
  .inspector-source-links {
    margin-top: 10px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .inspector-source-links a {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 0 10px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: white;
    color: var(--fg);
    text-decoration: none;
    font-size: 12px;
    font-weight: 650;
  }

  @media (max-width: 980px) {
    .tree-inspector {
      display: none;
    }
  }
</style>
