---
// Right-side inspector panel for the /tree/ page.
// Populated by client JS when a model is selected in either tree or compact mode.
---

<aside class="tree-inspector" data-open="true" aria-label="Selected node details">
  <div class="inspector-shell">
    <section class="inspector-card inspector-card-main">
      <div class="inspector-header">
        <div>
          <div class="inspector-kicker">Selected model</div>
          <div class="inspector-title-row">
            <h2 class="inspector-title" id="inspector-title">Select a node</h2>
            <span class="inspector-badge" id="inspector-badge" hidden></span>
          </div>
          <div class="inspector-subtitle" id="inspector-subtitle">Click a node in the graph.</div>
        </div>
        <button class="inspector-close" type="button" aria-label="Close inspector" title="Close">
          ×
        </button>
      </div>

      <p class="inspector-desc" id="inspector-desc">
        Click a node in the graph to explore its summary, model facts, and related lineage.
      </p>

      <dl class="inspector-facts" id="inspector-facts" hidden></dl>

      <div class="inspector-actions" id="inspector-actions" hidden>
        <a class="inspector-cta" id="inspector-open" href="#">View model page</a>
        {/* Secondary "Open source / Artificial Analysis" CTA disabled
            (2026-05-03). Restore by uncommenting. */}
        {/*
        <a class="inspector-cta secondary" id="inspector-external" href="#" target="_blank" rel="noopener" hidden>
          Open source
        </a>
        */}
      </div>
    </section>

    {/* Related models section — disabled (2026-05-03). Restore by
        uncommenting. */}
    {/*
    <section class="inspector-card" id="inspector-related-section" hidden>
      <div class="inspector-section-title">Related models</div>
      <ul class="inspector-list" id="inspector-related"></ul>
      <a class="inspector-link" id="inspector-more-related" href="#" hidden>View more in model page →</a>
    </section>
    */}

    {/* Brief + Data sources sections — disabled (2026-05-03). The
        sections are removed from the markup so the populator JS no-ops
        when it can't find the targets. Restore by uncommenting. */}
    {/*
    <section class="inspector-card" id="inspector-insights-section" hidden>
      <div class="inspector-section-title">Brief</div>
      <ul class="inspector-bullets" id="inspector-insights"></ul>
    </section>

    <section class="inspector-card" id="inspector-sources-section" hidden>
      <div class="inspector-section-title">Data sources</div>
      <div class="inspector-source-meta" id="inspector-source-meta"></div>
      <div class="inspector-source-links" id="inspector-source-links"></div>
    </section>
    */}
  </div>
</aside>

<style>
  .tree-inspector {
    width: 360px;
    flex: 0 0 360px;
    max-height: 100%;
    border-left: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg-soft) 92%, white 8%);
    color: var(--fg);
    display: flex;
    flex-direction: column;
    min-height: 0;
  }
  .tree-inspector[data-open="false"] {
    display: none;
  }
  /* Mobile: the inspector is redundant with the full node detail page
     (which a tap on any card already navigates to). Hide it entirely
     to give the canvas the full viewport. */
  @media (max-width: 720px) {
    .tree-inspector { display: none !important; }
  }
  .inspector-shell {
    padding: 14px;
    overflow: auto;
    min-height: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .inspector-card {
    background: rgba(255, 255, 255, 0.66);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 14px;
  }
  .inspector-card-main {
    background: linear-gradient(180deg, rgba(255,255,255,0.82), rgba(255,255,255,0.7));
  }
  .inspector-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }
  .inspector-kicker,
  .inspector-section-title {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }
  .inspector-title-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 6px;
  }
  .inspector-title {
    font-size: 1.125rem;
    line-height: 1.3;
    letter-spacing: -0.01em;
    font-weight: 600;
    margin: 0;
    color: var(--fg);
  }
  .inspector-badge {
    display: inline-flex;
    align-items: center;
    min-height: 20px;
    padding: 0 8px;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 0.6875rem;
    font-weight: 600;
  }
  .inspector-subtitle {
    margin-top: 6px;
    font-size: 0.8125rem;
    color: var(--fg-muted);
  }
  .inspector-close {
    width: 32px;
    height: 32px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: rgba(255,255,255,0.8);
    color: var(--fg-muted);
    font-size: 18px;
    line-height: 1;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .inspector-close:hover {
    border-color: var(--border-strong);
    color: var(--fg);
  }
  .inspector-desc {
    margin: 12px 0 0 0;
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--fg-muted);
  }
  .inspector-facts {
    margin: 16px 0 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 6px;
  }
  .inspector-fact {
    display: flex;
    flex-direction: row;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    padding: 8px 12px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid var(--border);
    border-radius: 8px;
    min-width: 0;
  }
  .inspector-fact dt {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--fg-muted);
    flex-shrink: 0;
  }
  .inspector-fact dd {
    margin: 0;
    text-align: right;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--fg);
    line-height: 1.3;
    word-break: break-word;
  }
  .inspector-fact dd a {
    color: var(--accent);
    text-decoration: none;
  }
  .inspector-fact dd a:hover,
  .inspector-link:hover,
  .inspector-list li a:hover,
  .inspector-source-links a:hover {
    text-decoration: underline;
  }
  .inspector-actions {
    margin-top: 16px;
    display: flex;
    justify-content: center;
  }
  .inspector-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    padding: 0 18px;
    border-radius: 8px;
    border: 1px solid var(--accent);
    background: var(--accent);
    color: white;
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }
  .inspector-cta:hover {
    opacity: 0.9;
  }
  .inspector-cta.secondary {
    border-color: var(--border-strong);
    background: white;
    color: var(--fg);
  }
  .inspector-list,
  .inspector-bullets {
    list-style: none;
    padding: 0;
    margin: 10px 0 0 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .inspector-list li {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 12px;
    align-items: center;
    padding: 0;
  }
  .inspector-list li a {
    color: var(--fg);
    text-decoration: none;
    font-weight: 650;
  }
  .inspector-list .right {
    font-size: 12px;
    color: var(--fg-muted);
  }
  .inspector-link {
    display: inline-block;
    margin-top: 12px;
    font-size: 13px;
    font-weight: 650;
    color: #5b39d3;
    text-decoration: none;
  }
  .inspector-bullets li {
    position: relative;
    padding-left: 18px;
    font-size: 13px;
    line-height: 1.5;
    color: var(--fg);
  }
  .inspector-bullets li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 7px;
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: #7fcda8;
    box-shadow: 0 0 0 5px rgba(127, 205, 168, 0.12);
  }
  .inspector-source-meta {
    margin-top: 10px;
    font-size: 12px;
    color: var(--fg-muted);
  }
  .inspector-source-links {
    margin-top: 10px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .inspector-source-links a {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 0 10px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: white;
    color: var(--fg);
    text-decoration: none;
    font-size: 12px;
    font-weight: 650;
  }

  @media (max-width: 980px) {
    .tree-inspector {
      display: none;
    }
  }
</style>
