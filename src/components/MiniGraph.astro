---
import type { CollectionEntry } from "astro:content";

interface Props {
  nodes: CollectionEntry<"nodes">[];
  currentSlug: string;
}
const { nodes, currentSlug } = Astro.props;

// Group by year
const byYear = new Map<number, CollectionEntry<"nodes">[]>();
for (const n of nodes) {
  const y = n.data.date.getFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(n);
}
const years = Array.from(byYear.keys()).sort((a, b) => a - b);

// Mini layout — compact horizontal
const COL_W = 26;
const NODE_DOT = 4;
const NODE_GAP_Y = 10;
const TOP_HEADER = 18;
const TOP_PAD = 8;
const SIDE_PAD = 8;
const BOT_PAD = 8;

const totalW = SIDE_PAD * 2 + years.length * COL_W;
const maxNodesPerYear = Math.max(
  ...Array.from(byYear.values()).map((v) => v.length),
);
const totalH =
  TOP_PAD + TOP_HEADER + maxNodesPerYear * NODE_GAP_Y + BOT_PAD;

// Place nodes
type Placed = {
  slug: string;
  x: number;
  y: number;
  isCurrent: boolean;
  org: string;
  title: string;
  date: Date;
};
const placed: Placed[] = [];
for (const year of years) {
  const colIdx = years.indexOf(year);
  const sorted = [...byYear.get(year)!].sort(
    (a, b) => a.data.date.getTime() - b.data.date.getTime(),
  );
  for (let i = 0; i < sorted.length; i++) {
    const n = sorted[i];
    placed.push({
      slug: n.data.slug,
      x: SIDE_PAD + colIdx * COL_W + COL_W / 2,
      y: TOP_PAD + TOP_HEADER + i * NODE_GAP_Y + NODE_DOT,
      isCurrent: n.data.slug === currentSlug,
      org: n.data.org,
      title: n.data.title,
      date: n.data.date,
    });
  }
}

// Edges — simple straight lines with very thin stroke
const placedById = new Map(placed.map((p) => [p.slug, p]));
type MiniEdge = { src: Placed; tgt: Placed; involvesCurrent: boolean };
const edges: MiniEdge[] = [];
for (const n of nodes) {
  const tgt = placedById.get(n.data.slug);
  if (!tgt) continue;
  for (const r of n.data.relationships) {
    const src = placedById.get(r.to);
    if (!src) continue;
    edges.push({
      src,
      tgt,
      involvesCurrent:
        src.slug === currentSlug || tgt.slug === currentSlug,
    });
  }
}

// Year color (warm → cool)
function yearColor(idx: number, total: number): string {
  const t = total <= 1 ? 0 : idx / (total - 1);
  const hue = 45 + t * 190;
  return `hsl(${hue}, 50%, 96.5%)`;
}
function yearStroke(idx: number, total: number): string {
  const t = total <= 1 ? 0 : idx / (total - 1);
  const hue = 45 + t * 190;
  return `hsl(${hue}, 55%, 50%)`;
}

const current = placed.find((p) => p.isCurrent);
---

<aside
  class="minimap rounded-lg border border-slate-200 bg-white p-3 shadow-sm"
>
  <div class="mb-2 flex items-baseline justify-between gap-2 text-xs">
    <span class="font-semibold text-slate-700">🗺 Tree map</span>
    <span class="text-slate-500">
      <span class="inline-block h-2 w-2 rounded-full bg-red-600"></span>
      You are here
    </span>
  </div>
  <div class="overflow-x-auto">
    <svg
      width={totalW}
      height={totalH}
      viewBox={`0 0 ${totalW} ${totalH}`}
      class="block"
      role="img"
      aria-label="Map of all nodes in the tree showing current position"
    >
      {/* year column backgrounds */}
      <g class="cols">
        {
          years.map((year, idx) => (
            <g>
              <rect
                x={SIDE_PAD + idx * COL_W}
                y={0}
                width={COL_W}
                height={totalH}
                fill={yearColor(idx, years.length)}
              />
              <text
                x={SIDE_PAD + idx * COL_W + COL_W / 2}
                y={12}
                text-anchor="middle"
                font-size="8.5"
                font-family="ui-monospace, monospace"
                font-weight="700"
                fill={yearStroke(idx, years.length)}
              >
                {year.toString().slice(-2)}
              </text>
            </g>
          ))
        }
      </g>

      {/* edges */}
      <g class="edges">
        {
          edges.map((e) => (
            <line
              x1={e.src.x}
              y1={e.src.y}
              x2={e.tgt.x}
              y2={e.tgt.y}
              stroke={e.involvesCurrent ? "#dc2626" : "#cbd5e1"}
              stroke-width={e.involvesCurrent ? 1.2 : 0.45}
              opacity={e.involvesCurrent ? 0.85 : 0.5}
            />
          ))
        }
      </g>

      {/* nodes */}
      <g class="nodes">
        {
          placed.map((p) => (
            <a href={`/node/${p.slug}/`}>
              <title>{p.title}</title>
              <circle
                cx={p.x}
                cy={p.y}
                r={p.isCurrent ? 4.5 : 2.2}
                fill={p.isCurrent ? "#dc2626" : "#475569"}
                stroke={p.isCurrent ? "white" : "none"}
                stroke-width={p.isCurrent ? 1.5 : 0}
                class="mini-dot"
              />
            </a>
          ))
        }
      </g>

      {/* "You are here" callout for current node */}
      {
        current && (
          <g class="callout">
            <line
              x1={current.x}
              y1={current.y - 6}
              x2={current.x}
              y2={Math.max(current.y - 14, 18)}
              stroke="#dc2626"
              stroke-width="0.8"
              opacity="0.7"
            />
          </g>
        )
      }
    </svg>
  </div>
</aside>

<style>
  .minimap .mini-dot {
    transition:
      r 0.15s ease,
      fill 0.15s ease;
  }
  .minimap a:hover .mini-dot:not([fill="#dc2626"]) {
    r: 3.5;
    fill: #0ea5e9;
  }
</style>
