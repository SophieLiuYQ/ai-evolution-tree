  "Salesforce": "bg-sky-50 text-sky-800 border-sky-300",
  "Nvidia": "bg-green-50 text-green-800 border-green-300",
  "Apple": "bg-slate-100 text-slate-800 border-slate-300",
  "IBM": "bg-blue-50 text-blue-800 border-blue-300",
  "Academic / Independent": "bg-stone-100 text-stone-700 border-stone-300",
