  "DeepMind": "bg-blue-50 text-blue-800 border-blue-300",
  "Google Brain": "bg-blue-50 text-blue-800 border-blue-300",
  "Google/DeepMind": "bg-blue-50 text-blue-800 border-blue-300",
  "Meta AI": "bg-cyan-50 text-cyan-800 border-cyan-300",
  "Microsoft": "bg-teal-50 text-teal-800 border-teal-300",
  "Mistral AI": "bg-red-50 text-red-800 border-red-300",
  "Stability AI": "bg-stone-100 text-stone-700 border-stone-300",
  "EleutherAI": "bg-purple-50 text-purple-800 border-purple-300",
  "Cohere": "bg-pink-50 text-pink-800 border-pink-300",
  "xAI": "bg-zinc-100 text-zinc-800 border-zinc-300",
  "Alibaba": "bg-yellow-50 text-yellow-800 border-yellow-300",
  "DeepSeek": "bg-fuchsia-50 text-fuchsia-800 border-fuchsia-300",
  "Tsinghua / Zhipu": "bg-rose-50 text-rose-800 border-rose-300",
  "01.AI": "bg-rose-50 text-rose-800 border-rose-300",
