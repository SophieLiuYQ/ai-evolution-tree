  "Moonshot AI": "bg-indigo-50 text-indigo-800 border-indigo-300",
  "MiniMax": "bg-violet-50 text-violet-800 border-violet-300",
  "ByteDance": "bg-orange-50 text-orange-800 border-orange-300",
  "Stepfun": "bg-emerald-50 text-emerald-800 border-emerald-300",
  "Suno": "bg-pink-50 text-pink-800 border-pink-300",
  "Runway": "bg-violet-50 text-violet-800 border-violet-300",
