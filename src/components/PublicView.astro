---
interface Props {
  pv: {
    plain_english: string;
    analogy: string;
    applications: { product: string; company: string; year_deployed: number }[];
    investment_angle: string;
    market_size_usd?: number;
    why_it_matters: string;
  };
}
const { pv } = Astro.props;

const formatUSD = (n?: number) => {
  if (!n) return null;
  if (n >= 1_000_000_000) return `$${(n / 1_000_000_000).toFixed(0)}B`;
  if (n >= 1_000_000) return `$${(n / 1_000_000).toFixed(0)}M`;
  return `$${n}`;
};
---

<section class="prose-node space-y-8">
  <div>
    <h2>What it is, plainly</h2>
    <p class="text-lg leading-relaxed">{pv.plain_english}</p>
  </div>

  <div class="rounded-lg border border-[var(--border)] bg-white p-5 shadow-sm">
    <div class="mb-2 text-xs uppercase tracking-wider text-[var(--fg-muted)]">
      Analogy
    </div>
    <p class="italic text-[var(--fg)]">{pv.analogy}</p>
  </div>

  <div>
    <h2>Where you encounter it</h2>
    <ul class="space-y-2">
      {
        pv.applications.map((a) => (
          <li class="flex items-baseline justify-between gap-4 border-b border-[var(--border)] py-2">
            <div>
              <div class="font-medium">{a.product}</div>
              <div class="text-sm text-[var(--fg-muted)]">{a.company}</div>
            </div>
            <div class="font-mono text-sm text-[var(--fg-muted)]">
              {a.year_deployed}
            </div>
          </li>
        ))
      }
    </ul>
  </div>

  <div>
    <h2>Investment angle</h2>
    <p>{pv.investment_angle}</p>
    {
      pv.market_size_usd && (
        <p class="mt-3 inline-block rounded-md border border-[var(--border)] bg-white px-3 py-1.5 text-sm shadow-sm">
          Implied market scale:{" "}
          <strong class="text-[var(--accent)]">
            {formatUSD(pv.market_size_usd)}
          </strong>
        </p>
      )
    }
  </div>

  <div>
    <h2>Why it matters</h2>
    <p>{pv.why_it_matters}</p>
  </div>
</section>
