// ============== Benchmark parsing (Direction H scale-bar rendering) ==============
// Each benchmark row in the frontmatter stores `score` + freeform `vs_baseline`.
// To render a prev→now scale bar we need both as 0-100 numbers. The parser
// returns nulls for non-percentage scores (Elo, prices, ratios) so the row
// can fall back to the old text rendering.

type ParsedBench = {
  current: number | null;
  baseline: number | null;
  baselineLabel: string | null;
};

function parseBench(scoreStr: string, baselineStr?: string): ParsedBench {
  // Extract first "<num>%" from the score. Anything else (ratios like "107×",
  // prices, Elo) disables the scale bar.
  const scoreMatch = scoreStr.match(/(\d+(?:\.\d+)?)\s*%/);
  const current = scoreMatch ? parseFloat(scoreMatch[1]) : null;

  let baseline: number | null = null;
  let baselineLabel: string | null = null;
  if (baselineStr) {
    // "<label> <num>%" — capture the label (non-greedy) up to the first percentage.
    // Examples matched:
    //   "Claude 3 Opus 86.8%, GPT-4o 88.7%" → label="Claude 3 Opus", num=86.8
    //   "o1 83.3%, DeepSeek R1 79.8%"       → label="o1",           num=83.3
    //   "Llama 2 70B 68.9%"                 → label="Llama 2 70B",  num=68.9
    const m = baselineStr.match(/^\s*([^,]+?)\s+(\d+(?:\.\d+)?)\s*%/);
    if (m) {
      baselineLabel = m[1].trim();
      baseline = parseFloat(m[2]);
    }
  }
  return { current, baseline, baselineLabel };
}

// ============== Scale-bar references ==============
// Each scale defines tick marks (the labeled stops) on a log axis from
// min..max. logScalePos() maps a value to a 0-100 percentage along the
// bar; we plot the active value as a marker on top.

type Tick = { label: string; value: number; note?: string };

function logScalePos(value: number, min: number, max: number): number {
  if (value <= min) return 0;
  if (value >= max) return 100;
  const lo = Math.log10(min);
  const hi = Math.log10(max);
  return ((Math.log10(value) - lo) / (hi - lo)) * 100;
}

// PARAMETERS scale — billions, log axis 0.5B..2T
const PARAM_TICKS: Tick[] = [
  { label: "1B", value: 1, note: "Edge" },
  { label: "7B", value: 7, note: "Single GPU" },
  { label: "70B", value: 70, note: "Workstation" },
  { label: "200B", value: 200 },
  { label: "700B", value: 700, note: "Datacenter" },
  { label: "2T", value: 2000 },
];
const PARAM_MIN = 0.5;
const PARAM_MAX = 2000;

// Parse a parameter string into ALL the param sizes it lists.
//   "70B"                              → [70]
//   "8B / 70B / 405B"                  → [8, 70, 405]
//   "1B / 4B / 12B / 27B dense"        → [1, 4, 12, 27]
//   "671B total / 37B active MoE"      → total=671, active=37
//   "0.6B/1.7B/4B/8B/14B/32B dense + 30B-A3B and 235B-A22B MoE"
//                                       → variants=[0.6,1.7,4,8,14,32,30,235],
//                                         active=[3,22]   (MoE active counts)
//
// Strategy:
//  - "<X>B-A<Y>B" ("MoE shorthand") emits X total + Y active.
//  - When "active" appears with exactly two B-numbers, treat them as
//    total + active (DeepSeek-V3 / Hunyuan-Large style).
//  - Everything else is a regular variant.
type ParamParse = { variants: number[]; active: number[] };

function parseAllParams(s: string): ParamParse | null {
  // Capture MoE shorthand "30B-A3B" / "235B-A22B" first
  const moeShort = [...s.matchAll(/(\d+(?:\.\d+)?)\s*B\s*-\s*A\s*(\d+(?:\.\d+)?)\s*B/gi)];
  const variants: number[] = [];
  const active: number[] = [];
  let scrubbed = s;
  for (const m of moeShort) {
    variants.push(parseFloat(m[1]));
    active.push(parseFloat(m[2]));
    scrubbed = scrubbed.replace(m[0], " ");
  }

  const toB = (n: number, u: string) => {
    const U = u.toUpperCase();
    if (U === "B") return n;
    if (U === "M") return n / 1000;
    if (U === "K") return n / 1_000_000;
    return n;
  };
  const remaining = [...scrubbed.matchAll(/(\d+(?:\.\d+)?)\s*([BMK])\b/gi)].map(
    (m) => toB(parseFloat(m[1]), m[2]),
  );

  // total/active pattern: "236B total / 21B active" or "671B / 37B active"
  const isExplicitMoE = /\bactive\b/i.test(scrubbed);
  if (isExplicitMoE && remaining.length === 2) {
    variants.push(remaining[0]);
    active.push(remaining[1]);
  } else {
    for (const v of remaining) variants.push(v);
  }

  if (variants.length === 0 && active.length === 0) return null;
  // Sort + dedupe
  const dedup = (a: number[]) =>
    [...new Set(a.map((n) => Math.round(n * 100) / 100))].sort((x, y) => x - y);
  return { variants: dedup(variants), active: dedup(active) };
}

// CONTEXT WINDOW scale — tokens, log axis 4k..10M
const CTX_TICKS: Tick[] = [
  { label: "4k", value: 4_000, note: "Chat" },
  { label: "32k", value: 32_000 },
  { label: "128k", value: 128_000, note: "Long doc" },
  { label: "1M", value: 1_000_000, note: "Codebase" },
  { label: "10M", value: 10_000_000 },
];
const CTX_MIN = 2_000;
const CTX_MAX = 10_000_000;

// TRAINING TOKENS scale — trillions, log axis 0.3T..50T
const TOK_TICKS: Tick[] = [
  { label: "1T", value: 1 },
  { label: "5T", value: 5, note: "Modern" },
  { label: "15T", value: 15, note: "Frontier" },
  { label: "30T", value: 30 },
];
const TOK_MIN = 0.3;
const TOK_MAX = 50;

// Parse "15T" / "5.6T" / "1.4T tokens" → trillions
function parseTokensT(s: string): number | null {
  const m = s.match(/(\d+(?:\.\d+)?)\s*([TB])/i);
  if (!m) return null;
  const n = parseFloat(m[1]);
  return m[2].toUpperCase() === "T" ? n : n / 1000;
}

// TRAINING COMPUTE scale — FLOPs exponent (linear axis)
const COMPUTE_TICKS: Tick[] = [
  { label: "1e22", value: 22 },
  { label: "1e23", value: 23, note: "GPT-3 era" },
  { label: "1e24", value: 24 },
  { label: "1e25", value: 25, note: "GPT-4 era" },
  { label: "1e26", value: 26, note: "Frontier" },
];
const COMPUTE_MIN_EXP = 22;
const COMPUTE_MAX_EXP = 26.5;

// Parse "3.8e25" / "2e+25 FLOPs" → exponent (with mantissa contribution)
function parseComputeExp(s: string): number | null {
  const m = s.match(/(\d+(?:\.\d+)?)\s*[eE]\+?(\d+)/);
  if (!m) return null;
  const mant = parseFloat(m[1]);
  const exp = parseInt(m[2], 10);
  return exp + Math.log10(Math.max(1, mant));
}

function linearPos(value: number, min: number, max: number): number {
  if (value <= min) return 0;
  if (value >= max) return 100;
  return ((value - min) / (max - min)) * 100;
}

// ============== Pill-group enum options ==============

// Pill / chip tooltips — DUAL audience: ONE bullet per perspective.
// Bullet 1 = technical / specific terms / engineer-targeted.
// Bullet 2 = plain English / analogy / non-technical reader.
// Audience headers are intentionally NOT printed — the contrast in
// language between the two bullets makes the split self-evident.
type DualTip = { tech: string; lay: string };
type PillOptDef = { id: string; label: string; tip: DualTip };

const RELEASE_PILLS: PillOptDef[] = [
  {
    id: "paper",
    label: "Paper",
    tip: {
      tech: "A published research paper without released model files or a hosted service.",
      lay: "It's a research paper, not something you can use yet.",
    },
  },
  {
    id: "demo",
    label: "Demo",
    tip: {
      tech: "Public demo or waitlisted preview; the company hasn't committed to keeping it stable.",
      lay: "You can try it on a website, often after a waitlist — don't depend on it sticking around.",
    },
  },
  {
    id: "open_weights",
    label: "Open weights",
    tip: {
      tech: "The model file is downloadable; you run it on your own hardware and pick the license terms.",
      lay: "Anyone can download the model and run it on their own machines — no vendor lock-in.",
    },
  },
  {
    id: "api",
    label: "API",
    tip: {
      tech: "Hosted by the lab; pay per request, behavior and pricing can change without notice.",
      lay: "You pay each time you use it; the company runs the model and can change prices or cancel anytime.",
    },
  },
  {
    id: "product",
    label: "Product",
    tip: {
      tech: "Embedded inside a finished application; only the app's surface is exposed.",
      lay: "Baked into a finished app — you use the app, not the model directly.",
    },
  },
];

// Architecture chip extraction. Splits the free-form architecture
// string into a small set of canonical, recognizable tags. Order of
// checks matters — more specific tokens first.
const ARCH_PATTERNS: { pattern: RegExp; chip: string }[] = [
  { pattern: /\bsparse[- ]attention\b|\bDSA\b/i, chip: "Sparse Attention" },
  { pattern: /\b(linear[- ]attention|lightning[- ]attention)\b/i, chip: "Lightning Attention" },
  { pattern: /\bmamba\b|\bSSM\b|\bstate[- ]?space\b/i, chip: "SSM" },
  { pattern: /\bmixture[- ]of[- ]experts\b|\bMoE\b/i, chip: "MoE" },
  { pattern: /\b(rectified[- ]?flow|MMDiT|DiT)\b/i, chip: "Diffusion / Flow" },
  { pattern: /\bdiffusion\b/i, chip: "Diffusion" },
  { pattern: /\bdecoder[- ]only\b|\bGPT[- ]style\b/i, chip: "Decoder-only" },
  { pattern: /\bencoder[- ]decoder\b|\bseq2seq\b/i, chip: "Encoder-decoder" },
  { pattern: /\bvision encoder\b|\bvision[- ]language\b|\bVL[A]?\b/i, chip: "Vision encoder" },
  { pattern: /\bthinking\b|\breasoning\b|\bRL post[- ]?training\b/i, chip: "Reasoning" },
  { pattern: /\bagent(ic)?\b|\btool[- ]use\b/i, chip: "Agent" },
  { pattern: /\bGNN\b|\bgraph neural\b/i, chip: "GNN" },
  { pattern: /\bU-Net\b/i, chip: "U-Net" },
];

function archChips(s: string): string[] {
  const found: string[] = [];
  for (const { pattern, chip } of ARCH_PATTERNS) {
    if (pattern.test(s) && !found.includes(chip)) found.push(chip);
  }
  return found;
}

// Architecture chip tooltips — one bullet per audience, same as pills.
// Tech bullet keeps essential names (MoE, diffusion) but trims internal
// jargon and lists of specific implementations the lay reader can't use.
const ARCH_TIPS: Record<string, DualTip> = {
  "MoE": {
    tech: "Many parallel sub-networks; a router activates only a few per word. Total parameters set memory; active parameters set cost and speed.",
    lay: "Many specialist sub-networks; only a few activate per word — big knowledge at a small per-word cost.",
  },
  "SSM": {
    tech: "A different sequence-modeling math than the standard transformer; memory stays constant per token instead of growing with input length.",
    lay: "A different design from the standard transformer — faster on very long inputs (whole books, audio streams).",
  },
  "Sparse Attention": {
    tech: "Each word only compares itself to a chosen subset of others rather than all of them, so very long inputs become affordable.",
    lay: "Skips most word-pair comparisons so very long inputs (whole books, repos) become affordable.",
  },
  "Lightning Attention": {
    tech: "MiniMax's speed-optimized attention; cost grows in proportion to input length instead of with its square.",
    lay: "A speed-optimized attention design from MiniMax — used in their fast, cheap chat models.",
  },
  "Diffusion / Flow": {
    tech: "Generates outputs by repeatedly cleaning up random noise over many small refinement steps.",
    lay: "Starts from random noise and gradually refines it into the final image or video.",
  },
  "Diffusion": {
    tech: "Repeatedly cleans up random noise into the final result. Standard backbone for image generation.",
    lay: "Starts with noise, gradually turns it into a picture — the technique behind most AI image generators.",
  },
  "Decoder-only": {
    tech: "Predicts one word at a time, left to right. The standard LLM topology used by GPT, Claude, Llama.",
    lay: "The standard LLM design (GPT, Claude, Llama) — reads your message, then writes a reply word by word.",
  },
  "Encoder-decoder": {
    tech: "Reads the full input first, then writes the output. Older design, mostly replaced by left-to-right models for chat.",
    lay: "Older design that reads everything first, then writes the answer — common in translation tools.",
  },
  "Vision encoder": {
    tech: "A separate component processes images and converts them into a form the language part of the model can reason over.",
    lay: "Dedicated 'eyes' component — lets the AI describe and answer questions about images.",
  },
  "Reasoning": {
    tech: "Trained to write out a chain of thought before answering. Slower per response, more accurate on hard problems.",
    lay: "Trained to think step-by-step before answering — slower but smarter on math, code, and complex problems.",
  },
  "Agent": {
    tech: "Trained to use tools (browser, terminal, file editor) and plan multi-step actions, not only generate text.",
    lay: "Doesn't just chat — actually does things (browses, writes files, runs code) like a junior employee.",
  },
  "GNN": {
    tech: "For data shaped as a network of connected items; each item learns by exchanging information with its neighbors.",
    lay: "For data shaped like a network (molecules, friendships, maps); each node learns from its neighbors.",
  },
  "U-Net": {
    tech: "An hourglass-shaped network that compresses then reconstructs detail. Standard inside image diffusion models.",
    lay: "The image-processing engine inside many AI image generators; preserves fine detail.",
  },
};

// ============== Per-row visualization config builders ==============
// Extracted from the JSX scope so generic types like Set<string> don't
// get mis-parsed as JSX tags.

type Marker = {
  pos: number;
  label?: string;        // small inline label rendered above/below the dot
  hollow?: boolean;
  rawLabel?: string;     // tooltip + value-attribute fallback
  stack?: number;        // 0/1/2 — which staggered row the label sits in
};
type ScaleCfg = { ticks: Tick[]; markers: Marker[]; min: number; max: number; isLinear?: boolean };

// Stagger marker labels into up to 4 rows so adjacent markers don't
// collide on the log axis. Labels are ~28px wide on a ~600px bar, so
// anything within ~5% of an earlier marker's column gets bumped to the
// next free row. With Qwen3-VL packing 10 markers in the 0.6B-235B
// range, 3 rows weren't enough — 32B and 30B sit at nearly identical
// log-x and need to escape both up AND below.
function staggerMarkers(markers: Marker[]): Marker[] {
  const sorted = [...markers].sort((a, b) => a.pos - b.pos);
  const STAGGER_DIST = 5;
  const stackTops: number[] = [-Infinity, -Infinity, -Infinity, -Infinity];
  for (const m of sorted) {
    let placed = false;
    for (let i = 0; i < stackTops.length; i++) {
      if (m.pos - stackTops[i] >= STAGGER_DIST) {
        m.stack = i;
        stackTops[i] = m.pos;
        placed = true;
        break;
      }
    }
    if (!placed) {
      // Couldn't fit cleanly — pick the row with the oldest occupant
      let bestRow = 0;
      let bestTop = stackTops[0];
      for (let i = 1; i < stackTops.length; i++) {
        if (stackTops[i] < bestTop) {
          bestRow = i;
          bestTop = stackTops[i];
        }
      }
      m.stack = bestRow;
      stackTops[bestRow] = m.pos;
    }
  }
  return sorted;
}

function paramLabel(n: number): string {
  if (n >= 1000) return `${(n / 1000).toFixed(n >= 10000 ? 0 : 1)}T`;
  if (n >= 10) return `${Math.round(n)}B`;
  if (n >= 1) return `${n.toFixed(n < 10 ? 1 : 0).replace(/\.0$/, "")}B`;
  return `${Math.round(n * 1000)}M`;
}

function buildScaleCfg(
  key: string,
  value: string,
  ctxWindow: number | undefined,
): ScaleCfg | null {
  if (key === "parameters") {
    const p = parseAllParams(value);
    if (!p) return null;
    const markers: Marker[] = [];
    for (const v of p.variants) {
      markers.push({
        pos: logScalePos(v, PARAM_MIN, PARAM_MAX),
        rawLabel: paramLabel(v),
        label: paramLabel(v),
      });
    }
    for (const v of p.active) {
      markers.push({
        pos: logScalePos(v, PARAM_MIN, PARAM_MAX),
        rawLabel: paramLabel(v),
        label: paramLabel(v),
        hollow: true,
      });
    }
    return { ticks: PARAM_TICKS, markers: staggerMarkers(markers), min: PARAM_MIN, max: PARAM_MAX };
  }
  if (key === "context_window" && ctxWindow) {
    return {
      ticks: CTX_TICKS,
      markers: [{ pos: logScalePos(ctxWindow, CTX_MIN, CTX_MAX), label: "this model" }],
      min: CTX_MIN,
      max: CTX_MAX,
    };
  }
  if (key === "training_tokens") {
    const v = parseTokensT(value);
    if (!v) return null;
    return {
      ticks: TOK_TICKS,
      markers: [{ pos: logScalePos(v, TOK_MIN, TOK_MAX), label: "this model" }],
      min: TOK_MIN,
      max: TOK_MAX,
    };
  }
  if (key === "training_compute") {
    const exp = parseComputeExp(value);
    if (exp == null) return null;
    return {
      ticks: COMPUTE_TICKS,
      markers: [{ pos: linearPos(exp, COMPUTE_MIN_EXP, COMPUTE_MAX_EXP), label: "this model" }],
      min: COMPUTE_MIN_EXP,
      max: COMPUTE_MAX_EXP,
      isLinear: true,
    };
  }
  return null;
}

function tickPos(t: Tick, cfg: ScaleCfg): number {
  return cfg.isLinear ? linearPos(t.value, cfg.min, cfg.max) : logScalePos(t.value, cfg.min, cfg.max);
}

type PillOpt = { id: string; label: string; note?: string };
type PillCfg = { options: PillOpt[]; active: Set<string> };

function buildPillCfg(
  key: string,
  releaseType: string | undefined,
): PillCfg | null {
  if (key === "release_type" && releaseType) {
    return { options: RELEASE_PILLS, active: new Set([releaseType]) };
  }
  return null;
}

// ============== Build the row data ==============

type Row = {
  key: string;
  label: string;
  value: string;
  implication: string;
  implicationZh: string;
};

const rows: Row[] = [];
if (spec.parameters)
  rows.push({
    key: "parameters",
    label: "Parameters",
    value: spec.parameters,
    implication: paramImpl(spec.parameters),
    implicationZh: paramImplZh(spec.parameters),
  });
if (spec.architecture)
  rows.push({
    key: "architecture",
    label: "Architecture",
    value: spec.architecture,
    implication: archImpl(spec.architecture),
    implicationZh: archImplZh(spec.architecture),
  });
if (spec.context_window)
  rows.push({
    key: "context_window",
    label: "Context window",
    value: fmtCtx(spec.context_window) ?? "",
    implication: contextImpl(spec.context_window),
    implicationZh: contextImplZh(spec.context_window),
  });
if (spec.training_tokens)
  rows.push({
    key: "training_tokens",
    label: "Training tokens",
    value: spec.training_tokens,
    implication: trainingTokensImpl(spec.training_tokens),
    implicationZh: trainingTokensImplZh(spec.training_tokens),
  });
if (spec.training_compute)
  rows.push({
    key: "training_compute",
    label: "Training compute",
    value: spec.training_compute,
    implication: computeImpl(spec.training_compute),
    implicationZh: computeImplZh(spec.training_compute),
  });
if (spec.release_type)
  rows.push({
    key: "release_type",
    label: "Release type",
    value: spec.release_type,
    implication: licenseImpl(spec.release_type),
    implicationZh: licenseImplZh(spec.release_type),
  });
---

<section class="model-spec mb-8 rounded-lg border border-[var(--border)] bg-white p-5 shadow-sm">
  <div class="mb-4 flex items-baseline justify-between gap-3">
    <h2 class="text-sm uppercase tracking-wider text-[var(--accent)]" data-i18n="detail.modelSpec">
      Model spec
    </h2>
    {officialUrl && (
      <a
        href={officialUrl}
        target="_blank"
        rel="noopener"
        class="official-link"
        title={`Official site for ${modelTitle ?? "this model"}`}
        data-i18n="detail.officialSite"
      >
        Official site ↗
      </a>
    )}
  </div>

  {typeTags.length > 0 && (
    <div class="type-tags" role="list" aria-label="Model type tags">
      {typeTags.map((c) => (
        <span class={`type-tag type-tag-${c}`} role="listitem" data-i18n={`nodeType.${c}`}>
          {CATEGORY_LABEL[c] ?? c}
        </span>
      ))}
    </div>
  )}


  {
    rows.length > 0 && (
      <dl class="mb-6 flex flex-col gap-5 text-sm">
        {rows.map((r) => {
          const help = FIELD_HELP[r.key];
          const scale = buildScaleCfg(r.key, r.value, spec.context_window);
          const pillCfg = buildPillCfg(r.key, spec.release_type);
          const archTags = r.key === "architecture" ? archChips(r.value) : [];
          const hasMoEMarkers = scale ? scale.markers.some((m) => m.hollow) : false;
          // For MoE rows, pull the largest total + active so the
          // deployment-impact block can quote real numbers
          let moeNums: { total: number; active: number } | null = null;
          if (hasMoEMarkers && r.key === "parameters") {
            const p = parseAllParams(r.value);
            if (p && p.variants.length && p.active.length) {
              moeNums = {
                total: Math.max(...p.variants),
                active: Math.max(...p.active),
              };
            }
          }
          return (
            <div class="spec-row spec-row-stacked">
              {/* Header: label + tooltip on left, value text on right */}
              <div class="spec-row-head">
                <dt class="spec-label" data-i18n={`spec.${r.key}`}>{r.label}</dt>
                {help && (
                  <span class="spec-info-wrap">
                    <button
                      type="button"
                      class="spec-info-btn"
                      aria-label={`What ${r.label.toLowerCase()} means`}
                      tabindex="0"
                    >
                      ⓘ
                    </button>
                    <span class="spec-tooltip" role="tooltip">
                      <strong class="spec-tooltip-q">{help.question}</strong>
                      <span class="spec-tooltip-body">{help.body}</span>
                      {help.link && (
                        <a
                          href={help.link.href}
                          class="spec-tooltip-link"
                          target={help.link.href.startsWith("http") ? "_blank" : undefined}
                          rel={help.link.href.startsWith("http") ? "noopener" : undefined}
                        >
                          {help.link.label} →
                        </a>
                      )}
                    </span>
                  </span>
                )}
                {/* Architecture's raw value duplicates the chips below —
                    skip it; for everything else the value text on the right
                    complements the visualization. */}
                {!(r.key === "architecture" && archTags.length > 0) && (
                  <dd class="spec-value-inline">{r.value}</dd>
                )}
              </div>

              {/* Implication moved ABOVE the visualization — the conclusion
                  is the most useful line; bury it below and people skip it. */}
              {r.implication && (
                <p class="spec-implication">
                  ▸ <span class={r.implicationZh ? "lang-en has-zh" : "lang-en"}>{r.implication}</span>
                  {r.implicationZh && <span class="lang-zh">{r.implicationZh}</span>}
                </p>
              )}

              {/* Architecture: render canonical chips when we recognize tokens */}
              {r.key === "architecture" && archTags.length > 0 && (
                <div class="arch-chips" role="list">
                  {archTags.map((tag) => {
                    const t = ARCH_TIPS[tag];
                    return (
                      <span class="arch-chip chip-with-tip" role="listitem" tabindex="0">
                        {tag}
                        {t && (
                          <span class="dual-tip" role="tooltip">
                            <ul>
                              <li class="tip-tech">{t.tech}</li>
                              <li class="tip-lay">{t.lay}</li>
                            </ul>
                          </span>
                        )}
                      </span>
                    );
                  })}
                </div>
              )}

              {/* Scale bar visualization */}
              {scale && (
                <div
                  class="scale-bar-wrap"
                  style={`--marker-color: ${markerColor};`}
                >
                  <div class="scale-bar">
                    <div class="scale-bar-track" />
                    {scale.ticks.map((t) => (
                      <div class="scale-tick" style={`left: ${tickPos(t, scale)}%;`}>
                        <span class="scale-tick-mark" />
                        <span class="scale-tick-label">{t.label}</span>
                        {t.note && <span class="scale-tick-note" data-i18n={`tick.${t.note}`}>{t.note}</span>}
                      </div>
                    ))}
                    {scale.markers.map((m) => (
                      <div
                        class={`scale-marker ${m.hollow ? "scale-marker-hollow" : ""} stack-${m.stack ?? 0}`}
                        style={`left: ${m.pos}%;`}
                        title={m.rawLabel ?? r.value}
                        aria-label={m.rawLabel ?? r.value}
                      >
                        <span class="scale-marker-dot" />
                        {m.label && (
                          <span
                            class="scale-marker-label"
                            data-i18n={m.label === "this model" ? "spec.thisModel" : undefined}
                          >{m.label}</span>
                        )}
                      </div>
                    ))}
                  </div>
                  {hasMoEMarkers && (
                    <div class="scale-legend">
                      <span class="legend-item">
                        <span class="legend-swatch legend-filled" /> total
                      </span>
                      <span class="legend-item">
                        <span class="legend-swatch legend-hollow" /> active (MoE)
                      </span>
                    </div>
                  )}
                </div>
              )}

              {/* Deployment-impact block — only for MoE parameter rows.
                  Explains what total vs active actually mean for the four
                  decisions that map directly to a procurement question. */}
              {moeNums && (
                <details
                  class="moe-impact"
                  open
                  style={`--marker-color: ${markerColor};`}
                >
                  <summary class="moe-impact-summary">
                    Why total vs active matters
                  </summary>
                  <dl class="moe-impact-grid">
                    <div class="moe-impact-row">
                      <dt class="moe-impact-label">Deployment</dt>
                      <dd class="moe-impact-value">
                        <span class="impact-marker impact-marker-filled" />
                        <strong>{paramLabel(moeNums.total)} total</strong>
                        {" — sets memory + load time. "}
                        <span class="impact-impl">{paramTier(moeNums.total)}-class hardware required.</span>
                      </dd>
                    </div>
                    <div class="moe-impact-row">
                      <dt class="moe-impact-label">Inference cost</dt>
                      <dd class="moe-impact-value">
                        <span class="impact-marker impact-marker-hollow" />
                        <strong>{paramLabel(moeNums.active)} active</strong>
                        {" — drives speed + $/token. "}
                        <span class="impact-impl">≈ a {paramTier(moeNums.active * 2)}-class dense model in latency.</span>
                      </dd>
                    </div>
                    <div class="moe-impact-row">
                      <dt class="moe-impact-label">$/token pricing</dt>
                      <dd class="moe-impact-value">
                        Active alone determines per-token compute, so MoE APIs typically run
                        {" "}<strong>5–10× cheaper</strong>{" "}
                        than equal-quality dense models.
                      </dd>
                    </div>
                    <div class="moe-impact-row">
                      <dt class="moe-impact-label">Capability ceiling</dt>
                      <dd class="moe-impact-value">
                        Knowledge breadth tracks <strong>total</strong> ({paramLabel(moeNums.total)}),
                        not active. The model "knows" what its full parameter count learned;
                        the router just picks which experts speak per token.
                      </dd>
                    </div>
                  </dl>
                </details>
              )}

              {/* Pill group visualization */}
              {pillCfg && (
                <div
                  class="pill-group"
                  role="list"
                  style={`--marker-color: ${markerColor};`}
                >
                  {pillCfg.options.map((opt) => {
                    const isActive = pillCfg!.active.has(opt.id);
                    const t = (opt as { tip?: DualTip }).tip;
                    return (
                      <span
                        class={`pill chip-with-tip ${isActive ? "pill-active" : ""}`}
                        role="listitem"
                        tabindex="0"
                      >
                        {isActive && <span class="pill-dot" />}
                        <span data-i18n={`release.${opt.id}`}>{opt.label}</span>
                        {t && (
                          <span class="dual-tip" role="tooltip">
                            <ul>
                              <li class="tip-tech">{t.tech}</li>
                              <li class="tip-lay">{t.lay}</li>
                            </ul>
                          </span>
                        )}
                      </span>
                    );
                  })}
                </div>
              )}
            </div>
          );
        })}
      </dl>
    )
  }

  {
    spec.benchmarks && spec.benchmarks.length > 0 && (
      <div>
        <div class="mb-2 flex items-center gap-1.5">
          <h3 class="text-xs uppercase tracking-wider text-[var(--fg-muted)]" data-i18n="detail.benchmarks">
            Benchmarks
          </h3>
          {FIELD_HELP.benchmarks && (
            <span class="spec-info-wrap">
              <button
                type="button"
                class="spec-info-btn"
                aria-label="What benchmarks mean"
                tabindex="0"
              >
                ⓘ
              </button>
              <span class="spec-tooltip" role="tooltip">
                <strong class="spec-tooltip-q">
                  {FIELD_HELP.benchmarks.question}
                </strong>
                <span class="spec-tooltip-body">
                  {FIELD_HELP.benchmarks.body}
                </span>
                <a
                  href={FIELD_HELP.benchmarks.link!.href}
                  class="spec-tooltip-link"
                  target="_blank"
                  rel="noopener"
                >
                  {FIELD_HELP.benchmarks.link!.label} →
                </a>
              </span>
            </span>
          )}
        </div>
        {/* Direction H prev→now scale-bar rendering. Each benchmark row shows
            a baseline → current progression on a 0-100 axis with a colored
            delta segment, so readers see the gap AND the magnitude at a glance
            instead of parsing two numbers in a table cell. Rows that don't
            parse as percentages (Elo, prices, ratios) fall back to text-only. */}
        <div class="bench-list" style={`--marker-color: ${markerColor};`}>
          {spec.benchmarks.map((b) => {
            const src = benchSource(b);
            const p = parseBench(b.score, b.vs_baseline);
            const hasScale = p.current !== null;
            const hasDelta = hasScale && p.baseline !== null;
            const delta = hasDelta ? (p.current! - p.baseline!) : null;
            return (
              <div class="bench-row">
                <div class="bench-top">
                  <div class="bench-name">
                    {b.name}
                    <a
                      href={src.url}
                      target="_blank"
                      rel="noopener"
                      class="bench-source-link"
                      title={`Verified on ${src.label}`}
                    >
                      {src.label} ↗
                    </a>
                  </div>
                  <div class="bench-nums">
                    {hasDelta && (
                      <>
                        <span class="bench-prev-num">{p.baseline!.toFixed(1)}%</span>
                        <span class="bench-arrow">→</span>
                      </>
                    )}
                    <span class="bench-curr-num">{b.score}</span>
                    {delta !== null && (
                      <span class={`bench-delta ${delta >= 0 ? "bench-delta-pos" : "bench-delta-neg"}`}>
                        {delta >= 0 ? "+" : ""}{delta.toFixed(1)}
                      </span>
                    )}
                  </div>
                </div>
                {p.baselineLabel && hasDelta && (
                  <div class="bench-baseline-label">
                    vs <span class="bench-baseline-name">{p.baselineLabel}</span>
                  </div>
                )}
                {hasScale ? (
                  <div class="bench-bar">
                    <div class="bench-track" />
                    {[0, 25, 50, 75, 100].map((t) => (
                      <div class="bench-tick" style={`left: ${t}%;`} />
                    ))}
                    {hasDelta && (
                      <div
                        class="bench-fill"
                        style={`left: ${Math.min(p.baseline!, p.current!)}%; width: ${Math.abs(p.current! - p.baseline!)}%;`}
                      />
                    )}
                    {hasDelta && (
                      <div class="bench-marker-prev" style={`left: ${p.baseline}%;`} />
                    )}
                    <div class="bench-marker-curr" style={`left: ${p.current}%;`} />
                    <div class="bench-endpoint bench-endpoint-0">0%</div>
                    <div class="bench-endpoint bench-endpoint-100">100%</div>
                  </div>
                ) : (
                  b.vs_baseline && (
                    <div class="bench-baseline-text">baseline: {b.vs_baseline}</div>
                  )
                )}
              </div>
            );
          })}
        </div>
        <p class="mt-2 text-[10.5px] italic text-[var(--fg-muted)]">
          All ranking scores cite one of three approved leaderboards
          (Artificial Analysis, Hugging Face, LLM Stats). Click "Source"
          to verify.
        </p>
      </div>
    )
  }
</section>

