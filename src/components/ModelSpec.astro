  }

  /* ⓘ tooltip — pure CSS, hover or :focus-within reveal */
  .spec-info-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
  }
  .spec-info-btn {
    background: transparent;
    border: none;
