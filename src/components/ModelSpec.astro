// Parse "15T" / "5.6T" / "1.4T tokens" → trillions
function parseTokensT(s: string): number | null {
  const m = s.match(/(\d+(?:\.\d+)?)\s*([TB])/i);
  if (!m) return null;
  const n = parseFloat(m[1]);
  return m[2].toUpperCase() === "T" ? n : n / 1000;
}

// TRAINING COMPUTE scale — FLOPs exponent (linear axis)
const COMPUTE_TICKS: Tick[] = [
  { label: "1e22", value: 22 },
  { label: "1e23", value: 23, note: "GPT-3 era" },
  { label: "1e24", value: 24 },
  { label: "1e25", value: 25, note: "GPT-4 era" },
  { label: "1e26", value: 26, note: "Frontier" },
];
const COMPUTE_MIN_EXP = 22;
const COMPUTE_MAX_EXP = 26.5;

// Parse "3.8e25" / "2e+25 FLOPs" → exponent (with mantissa contribution)
function parseComputeExp(s: string): number | null {
  const m = s.match(/(\d+(?:\.\d+)?)\s*[eE]\+?(\d+)/);
  if (!m) return null;
  const mant = parseFloat(m[1]);
  const exp = parseInt(m[2], 10);
  return exp + Math.log10(Math.max(1, mant));
}

function linearPos(value: number, min: number, max: number): number {
  if (value <= min) return 0;
  if (value >= max) return 100;
  return ((value - min) / (max - min)) * 100;
}

// ============== Pill-group enum options ==============

const RELEASE_PILLS: { id: string; label: string; note: string }[] = [
  { id: "paper", label: "Paper", note: "Theory only" },
  { id: "demo", label: "Demo", note: "Limited / waitlisted" },
  { id: "open_weights", label: "Open weights", note: "Self-hostable" },
  { id: "api", label: "API", note: "Vendor-hosted" },
  { id: "product", label: "Product", note: "Embedded only" },
];

const MODALITY_PILLS: { id: string; label: string }[] = [
  { id: "text", label: "Text" },
  { id: "vision", label: "Vision" },
  { id: "audio", label: "Audio" },
  { id: "video", label: "Video" },
  { id: "generative", label: "Generative" },
];

// Architecture chip extraction. Splits the free-form architecture
// string into a small set of canonical, recognizable tags. Order of
// checks matters — more specific tokens first.
const ARCH_PATTERNS: { pattern: RegExp; chip: string }[] = [
  { pattern: /\bsparse[- ]attention\b|\bDSA\b/i, chip: "Sparse Attention" },
  { pattern: /\b(linear[- ]attention|lightning[- ]attention)\b/i, chip: "Lightning Attention" },
  { pattern: /\bmamba\b|\bSSM\b|\bstate[- ]?space\b/i, chip: "SSM" },
  { pattern: /\bmixture[- ]of[- ]experts\b|\bMoE\b/i, chip: "MoE" },
  { pattern: /\b(rectified[- ]?flow|MMDiT|DiT)\b/i, chip: "Diffusion / Flow" },
  { pattern: /\bdiffusion\b/i, chip: "Diffusion" },
  { pattern: /\bdecoder[- ]only\b|\bGPT[- ]style\b/i, chip: "Decoder-only" },
  { pattern: /\bencoder[- ]decoder\b|\bseq2seq\b/i, chip: "Encoder-decoder" },
  { pattern: /\bvision encoder\b|\bvision[- ]language\b|\bVL[A]?\b/i, chip: "Vision encoder" },
  { pattern: /\bthinking\b|\breasoning\b|\bRL post[- ]?training\b/i, chip: "Reasoning" },
  { pattern: /\bagent(ic)?\b|\btool[- ]use\b/i, chip: "Agent" },
  { pattern: /\bGNN\b|\bgraph neural\b/i, chip: "GNN" },
  { pattern: /\bU-Net\b/i, chip: "U-Net" },
];

function archChips(s: string): string[] {
  const found: string[] = [];
  for (const { pattern, chip } of ARCH_PATTERNS) {
    if (pattern.test(s) && !found.includes(chip)) found.push(chip);
  }
  return found;
}

// ============== Per-row visualization config builders ==============
// Extracted from the JSX scope so generic types like Set<string> don't
// get mis-parsed as JSX tags.

type Marker = {
  pos: number;
  label?: string;        // small inline label rendered above/below the dot
  hollow?: boolean;
  rawLabel?: string;     // tooltip + value-attribute fallback
  stack?: number;        // 0/1/2 — which staggered row the label sits in
};
type ScaleCfg = { ticks: Tick[]; markers: Marker[]; min: number; max: number; isLinear?: boolean };

// Stagger marker labels into 2-3 rows so adjacent markers don't collide
// on the log axis. We assume ~28px label width and the bar is ~600px
// wide, so anything within ~5% of an earlier marker's column gets bumped.
function staggerMarkers(markers: Marker[]): Marker[] {
  const sorted = [...markers].sort((a, b) => a.pos - b.pos);
  const STAGGER_DIST = 6; // % of bar width
  const stackTops: number[] = [-Infinity, -Infinity, -Infinity];
  for (const m of sorted) {
    let placed = false;
    for (let i = 0; i < stackTops.length; i++) {
      if (m.pos - stackTops[i] >= STAGGER_DIST) {
        m.stack = i;
        stackTops[i] = m.pos;
        placed = true;
        break;
      }
    }
    if (!placed) m.stack = 0; // fall back; let it overlap
  }
  return sorted;
}

function paramLabel(n: number): string {
  if (n >= 1000) return `${(n / 1000).toFixed(n >= 10000 ? 0 : 1)}T`;
  if (n >= 10) return `${Math.round(n)}B`;
  if (n >= 1) return `${n.toFixed(n < 10 ? 1 : 0).replace(/\.0$/, "")}B`;
  return `${Math.round(n * 1000)}M`;
}

function buildScaleCfg(
  key: string,
  value: string,
  ctxWindow: number | undefined,
): ScaleCfg | null {
  if (key === "parameters") {
    const p = parseAllParams(value);
    if (!p) return null;
    const markers: Marker[] = [];
    for (const v of p.variants) {
      markers.push({
        pos: logScalePos(v, PARAM_MIN, PARAM_MAX),
        rawLabel: paramLabel(v),
        label: paramLabel(v),
      });
    }
    for (const v of p.active) {
      markers.push({
        pos: logScalePos(v, PARAM_MIN, PARAM_MAX),
        rawLabel: paramLabel(v),
        label: paramLabel(v),
        hollow: true,
      });
    }
    return { ticks: PARAM_TICKS, markers: staggerMarkers(markers), min: PARAM_MIN, max: PARAM_MAX };
  }
  if (key === "context_window" && ctxWindow) {
    return {
      ticks: CTX_TICKS,
      markers: [{ pos: logScalePos(ctxWindow, CTX_MIN, CTX_MAX), label: "this model" }],
      min: CTX_MIN,
      max: CTX_MAX,
    };
  }
  if (key === "training_tokens") {
    const v = parseTokensT(value);
    if (!v) return null;
    return {
      ticks: TOK_TICKS,
      markers: [{ pos: logScalePos(v, TOK_MIN, TOK_MAX), label: "this model" }],
      min: TOK_MIN,
      max: TOK_MAX,
    };
  }
  if (key === "training_compute") {
    const exp = parseComputeExp(value);
    if (exp == null) return null;
    return {
      ticks: COMPUTE_TICKS,
      markers: [{ pos: linearPos(exp, COMPUTE_MIN_EXP, COMPUTE_MAX_EXP), label: "this model" }],
      min: COMPUTE_MIN_EXP,
      max: COMPUTE_MAX_EXP,
      isLinear: true,
    };
  }
  return null;
}

function tickPos(t: Tick, cfg: ScaleCfg): number {
  return cfg.isLinear ? linearPos(t.value, cfg.min, cfg.max) : logScalePos(t.value, cfg.min, cfg.max);
}

type PillOpt = { id: string; label: string; note?: string };
type PillCfg = { options: PillOpt[]; active: Set<string> };

function buildPillCfg(
  key: string,
  releaseType: string | undefined,
  modalities: string[] | undefined,
): PillCfg | null {
  if (key === "release_type" && releaseType) {
    return { options: RELEASE_PILLS, active: new Set([releaseType]) };
  }
  if (key === "modalities" && modalities) {
    return { options: MODALITY_PILLS, active: new Set(modalities.map((m) => m.toLowerCase())) };
  }
  return null;
}

// ============== Build the row data ==============

type Row = {
  key: string;
  label: string;
  value: string;
  implication: string;
};

const rows: Row[] = [];
if (spec.parameters)
  rows.push({
    key: "parameters",
    label: "Parameters",
    value: spec.parameters,
    implication: paramImpl(spec.parameters),
  });
if (spec.architecture)
  rows.push({
    key: "architecture",
    label: "Architecture",
    value: spec.architecture,
    implication: archImpl(spec.architecture),
  });
if (spec.context_window)
  rows.push({
    key: "context_window",
    label: "Context window",
    value: fmtCtx(spec.context_window) ?? "",
    implication: contextImpl(spec.context_window),
  });
if (spec.training_tokens)
  rows.push({
    key: "training_tokens",
    label: "Training tokens",
    value: spec.training_tokens,
    implication: trainingTokensImpl(spec.training_tokens),
  });
if (spec.training_compute)
  rows.push({
    key: "training_compute",
    label: "Training compute",
    value: spec.training_compute,
    implication: computeImpl(spec.training_compute),
  });
if (spec.release_type)
  rows.push({
    key: "release_type",
    label: "Release type",
    value: spec.release_type,
    implication: licenseImpl(spec.release_type),
  });
if (spec.modalities && spec.modalities.length)
  rows.push({
    key: "modalities",
    label: "Modalities",
    value: spec.modalities.join(", "),
    implication: modalitiesImpl(spec.modalities),
  });
---

<section class="model-spec mb-8 rounded-lg border border-[var(--border)] bg-white p-5 shadow-sm">
  <div class="mb-4 flex items-baseline justify-between gap-3">
    <h2 class="text-sm uppercase tracking-wider text-[var(--accent)]">
      Model spec
    </h2>
    {officialUrl && (
      <a
        href={officialUrl}
        target="_blank"
        rel="noopener"
        class="official-link"
        title={`Official site for ${modelTitle ?? "this model"}`}
      >
        Official site ↗
      </a>
    )}
  </div>


  {
    rows.length > 0 && (
      <dl class="mb-6 flex flex-col gap-5 text-sm">
        {rows.map((r) => {
          const help = FIELD_HELP[r.key];
          const scale = buildScaleCfg(r.key, r.value, spec.context_window);
          const pillCfg = buildPillCfg(r.key, spec.release_type, spec.modalities);
          const archTags = r.key === "architecture" ? archChips(r.value) : [];
          const hasMoEMarkers = scale ? scale.markers.some((m) => m.hollow) : false;
          return (
            <div class="spec-row spec-row-stacked">
              {/* Header: label + tooltip on left, value text on right */}
              <div class="spec-row-head">
                <dt class="spec-label">{r.label}</dt>
                {help && (
                  <span class="spec-info-wrap">
                    <button
                      type="button"
                      class="spec-info-btn"
                      aria-label={`What ${r.label.toLowerCase()} means`}
                      tabindex="0"
                    >
                      ⓘ
                    </button>
                    <span class="spec-tooltip" role="tooltip">
                      <strong class="spec-tooltip-q">{help.question}</strong>
                      <span class="spec-tooltip-body">{help.body}</span>
                      {help.link && (
                        <a
                          href={help.link.href}
                          class="spec-tooltip-link"
                          target={help.link.href.startsWith("http") ? "_blank" : undefined}
                          rel={help.link.href.startsWith("http") ? "noopener" : undefined}
                        >
                          {help.link.label} →
                        </a>
                      )}
                    </span>
                  </span>
                )}
                <dd class="spec-value-inline">{r.value}</dd>
              </div>

              {/* Implication moved ABOVE the visualization — the conclusion
                  is the most useful line; bury it below and people skip it. */}
              {r.implication && (
                <p class="spec-implication">▸ {r.implication}</p>
              )}

              {/* Architecture: render canonical chips when we recognize tokens */}
              {r.key === "architecture" && archTags.length > 0 && (
                <div class="arch-chips" role="list">
                  {archTags.map((tag) => (
                    <span class="arch-chip" role="listitem">{tag}</span>
                  ))}
                </div>
              )}

              {/* Scale bar visualization */}
              {scale && (
                <div
                  class="scale-bar-wrap"
                  style={`--marker-color: ${markerColor};`}
                >
                  <div class="scale-bar">
                    <div class="scale-bar-track" />
                    {scale.ticks.map((t) => (
                      <div class="scale-tick" style={`left: ${tickPos(t, scale)}%;`}>
                        <span class="scale-tick-mark" />
                        <span class="scale-tick-label">{t.label}</span>
                        {t.note && <span class="scale-tick-note">{t.note}</span>}
                      </div>
                    ))}
                    {scale.markers.map((m) => (
                      <div
                        class={`scale-marker ${m.hollow ? "scale-marker-hollow" : ""} stack-${m.stack ?? 0}`}
                        style={`left: ${m.pos}%;`}
                        title={m.rawLabel ?? r.value}
                        aria-label={m.rawLabel ?? r.value}
                      >
                        <span class="scale-marker-dot" />
                        {m.label && (
                          <span class="scale-marker-label">{m.label}</span>
                        )}
                      </div>
                    ))}
                  </div>
                  {hasMoEMarkers && (
                    <div class="scale-legend">
                      <span class="legend-item">
                        <span class="legend-swatch legend-filled" /> total
                      </span>
                      <span class="legend-item">
                        <span class="legend-swatch legend-hollow" /> active (MoE)
                      </span>
                    </div>
                  )}
                </div>
              )}

              {/* Pill group visualization */}
              {pillCfg && (
                <div
                  class="pill-group"
                  role="list"
                  style={`--marker-color: ${markerColor};`}
                >
                  {pillCfg.options.map((opt) => {
                    const isActive = pillCfg!.active.has(opt.id);
                    return (
                      <span
                        class={`pill ${isActive ? "pill-active" : ""}`}
                        role="listitem"
                        title={opt.note ?? ""}
                      >
                        {isActive && <span class="pill-dot" />}
                        {opt.label}
                      </span>
                    );
                  })}
                </div>
              )}
            </div>
          );
        })}
      </dl>
    )
  }

  {
    spec.benchmarks && spec.benchmarks.length > 0 && (
      <div>
        <div class="mb-2 flex items-center gap-1.5">
          <h3 class="text-xs uppercase tracking-wider text-[var(--fg-muted)]">
            Benchmarks
          </h3>
          {FIELD_HELP.benchmarks && (
            <span class="spec-info-wrap">
              <button
                type="button"
                class="spec-info-btn"
                aria-label="What benchmarks mean"
                tabindex="0"
              >
                ⓘ
              </button>
              <span class="spec-tooltip" role="tooltip">
                <strong class="spec-tooltip-q">
                  {FIELD_HELP.benchmarks.question}
                </strong>
                <span class="spec-tooltip-body">
                  {FIELD_HELP.benchmarks.body}
                </span>
                <a
                  href={FIELD_HELP.benchmarks.link!.href}
                  class="spec-tooltip-link"
                  target="_blank"
                  rel="noopener"
                >
                  {FIELD_HELP.benchmarks.link!.label} →
                </a>
              </span>
            </span>
          )}
        </div>
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-[var(--border)] text-left text-xs text-[var(--fg-muted)]">
              <th class="py-1.5 pr-2">Benchmark</th>
              <th class="py-1.5 pr-2">Score</th>
              <th class="py-1.5 pr-2">Baseline</th>
              <th class="py-1.5">Source</th>
            </tr>
          </thead>
          <tbody>
            {spec.benchmarks.map((b) => {
              const src = benchSource(b);
              return (
                <tr class="border-b border-[var(--border)]/60">
                  <td class="py-1.5 pr-2">{b.name}</td>
                  <td class="py-1.5 pr-2 font-mono font-semibold text-[var(--accent)]">
                    {b.score}
                  </td>
                  <td class="py-1.5 pr-2 text-xs text-[var(--fg-muted)]">
                    {b.vs_baseline ?? "—"}
                  </td>
                  <td class="py-1.5 text-xs">
                    <a
                      href={src.url}
                      target="_blank"
                      rel="noopener"
                      class="bench-source-link"
                      title={`Verified on ${src.label}`}
                    >
                      {src.label} ↗
                    </a>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
        <p class="mt-2 text-[10.5px] italic text-[var(--fg-muted)]">
          All ranking scores cite one of three approved leaderboards
          (Artificial Analysis, Hugging Face, LLM Stats). Click "Source"
          to verify.
        </p>
      </div>
    )
  }
</section>

<style>
  .spec-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }
  .spec-row-stacked {
    gap: 8px;
    padding-bottom: 14px;
  }
  .spec-row-head {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .spec-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg-muted);
    font-weight: 700;
  }
  .spec-value {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 13px;
    color: var(--fg);
    margin: 0;
  }
