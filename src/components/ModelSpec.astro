    box-shadow: 0 0 0 1.5px var(--marker-color, #2563eb);
  }

  /* ===== Pill group ===== */
  .pill-group {
    --marker-color: #2563eb;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 2px;
  }
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 11px;
    border-radius: 999px;
