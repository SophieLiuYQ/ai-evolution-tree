---
// Model Spec — value-driven implication + ⓘ tooltip + citations.
//
// Sourcing rules (per project policy):
//   • Every benchmark / ranking score MUST link to one of:
//       llm-stats.com · huggingface.co · artificialanalysis.ai
//     (per-benchmark `source_url` overrides; otherwise default lookup
//     resolves to one of the three).
//   • Every model spec block MUST link to the model's official
//     homepage (`spec.homepage` overrides; otherwise org → homepage
//     fallback applies). Both ensure no number on this page is
//     dangling without an authority behind it.

interface Spec {
  parameters?: string;
  architecture?: string;
  context_window?: number;
  training_tokens?: string;
  training_compute?: string;
  release_type?: string;
  modalities?: string[];
  benchmarks?: {
    name: string;
    score: string;
    vs_baseline?: string;
    source_url?: string;
  }[];
  homepage?: string;
}
interface Props {
  spec: Spec;
  org?: string;
  modelTitle?: string;
}
const { spec, org, modelTitle } = Astro.props;

// ============== Value formatters ==============

const fmtCtx = (n?: number) => {
  if (!n) return null;
  if (n >= 1_000_000) return `${n / 1_000_000}M tokens`;
  if (n >= 1_000) return `${n / 1_000}k tokens`;
  return `${n} tokens`;
};

// ============== Value-driven IMPLICATIONS ==============
// One sentence about what this specific value means in practice.

function paramImpl(s: string): string {
  const isMoE = /\b(MoE|active|experts?)\b/i.test(s);
  const m = s.match(/(\d+(?:\.\d+)?)\s*([BMK])/i);
  if (!m) return isMoE ? "MoE — total ≠ active params" : "";
  const n = parseFloat(m[1]);
  const unit = m[2].toUpperCase();
  let b = n;
  if (unit === "M") b = n / 1000;
  if (unit === "K") b = n / 1_000_000;
  const tier =
    b < 3
      ? "Edge / mobile-class"
      : b < 15
        ? "Single consumer GPU (RTX 4090)"
        : b < 80
          ? "Workstation (A100 80GB)"
          : b < 300
            ? "Multi-GPU (A100 × 4–8)"
            : "Datacenter-scale";
  return isMoE ? `${tier} · MoE (active params drive cost)` : tier;
}

function contextImpl(n: number): string {
  if (n < 16_000) return "Single chat / short prompt";
  if (n < 64_000) return "Long doc / chapter fits";
  if (n < 256_000) return "Whole book / long PDF fits";
  if (n < 1_000_000) return "Multi-doc RAG, full repo possible";
  return "Whole codebase / corpus fits";
}

function licenseImpl(t: string): string {
  switch (t) {
    case "open_weights":
      return "Self-hostable — no vendor lock";
    case "api":
      return "Vendor-hosted only — pay per token";
    case "product":
      return "Embedded in a product — no raw access";
    case "paper":
      return "Research artifact — no public weights";
    case "demo":
      return "Limited / waitlisted access";
    default:
      return "";
  }
}

function archImpl(s: string): string {
  const x = s.toLowerCase();
  if (/\bmoe\b|mixture/.test(x))
    return "MoE — only some experts fire per token (cheap inference)";
  if (/mamba|ssm|state[- ]?space/.test(x))
    return "Linear-time alternative to attention";
  if (/diffusion|rectified[- ]?flow/.test(x))
    return "Iterative-refinement generation";
  if (/sparse[- ]?attention/.test(x))
    return "Sub-quadratic attention — long context cheaper";
  if (/decoder[- ]?only|gpt[- ]?style/.test(x)) return "Standard LLM topology";
  if (/encoder[- ]?decoder|seq2seq/.test(x))
    return "Encoder-decoder (seq2seq lineage)";
  return "";
}

function modalitiesImpl(arr: string[]): string {
  const set = new Set(arr.map((m) => m.toLowerCase()));
  if (set.has("video") || (set.has("audio") && set.has("vision")))
    return "Native omni-modal — text+image+audio+video";
  if (set.has("vision") && set.has("audio"))
    return "Reads images and listens to speech";
  if (set.has("vision")) return "Reads images / PDFs / screenshots";
  if (set.has("audio")) return "Speech I/O";
  if (arr.length === 1) return `${arr[0]} only`;
  return arr.join(" + ");
}

function trainingTokensImpl(s: string): string {
  const m = s.match(/(\d+(?:\.\d+)?)\s*([TB])/i);
  if (!m) return "";
  const n = parseFloat(m[1]);
  const t = m[2].toUpperCase() === "T" ? n : n / 1000;
  if (t >= 15) return "Heavily trained — modern frontier scale";
  if (t >= 5) return "Modern scale (post-Chinchilla optimal)";
  if (t >= 1) return "Light training — likely undertrained";
  return "Small training corpus";
}

function computeImpl(s: string): string {
  const m = s.match(/(\d+(?:\.\d+)?)e(\+?)(\d+)/i);
  if (!m) return "";
  const exp = parseInt(m[3], 10);
  if (exp >= 26) return "Frontier-class — datacenter-month order";
  if (exp >= 25) return "GPT-4 era (~$50–100M training cost)";
  if (exp >= 24) return "GPT-3 era (~$5–15M training cost)";
  return "Pre-frontier compute";
}

// ============== "Why this matters" tooltip help text ==============
// One concise paragraph + a "Learn more" link to the most relevant
// internal node or external resource.

const FIELD_HELP: Record<
  string,
  { question: string; body: string; link?: { label: string; href: string } }
> = {
  parameters: {
    question: "How many GPUs do I need to run this?",
    body: "7B fits a single RTX 4090. 70B needs an A100 80GB or 4× consumer GPUs. 700B+ needs a datacenter. For Mixture-of-Experts, total parameters set RAM but only the active parameters drive inference cost — MoE wins on cost-per-token.",
    link: { label: "Scaling laws (Kaplan 2020)", href: "/node/scaling-laws/" },
  },
  architecture: {
    question: "What's the topology — and what does that imply about cost?",
    body: "Decoder-only transformers are the default since GPT-3. Mixture-of-Experts (MoE) cuts inference cost by activating a fraction of params per token. State-space models (Mamba) and sparse attention dodge attention's n² scaling for long context.",
    link: { label: "Transformer (Vaswani 2017)", href: "/node/transformer/" },
  },
  context_window: {
    question: "How much can I shove into a single prompt?",
    body: "8k = single chat. 32–128k = long documents. 1M+ = whole codebases. The context window directly determines whether the model fits your RAG / agent / long-doc workflow without chunking gymnastics.",
    link: { label: "DeepSeek V3.2 (sparse attention)", href: "/node/deepseek-v3-2/" },
  },
  training_tokens: {
    question: "Was it trained on enough data?",
    body: "Chinchilla showed that compute-optimal training pairs ~20 tokens per parameter. 15T+ tokens at frontier scale is heavily trained; 1T at 70B is undertrained and explains weak performance even before benchmarks.",
    link: { label: "Chinchilla scaling laws", href: "/node/chinchilla/" },
  },
  training_compute: {
    question: "How much did it cost to train — and who can replicate it?",
    body: "Total FLOPs is the rough cost proxy. GPT-4 ≈ 2×10²⁵ FLOPs ≈ $50–100M. DeepSeek V3 reported ~$5.6M via algorithmic efficiency. Lower compute = more replicable = thinner moat.",
    link: { label: "Epoch AI compute trends", href: "https://epoch.ai/data/notable-ai-models" },
  },
  release_type: {
    question: "Can I get the weights — and on what license?",
    body: "open_weights: download and self-host. api: rent per token. product: only inside a vendor app. paper / demo: theoretical or waitlisted. The 2026 split is regional — most Chinese frontier models are open; most US frontier models are closed.",
    link: { label: "Filter the tree by license", href: "/tree/" },
  },
  modalities: {
    question: "What inputs and outputs does it handle natively?",
    body: "Native multimodal (single backbone for text+image+audio+video) is now table stakes for frontier models like GPT-5, Gemini 3, Claude 4.x. Single-modality models are increasingly niche.",
    link: { label: "GPT-4o (native omni-modal)", href: "/node/gpt-4o/" },
  },
  benchmarks: {
    question: "How is it actually measured — and against what baseline?",
    body: "Absolute scores mean little without context. Always read the baseline column: a 70% on SWE-bench is mediocre against a 72% Claude baseline, frontier against a 49% one. Benchmark hill-climbing also drifts (training contamination), so trust deltas more than absolute peaks.",
    link: { label: "Open LLM Leaderboard", href: "https://huggingface.co/spaces/HuggingFaceH4/open_llm_leaderboard" },
  },
};

// ============== Benchmark → leaderboard source ==============
// Default citation source for each benchmark. Constrained to the three
// approved authorities: artificialanalysis.ai (frontier evals),
// huggingface.co (open-weight evals), llm-stats.com (cross-model
// comparison). A node's per-benchmark `source_url` overrides this.

type LBProvider = "artificialanalysis" | "huggingface" | "llm-stats";
const LB_HOME: Record<LBProvider, { label: string; url: string }> = {
  "artificialanalysis": { label: "Artificial Analysis", url: "https://artificialanalysis.ai/" },
  "huggingface": { label: "Hugging Face", url: "https://huggingface.co/spaces/HuggingFaceH4/open_llm_leaderboard" },
  "llm-stats": { label: "LLM Stats", url: "https://llm-stats.com/" },
};

const BENCHMARK_PROVIDER: Record<string, LBProvider> = {
  // Frontier reasoning + generic LLM (artificialanalysis)
  "MMLU": "artificialanalysis",
  "MMLU-Pro": "artificialanalysis",
  "GPQA": "artificialanalysis",
  "GPQA Diamond": "artificialanalysis",
  "AIME": "artificialanalysis",
  "AIME 2024": "artificialanalysis",
  "AIME 2025": "artificialanalysis",
  "Humanity's Last Exam": "artificialanalysis",
  "BrowseComp": "artificialanalysis",
  "Artificial Analysis Intelligence": "artificialanalysis",
  // Coding (artificialanalysis tracks SWE-bench Verified)
  "SWE-bench": "artificialanalysis",
  "SWE-bench Verified": "artificialanalysis",
  "HumanEval": "huggingface",
  "Terminal-Bench": "artificialanalysis",
  "LiveCodeBench v5": "artificialanalysis",
  "RepoBench": "huggingface",
  "Codeforces": "artificialanalysis",
  // Math
  "MATH": "huggingface",
  "GSM8K": "huggingface",
  // Multimodal (artificialanalysis)
  "MathVista": "artificialanalysis",
  "MMMU": "artificialanalysis",
  "MMMU-Pro": "artificialanalysis",
  // Image / video (artificialanalysis covers image + video arenas)
  "VBench": "artificialanalysis",
  // Cross-comparison (llm-stats)
  "ChatBot Arena": "llm-stats",
  "ChatBot Arena Elo": "llm-stats",
  "LMArena": "llm-stats",
  "ARC-AGI": "artificialanalysis",
  // Hallucination (artificialanalysis tracks FACTS Grounding)
  "FACTS Grounding": "artificialanalysis",
  "Hallucination rate (FACTS Grounding)": "artificialanalysis",
  // Tool use
  "BFL-v3 tool use": "artificialanalysis",
  "BFCL-v3 tool use": "artificialanalysis",
};

// Resolve a citation URL for a benchmark row. Priority:
//   1. explicit source_url on the row
//   2. exact-match provider in BENCHMARK_PROVIDER
//   3. prefix-match provider (e.g., "AIME 2025" → "AIME")
//   4. default to artificialanalysis.ai homepage
function benchSource(b: { name: string; source_url?: string }): {
  label: string;
  url: string;
} {
  if (b.source_url) {
    // Detect which provider hosts the URL for the label
    if (/llm-stats\.com/.test(b.source_url)) return { label: "LLM Stats", url: b.source_url };
    if (/huggingface\.co/.test(b.source_url)) return { label: "Hugging Face", url: b.source_url };
    if (/artificialanalysis\.ai/.test(b.source_url))
      return { label: "Artificial Analysis", url: b.source_url };
    return { label: "Source", url: b.source_url };
  }
  let provider: LBProvider | undefined = BENCHMARK_PROVIDER[b.name];
  if (!provider) {
    for (const k of Object.keys(BENCHMARK_PROVIDER)) {
      if (b.name.startsWith(k)) {
        provider = BENCHMARK_PROVIDER[k];
        break;
      }
    }
  }
  return LB_HOME[provider ?? "artificialanalysis"];
}

