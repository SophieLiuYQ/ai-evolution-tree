<section class="model-spec mb-8 rounded-lg border border-[var(--border)] bg-white p-5 shadow-sm">
  <div class="mb-4 flex items-baseline justify-between gap-3">
    <h2 class="text-sm uppercase tracking-wider text-[var(--accent)]" data-i18n="detail.modelSpec">
      Model spec
    </h2>
    {officialUrl && (
      <a
        href={officialUrl}
        target="_blank"
        rel="noopener"
        class="official-link"
        title={`Official site for ${modelTitle ?? "this model"}`}
        data-i18n="detail.officialSite"
      >
        Official site ↗
      </a>
    )}
  </div>

  {typeTags.length > 0 && (
    <div class="type-tags" role="list" aria-label="Model type tags">
      {typeTags.map((c) => (
        <span class={`type-tag type-tag-${c}`} role="listitem" data-i18n={`nodeType.${c}`}>
          {CATEGORY_LABEL[c] ?? c}
        </span>
      ))}
    </div>
  )}


  {
    rows.length > 0 && (
      <dl class="mb-6 flex flex-col gap-5 text-sm">
        {rows.map((r) => {
          const help = FIELD_HELP[r.key];
          const scale = buildScaleCfg(r.key, r.value, spec.context_window);
          const pillCfg = buildPillCfg(r.key, spec.release_type);
          const archTags = r.key === "architecture" ? archChips(r.value) : [];
          const hasMoEMarkers = scale ? scale.markers.some((m) => m.hollow) : false;
          // For MoE rows, pull the largest total + active so the
          // deployment-impact block can quote real numbers
          let moeNums: { total: number; active: number } | null = null;
          if (hasMoEMarkers && r.key === "parameters") {
            const p = parseAllParams(r.value);
            if (p && p.variants.length && p.active.length) {
              moeNums = {
                total: Math.max(...p.variants),
                active: Math.max(...p.active),
              };
            }
          }
          return (
            <div class="spec-row spec-row-stacked">
              {/* Header: label + tooltip on left, value text on right */}
              <div class="spec-row-head">
                <dt class="spec-label" data-i18n={`spec.${r.key}`}>{r.label}</dt>
                {help && (
                  <span class="spec-info-wrap">
                    <button
                      type="button"
                      class="spec-info-btn"
                      aria-label={`What ${r.label.toLowerCase()} means`}
                      tabindex="0"
                    >
                      ⓘ
                    </button>
                    <span class="spec-tooltip" role="tooltip">
                      {/* 3-section tooltip: 什么是 X / 有哪些种类 /
                          本模型用的是. Dual-language via .lang-en /
                          .lang-zh sibling spans — CSS picks the right
                          one based on <html lang>. */}
                      <strong class="spec-tooltip-q">
                        <span class="lang-en has-zh">{help.title.en}</span>
                        <span class="lang-zh">{help.title.zh}</span>
                      </strong>
                      <span class="spec-tooltip-body">
                        <span class="lang-en has-zh">{help.what.en}</span>
                        <span class="lang-zh">{help.what.zh}</span>
                      </span>

                      <strong class="spec-tooltip-q spec-tooltip-q-sub">
                        <span class="lang-en has-zh">{help.kinds_title?.en ?? HELP_TITLE_KINDS.en}</span>
                        <span class="lang-zh">{help.kinds_title?.zh ?? HELP_TITLE_KINDS.zh}</span>
                      </strong>
                      <span class="spec-tooltip-body spec-tooltip-list">
                        <span class="lang-en has-zh">{help.kinds.en}</span>
                        <span class="lang-zh">{help.kinds.zh}</span>
                      </span>

                      {help.special && (
                        <>
                          <strong class="spec-tooltip-q spec-tooltip-q-sub">
                            <span class="lang-en has-zh">{help.special.title.en}</span>
                            <span class="lang-zh">{help.special.title.zh}</span>
                          </strong>
                          <span class="spec-tooltip-body">
                            <span class="lang-en has-zh">{help.special.body.en}</span>
                            <span class="lang-zh">{help.special.body.zh}</span>
                          </span>
                        </>
                      )}

                      <strong class="spec-tooltip-q spec-tooltip-q-sub">
                        <span class="lang-en has-zh">{HELP_TITLE_THIS.en}</span>
                        <span class="lang-zh">{HELP_TITLE_THIS.zh}</span>
                      </strong>
                      <span class="spec-tooltip-body spec-tooltip-this">
                        {r.value}
                        {r.implication && (
                          <>
                            {" — "}
                            <span class={r.implicationZh ? "lang-en has-zh" : "lang-en"}>{r.implication}</span>
                            {r.implicationZh && <span class="lang-zh">{r.implicationZh}</span>}
                          </>
                        )}
                      </span>
                    </span>
                  </span>
                )}
                {/* Architecture's raw value duplicates the chips below —
                    skip it; for everything else the value text on the right
                    complements the visualization. */}
                {!(r.key === "architecture" && archTags.length > 0) && (
                  <dd class="spec-value-inline">{r.value}</dd>
                )}
              </div>

              {/* Implication moved ABOVE the visualization — the conclusion
                  is the most useful line; bury it below and people skip it. */}
              {r.implication && (
                <p class="spec-implication">
                  ▸ <span class={r.implicationZh ? "lang-en has-zh" : "lang-en"}>{r.implication}</span>
                  {r.implicationZh && <span class="lang-zh">{r.implicationZh}</span>}
                </p>
              )}

              {/* Architecture: render canonical chips when we recognize tokens */}
              {r.key === "architecture" && archTags.length > 0 && (
                <div class="arch-chips" role="list">
                  {archTags.map((tag) => {
                    const t = ARCH_TIPS[tag];
                    return (
                      <span class="arch-chip chip-with-tip" role="listitem" tabindex="0">
                        {tag}
                        {t && (
                          <span class="dual-tip" role="tooltip">
                            <ul>
                              <li class="tip-tech">{t.tech}</li>
                              <li class="tip-lay">{t.lay}</li>
                            </ul>
                          </span>
                        )}
                      </span>
                    );
                  })}
                </div>
              )}

              {/* Scale bar visualization */}
              {scale && (
                <div
                  class="scale-bar-wrap"
                  style={`--marker-color: ${markerColor};`}
                >
                  <div class="scale-bar">
                    <div class="scale-bar-track" />
                    {scale.ticks.map((t) => (
                      <div class="scale-tick" style={`left: ${tickPos(t, scale)}%;`}>
                        <span class="scale-tick-mark" />
                        <span class="scale-tick-label">{t.label}</span>
                        {t.note && <span class="scale-tick-note" data-i18n={`tick.${t.note}`}>{t.note}</span>}
                      </div>
                    ))}
                    {scale.markers.map((m) => (
                      <div
                        class={`scale-marker ${m.hollow ? "scale-marker-hollow" : ""} stack-${m.stack ?? 0}`}
                        style={`left: ${m.pos}%;`}
                        title={m.rawLabel ?? r.value}
                        aria-label={m.rawLabel ?? r.value}
                      >
                        <span class="scale-marker-dot" />
                        {m.label && (
                          <span
                            class="scale-marker-label"
                            data-i18n={m.label === "this model" ? "spec.thisModel" : undefined}
                          >{m.label}</span>
                        )}
                      </div>
                    ))}
                  </div>
                  {hasMoEMarkers && (
                    <div class="scale-legend">
                      <span class="legend-item">
                        <span class="legend-swatch legend-filled" /> total
                      </span>
                      <span class="legend-item">
                        <span class="legend-swatch legend-hollow" /> active (MoE)
                      </span>
                    </div>
                  )}
                </div>
              )}

              {/* Deployment-impact block — only for MoE parameter rows.
                  Explains what total vs active actually mean for the four
                  decisions that map directly to a procurement question. */}
              {moeNums && (
                <details
                  class="moe-impact"
                  open
                  style={`--marker-color: ${markerColor};`}
                >
                  <summary class="moe-impact-summary">
                    Why total vs active matters
                  </summary>
                  <dl class="moe-impact-grid">
                    <div class="moe-impact-row">
                      <dt class="moe-impact-label">Deployment</dt>
                      <dd class="moe-impact-value">
                        <span class="impact-marker impact-marker-filled" />
                        <strong>{paramLabel(moeNums.total)} total</strong>
                        {" — sets memory + load time. "}
                        <span class="impact-impl">{paramTier(moeNums.total)}-class hardware required.</span>
                      </dd>
                    </div>
                    <div class="moe-impact-row">
                      <dt class="moe-impact-label">Inference cost</dt>
                      <dd class="moe-impact-value">
                        <span class="impact-marker impact-marker-hollow" />
                        <strong>{paramLabel(moeNums.active)} active</strong>
                        {" — drives speed + $/token. "}
                        <span class="impact-impl">≈ a {paramTier(moeNums.active * 2)}-class dense model in latency.</span>
                      </dd>
                    </div>
                    <div class="moe-impact-row">
                      <dt class="moe-impact-label">$/token pricing</dt>
                      <dd class="moe-impact-value">
                        Active alone determines per-token compute, so MoE APIs typically run
                        {" "}<strong>5–10× cheaper</strong>{" "}
                        than equal-quality dense models.
                      </dd>
                    </div>
                    <div class="moe-impact-row">
                      <dt class="moe-impact-label">Capability ceiling</dt>
                      <dd class="moe-impact-value">
                        Knowledge breadth tracks <strong>total</strong> ({paramLabel(moeNums.total)}),
                        not active. The model "knows" what its full parameter count learned;
                        the router just picks which experts speak per token.
                      </dd>
                    </div>
                  </dl>
                </details>
              )}

              {/* Pill group visualization */}
              {pillCfg && (
                <div
                  class="pill-group"
                  role="list"
                  style={`--marker-color: ${markerColor};`}
                >
                  {pillCfg.options.map((opt) => {
                    const isActive = pillCfg!.active.has(opt.id);
                    const t = (opt as { tip?: DualTip }).tip;
                    return (
                      <span
                        class={`pill chip-with-tip ${isActive ? "pill-active" : ""}`}
                        role="listitem"
                        tabindex="0"
                      >
                        {isActive && <span class="pill-dot" />}
                        <span data-i18n={`release.${opt.id}`}>{opt.label}</span>
                        {t && (
                          <span class="dual-tip" role="tooltip">
                            <ul>
                              <li class="tip-tech">{t.tech}</li>
                              <li class="tip-lay">{t.lay}</li>
                            </ul>
                          </span>
                        )}
                      </span>
                    );
                  })}
                </div>
              )}
            </div>
          );
        })}
      </dl>
    )
  }

  {
    spec.benchmarks && spec.benchmarks.length > 0 && (
      <div>
        <div class="mb-2 flex items-center gap-1.5">
          <h3 class="text-xs uppercase tracking-wider text-[var(--fg-muted)]" data-i18n="detail.benchmarks">
            Benchmarks
          </h3>
          {FIELD_HELP.benchmarks && (
            <span class="spec-info-wrap">
              <button
                type="button"
                class="spec-info-btn"
                aria-label="What benchmarks mean"
                tabindex="0"
              >
                ⓘ
              </button>
              <span class="spec-tooltip" role="tooltip">
                {/* Same 2-section structure as spec rows, minus the
                    per-model "this model" chunk since benchmarks is
                    many rows, not a single value. */}
                <strong class="spec-tooltip-q">
                  <span class="lang-en has-zh">{FIELD_HELP.benchmarks.title.en}</span>
                  <span class="lang-zh">{FIELD_HELP.benchmarks.title.zh}</span>
                </strong>
                <span class="spec-tooltip-body">
                  <span class="lang-en has-zh">{FIELD_HELP.benchmarks.what.en}</span>
                  <span class="lang-zh">{FIELD_HELP.benchmarks.what.zh}</span>
                </span>

                <strong class="spec-tooltip-q spec-tooltip-q-sub">
                  <span class="lang-en has-zh">{FIELD_HELP.benchmarks.kinds_title?.en ?? HELP_TITLE_KINDS.en}</span>
                  <span class="lang-zh">{FIELD_HELP.benchmarks.kinds_title?.zh ?? HELP_TITLE_KINDS.zh}</span>
                </strong>
                <span class="spec-tooltip-body">
                  <span class="lang-en has-zh">{FIELD_HELP.benchmarks.kinds.en}</span>
                  <span class="lang-zh">{FIELD_HELP.benchmarks.kinds.zh}</span>
                </span>
              </span>
            </span>
          )}
        </div>
        {/* Direction H prev→now scale-bar rendering. Each benchmark row shows
            a baseline → current progression on a 0-100 axis with a colored
            delta segment, so readers see the gap AND the magnitude at a glance
            instead of parsing two numbers in a table cell. Rows that don't
            parse as percentages (Elo, prices, ratios) fall back to text-only. */}
        <div class="bench-list" style={`--marker-color: ${markerColor};`}>
          {spec.benchmarks.map((b) => {
            const src = benchSource(b);
            const p = parseBench(b.score, b.vs_baseline);
            const hasScale = p.current !== null;
            const hasDelta = hasScale && p.baseline !== null;
            const delta = hasDelta ? (p.current! - p.baseline!) : null;
            return (
              <div class="bench-row">
                <div class="bench-top">
                  <div class="bench-name">
                    {b.name}
                    <a
                      href={src.url}
                      target="_blank"
                      rel="noopener"
                      class="bench-source-link"
                      title={`Verified on ${src.label}`}
                    >
                      {src.label} ↗
                    </a>
                  </div>
                  <div class="bench-nums">
                    {hasDelta && (
                      <>
                        <span class="bench-prev-num">{p.baseline!.toFixed(1)}%</span>
                        <span class="bench-arrow">→</span>
                      </>
                    )}
                    <span class="bench-curr-num">{b.score}</span>
                    {delta !== null && (
                      <span class={`bench-delta ${delta >= 0 ? "bench-delta-pos" : "bench-delta-neg"}`}>
                        {delta >= 0 ? "+" : ""}{delta.toFixed(1)}
                      </span>
                    )}
                  </div>
                </div>
                {p.baselineLabel && hasDelta && (
                  <div class="bench-baseline-label">
                    vs <span class="bench-baseline-name">{p.baselineLabel}</span>
                  </div>
                )}
                {hasScale ? (
                  <div class="bench-bar">
                    <div class="bench-track" />
                    {[0, 25, 50, 75, 100].map((t) => (
                      <div class="bench-tick" style={`left: ${t}%;`} />
                    ))}
                    {hasDelta && (
                      <div
                        class="bench-fill"
                        style={`left: ${Math.min(p.baseline!, p.current!)}%; width: ${Math.abs(p.current! - p.baseline!)}%;`}
                      />
                    )}
                    {hasDelta && (
                      <div class="bench-marker-prev" style={`left: ${p.baseline}%;`} />
                    )}
                    <div class="bench-marker-curr" style={`left: ${p.current}%;`} />
                    <div class="bench-endpoint bench-endpoint-0">0%</div>
                    <div class="bench-endpoint bench-endpoint-100">100%</div>
                  </div>
                ) : (
                  b.vs_baseline && (
                    <div class="bench-baseline-text">baseline: {b.vs_baseline}</div>
                  )
                )}
              </div>
            );
          })}
        </div>
        <p class="mt-2 text-[10.5px] italic text-[var(--fg-muted)]">
          All ranking scores cite one of three approved leaderboards
          (Artificial Analysis, Hugging Face, LLM Stats). Click "Source"
          to verify.
        </p>
      </div>
    )
  }
</section>

<style>
  /* Type scale — match the site's Tailwind defaults (xs=12, sm=14, base=16)
     so this card doesn't read in 9-11px when everything else is 12-16px.
     Spacing also tightened so the section is dense without feeling cramped. */
  .spec-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
  .spec-row-stacked {
    gap: 6px;
    padding-bottom: 10px;
  }
  .spec-row-head {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .spec-label {
    font-size: 12px;          /* text-xs */
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg-muted);
    font-weight: 700;
  }
  .spec-value {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 14px;          /* text-sm */
    color: var(--fg);
    margin: 0;
  }
  .spec-value-inline {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 14px;          /* text-sm */
    color: var(--fg);
    margin: 0 0 0 auto;
    text-align: right;
  }
  .spec-implication {
    font-size: 14px;          /* text-sm — was 11.5, hidden as a footnote */
    color: var(--fg-muted);
    margin: 0;
    font-style: italic;
  }

  /* ===== Architecture chips ===== */
  .arch-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-top: 2px;
  }
  .arch-chip {
    display: inline-flex;
    align-items: center;
    padding: 3px 9px;
    border-radius: 4px;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 12px;          /* text-xs */
    font-weight: 600;
    color: #475569;
    background: #f1f5f9;
    border: 1px solid #e2e8f0;
  }

  /* ===== Scale bar ===== */
  .scale-bar-wrap {
    --marker-color: #2563eb;
    padding: 88px 4px 60px;  /* room for 4-stack labels + tick + notes + legend */
  }
  .scale-bar {
    position: relative;
    height: 6px;
    margin: 0 8px;
  }
  .scale-bar-track {
    position: absolute;
    inset: 0;
    border-radius: 3px;
    background: linear-gradient(to right, #f1f5f9 0%, #e2e8f0 50%, #cbd5e1 100%);
  }
  .scale-tick {
    position: absolute;
    top: 0;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: none;
  }
  .scale-tick-mark {
    width: 1px;
    height: 10px;
    background: #94a3b8;
    margin-top: -2px;
  }
  .scale-tick-label {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 12px;           /* text-xs — was 10.5, sub-system size */
    color: #475569;
    margin-top: 4px;
    white-space: nowrap;
  }
  .scale-tick-note {
    font-size: 12px;           /* text-xs */
    color: #64748b;
    margin-top: 1px;
    white-space: nowrap;
    font-weight: 500;
  }
  .scale-marker {
    position: absolute;
    top: -6px;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 2;
  }
  .scale-marker-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--marker-color);
    border: 2px solid white;
    box-shadow: 0 0 0 1px var(--marker-color), 0 1px 2px rgba(15, 23, 42, 0.18);
  }
  .scale-marker-label {
    position: absolute;
    bottom: 100%;
    margin-bottom: 6px;
    padding: 1px 5px;
    border-radius: 3px;
    background: white;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 11px;            /* was 9.5 — too small for monospace digits */
    font-weight: 700;
    color: var(--marker-color);
    white-space: nowrap;
  }
  /* Stagger labels into up to 4 vertical rows. Bumped row spacing to fit
     the new 11px label height + comfortable connector. */
  .scale-marker.stack-0 .scale-marker-label { margin-bottom: 6px; }
  .scale-marker.stack-1 .scale-marker-label { margin-bottom: 26px; }
  .scale-marker.stack-2 .scale-marker-label { margin-bottom: 46px; }
  .scale-marker.stack-3 .scale-marker-label { margin-bottom: 66px; }
  .scale-marker.stack-1 .scale-marker-label::after,
  .scale-marker.stack-2 .scale-marker-label::after,
  .scale-marker.stack-3 .scale-marker-label::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 100%;
    width: 1px;
    background: var(--marker-color);
    opacity: 0.45;
  }
  .scale-marker.stack-1 .scale-marker-label::after { height: 20px; }
  .scale-marker.stack-2 .scale-marker-label::after { height: 40px; }
  .scale-marker.stack-3 .scale-marker-label::after { height: 60px; }

  /* MoE active marker — hollow dot on white, same color border */
  .scale-marker-hollow .scale-marker-dot {
    background: white;
    box-shadow: 0 0 0 2px var(--marker-color), 0 1px 2px rgba(15, 23, 42, 0.18);
  }

  .scale-legend {
    margin-top: 42px;
    display: flex;
    justify-content: flex-end;
    gap: 14px;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 12px;             /* text-xs */
    color: #64748b;
  }
  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }
  .legend-swatch {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .legend-filled {
    background: var(--marker-color, #2563eb);
    border: 1.5px solid white;
    box-shadow: 0 0 0 1px var(--marker-color, #2563eb);
  }
  .legend-hollow {
    background: white;
    box-shadow: 0 0 0 1.5px var(--marker-color, #2563eb);
  }

  /* ===== MoE total/active explainer block ===== */
  .moe-impact {
    --marker-color: var(--marker-color, #2563eb);
    margin-top: 2px;
    border: 1px solid var(--border, #e2e8f0);
    border-radius: 8px;
    background: #fafbfc;
    padding: 0;
  }
  .moe-impact-summary {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    cursor: pointer;
    list-style: none;
    font-size: 12px;             /* text-xs */
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #475569;
    user-select: none;
    border-radius: 8px;
  }
  .moe-impact-summary::-webkit-details-marker { display: none; }
  .moe-impact-summary::before {
    content: "▸";
    font-size: 10px;
    color: #94a3b8;
    transition: transform 0.15s ease;
  }
  .moe-impact[open] .moe-impact-summary::before {
    transform: rotate(90deg);
  }
  .moe-impact-summary:hover { color: #0f172a; }

  .moe-impact-grid {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: 4px 14px;
    padding: 0 12px 10px;
    margin: 0;
    border-top: 1px solid #f1f5f9;
    padding-top: 8px;
  }
  .moe-impact-row {
    display: contents;
  }
  .moe-impact-label {
    font-size: 12px;             /* text-xs */
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #64748b;
    align-self: start;
    padding-top: 2px;
  }
  .moe-impact-value {
    font-size: 14px;             /* text-sm — readable body copy */
    line-height: 1.5;
    color: #1e293b;
    margin: 0;
  }
  .moe-impact-value strong {
    font-weight: 700;
    color: #0f172a;
  }
  .impact-impl {
    color: #64748b;
    font-style: italic;
  }

  /* Inline ●/○ markers used in the impact value text */
  .impact-marker {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    margin-right: 5px;
    vertical-align: -1px;
  }
  .impact-marker-filled {
    background: var(--marker-color, #2563eb);
    box-shadow: 0 0 0 1px var(--marker-color, #2563eb);
  }
  .impact-marker-hollow {
    background: white;
    box-shadow: 0 0 0 1.5px var(--marker-color, #2563eb);
  }

  /* ===== Pill group ===== */
  .pill-group {
    --marker-color: #2563eb;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 2px;
  }
