  /* ===== Architecture chips ===== */
  .arch-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-top: 2px;
  }
  .arch-chip {
    display: inline-flex;
    align-items: center;
    padding: 3px 9px;
    border-radius: 4px;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 11px;
    font-weight: 600;
    color: #475569;
    background: #f1f5f9;
    border: 1px solid #e2e8f0;
  }

  /* ===== Scale bar ===== */
  .scale-bar-wrap {
    --marker-color: #2563eb;
    padding: 60px 4px 38px;  /* top: 3-stack label room, bottom: tick + notes */
  }
  .scale-bar {
    position: relative;
    height: 6px;
    margin: 0 8px;
  }
  .scale-bar-track {
    position: absolute;
    inset: 0;
    border-radius: 3px;
    background: linear-gradient(to right, #f1f5f9 0%, #e2e8f0 50%, #cbd5e1 100%);
  }
  .scale-tick {
    position: absolute;
    top: 0;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: none;
  }
  .scale-tick-mark {
    width: 1px;
    height: 10px;
    background: #94a3b8;
    margin-top: -2px;
  }
  .scale-tick-label {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 10.5px;
    color: #64748b;
    margin-top: 3px;
    white-space: nowrap;
  }
  .scale-tick-note {
    font-size: 10px;
    color: #64748b;
    margin-top: 1px;
    white-space: nowrap;
    font-weight: 500;
  }
  .scale-marker {
    position: absolute;
    top: -6px;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 2;
  }
  .scale-marker-dot {
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: var(--marker-color);
    border: 2px solid white;
    box-shadow: 0 0 0 1px var(--marker-color), 0 1px 2px rgba(15, 23, 42, 0.18);
  }
  .scale-marker-label {
    position: absolute;
    bottom: 100%;
    margin-bottom: 5px;
    padding: 1px 5px;
    border-radius: 3px;
    background: white;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 9.5px;
    font-weight: 700;
    color: var(--marker-color);
    white-space: nowrap;
  }
  /* Stagger labels into 3 vertical rows so neighboring markers don't
     collide on the log axis. The connector line bridges marker to label. */
  .scale-marker.stack-0 .scale-marker-label { margin-bottom: 5px; }
  .scale-marker.stack-1 .scale-marker-label { margin-bottom: 22px; }
  .scale-marker.stack-2 .scale-marker-label { margin-bottom: 39px; }
  .scale-marker.stack-1 .scale-marker-label::after,
  .scale-marker.stack-2 .scale-marker-label::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 100%;
    width: 1px;
    background: var(--marker-color);
    opacity: 0.45;
  }
  .scale-marker.stack-1 .scale-marker-label::after { height: 17px; }
  .scale-marker.stack-2 .scale-marker-label::after { height: 34px; }

  /* MoE active marker — hollow dot on white, same color border */
  .scale-marker-hollow .scale-marker-dot {
    background: white;
    box-shadow: 0 0 0 2px var(--marker-color), 0 1px 2px rgba(15, 23, 42, 0.18);
  }

  .scale-legend {
    margin-top: 18px;
    display: flex;
