---
import type { CollectionEntry } from "astro:content";
import {
  HIDDEN_EDGE_TYPES,
  edgeStyle,
  fill as orgFillColor,
  stroke as orgStrokeColor,
} from "../lib/graph/constants";
import { normalizeCategories } from "../lib/categories";
import { normalizeOrg } from "../lib/org-display";
import { computeLayout, groupByYear } from "../lib/graph/layout";
import type { Layout, Rel, SortMode } from "../lib/graph/types";
import { SORT_MODES } from "../lib/graph/types";
import LegendPanel from "./graph/LegendPanel.astro";
import OrientPane from "./graph/OrientPane.astro";
import ZoomModal from "./graph/ZoomModal.astro";

interface Props {
  nodes: CollectionEntry<"nodes">[];
}
const { nodes } = Astro.props;

const { byYear, years } = groupByYear(nodes);

// Org → count for the LegendPanel "Company" filter. Sorted by count
// desc with alphabetical tiebreaker so the high-volume labs (OpenAI,
// Google, Anthropic, ...) sit at the top of the scrollable list.
// `normalizeOrg` collapses the Google / DeepMind / Google DeepMind
// triad into one "Google/DeepMind" bucket so the filter has a single
// row per real lab.
const orgCountMap = new Map<string, number>();
for (const n of nodes) {
  const o = normalizeOrg(n.data.org);
  orgCountMap.set(o, (orgCountMap.get(o) ?? 0) + 1);
}
const orgs = Array.from(orgCountMap.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => (b.count - a.count) || a.name.localeCompare(b.name));

// Pre-compute every (orient × sort mode) layout. Layout dimensions are
// the same across sort modes within an orient; only intra-year card
// positions and routed edges change. Default = chronological.
const sortIds = SORT_MODES.map((m) => m.id);
const layouts: Record<"h" | "v", Record<SortMode, Layout>> = {
  h: Object.fromEntries(
    sortIds.map((m) => [m, computeLayout(nodes, byYear, years, "h", m)]),
  ) as Record<SortMode, Layout>,
  v: Object.fromEntries(
    sortIds.map((m) => [m, computeLayout(nodes, byYear, years, "v", m)]),
  ) as Record<SortMode, Layout>,
};
const horizontal = layouts.h.chronological;
const vertical = layouts.v.chronological;

// Pack a layout into the minimal client shape (edges + node positions).
const packLayout = (layout: Layout) => ({
  edges: layout.edges
    .filter((e) => !HIDDEN_EDGE_TYPES.has(e.type))
    .map((e) => ({ v: e.v, w: e.w, type: e.type, d: e.d, midX: e.midX, midY: e.midY })),
  nodePos: Object.fromEntries(
    layout.placedNodes.map((p) => [
      p.slug,
      { x: p.x, y: p.y, w: p.width, h: p.height },
    ]),
  ),
});

// Year-grouped data for the Compact view. Each tile carries the same
// data-cats / data-license / data-org / data-slug attrs as the SVG
// cards, so the existing filter chain (node-types.ts) applies to
// compact tiles too without any fork in the filter logic. Year rows
// keep the time axis visible when the tree collapses to a grid —
// rows whose tiles all get filtered out hide automatically via CSS
// `:has()` so the remaining years stack tightly.
const compactYears = (() => {
  const sortedNodes = [...nodes].sort(
    (a, b) => a.data.date.getTime() - b.data.date.getTime(),
  );
  const map = new Map<number, CollectionEntry<"nodes">[]>();
  for (const n of sortedNodes) {
    const y = n.data.date.getFullYear();
    const bucket = map.get(y) ?? [];
    bucket.push(n);
    map.set(y, bucket);
  }
  return Array.from(map.entries())
    .sort(([a], [b]) => a - b)
    .map(([year, ns]) => ({ year, nodes: ns }));
})();
const fmtCompactDate = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "short" });
const compactLicense = (n: CollectionEntry<"nodes">) => {
  const rt = n.data.model_spec?.release_type;
  if (!rt || rt === "open_weights" || rt === "paper") return "open";
  return "closed";
};

// Embedded JSON the client script reads on init. Holds all 6 layout
// variants; client swaps by orient + sort mode without recomputing.
const clientPayload = {
  edgeStyle: Object.fromEntries(
    Object.entries(edgeStyle).filter(
      ([t]) => !HIDDEN_EDGE_TYPES.has(t as Rel["type"]),
    ),
  ),
  layouts: {
    h: Object.fromEntries(sortIds.map((m) => [m, packLayout(layouts.h[m])])),
    v: Object.fromEntries(sortIds.map((m) => [m, packLayout(layouts.v[m])])),
  },
};
---

<figure class="ai-tree-graph overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
  <div class="graph-body flex">
    <LegendPanel orgs={orgs} />

    <div class="canvas-area min-w-0 flex-1">
      {/* 6 panes: 2 orients × 3 sort modes. Only one is visible at a time;
          orient.ts + sort.ts toggle display via data-orient + data-sort. */}
      <div class="panes-wrap">
        {(["h", "v"] as const).flatMap((orient) =>
          sortIds.map((m) => (
            <OrientPane
              layout={layouts[orient][m]}
              orient={orient}
              sortMode={m}
              yearsTotal={layouts[orient][m].bands.length}
              hidden={!(orient === "v" && m === "chronological")}
            />
          )),
        )}
      </div>

      {/* Compact view — a year-grouped grid that replaces the SVG tree
          when `.compact-mode` is active on the figure. Keeps the time
          axis visible (year labels run down the left gutter) so the
          chronology of the filtered set is still legible — just without
          the tree's empty-space bands. Tiles share the same data-*
          attribute grammar as the SVG cards so node-types.ts's filter
          chain applies without modification. Year rows with all tiles
          filtered out auto-hide via the CSS `:has()` rule below. */}
      <div class="compact-list" aria-label="Compact tree view">
        {compactYears.map(({ year, nodes: yearNodes }) => (
          <div class="compact-year" data-year={year}>
            <div class="compact-year-label">{year}</div>
            <div class="compact-year-tiles">
              {yearNodes.map((n) => {
                const d = n.data;
                const lic = compactLicense(n);
                const monthLabel = fmtCompactDate(d.date);
                return (
                  <a
                    href={`/node/${d.slug}/`}
                    class="node-link compact-tile"
                    data-slug={d.slug}
                    data-cats={normalizeCategories(d.category).join(" ")}
                    data-license={lic}
                    data-org={normalizeOrg(d.org)}
                    style={`--tile-stroke: ${orgStrokeColor(d.org)}; --tile-fill: ${orgFillColor(d.org)};`}
                  >
                    <div class="compact-tile-meta">{monthLabel} · {normalizeOrg(d.org)}</div>
                    <div class="compact-tile-title">{d.title}</div>
                  </a>
                );
              })}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <script
    type="application/json"
    id="ai-tree-graph-data"
    set:html={JSON.stringify(clientPayload)}
  />

  <ZoomModal />
</figure>

<script>
  import "../scripts/graph/main.ts";
</script>

<style>
  /* Figure shell — each child component owns its own CSS to keep Astro's
     scoping intact. (A parent component's <style> doesn't reach descendant
     component markup because the scope hashes don't match.) */
  .ai-tree-graph {
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .ai-tree-graph .graph-body {
    flex: 1;
    min-height: 0;
  }
  .ai-tree-graph .canvas-area {
    display: flex;
    flex-direction: column;
    min-height: 0;
  }
  @media (max-width: 720px) {
    .ai-tree-graph .graph-body { flex-direction: column; }
  }

  /* ===== Compact view — year-grouped grid replaces the SVG tree
     when active. Toggled via `.compact-mode` class on `.ai-tree-graph`
     (see compact.ts). The SVG panes get hidden, the year grid gets
     shown. Same filter chain applies — .card-filtered on a tile
     becomes display:none in compact mode so only visible tiles show. */
  .panes-wrap { display: contents; }
  .compact-list {
    display: none;
    padding: 20px 24px;
    overflow-y: auto;
    flex-direction: column;
    gap: 2px;
  }
  .ai-tree-graph.compact-mode .panes-wrap { display: none; }
  .ai-tree-graph.compact-mode .compact-list { display: flex; }
  /* Compact view = pure chronological browser: filters do NOT apply
     here. Per user feedback 2026-04-21, the gray/hide treatment that
     normally goes with .card-filtered is overridden inside compact
     mode so every tile renders normally regardless of filter state.
     The card-filtered class still gets toggled by node-types.ts (so
     toggling back to tree view picks up the filter again), it just
     has no visual effect inside .compact-mode. */
  .ai-tree-graph.compact-mode .compact-tile {
    opacity: 1 !important;
    filter: none !important;
    pointer-events: auto !important;
    display: flex !important;
  }

  /* Each year row: fixed-width year label gutter on the left, tiles
     flow-wrap to the right. Rows stack vertically so the time axis
     reads top→bottom. */
  .compact-year {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 20px;
    padding: 10px 0;
    border-top: 1px dashed #e2e8f0;
  }
  .compact-year:first-child { border-top: none; }
  .compact-year-label {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 18px;
    font-weight: 700;
    color: #475569;
    letter-spacing: 0.02em;
    padding-top: 4px;
    text-align: right;
    align-self: start;
    position: sticky;
    top: 0;
  }
  .compact-year-tiles {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-content: flex-start;
  }

  .compact-tile {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 8px 12px 9px 13px;
    background: white;
    border: 1px solid #e2e8f0;
    border-left: 4px solid var(--tile-stroke, #64748b);
    border-radius: 6px;
    text-decoration: none;
    color: #0f172a;
    transition: transform 0.12s ease, box-shadow 0.12s ease, border-color 0.12s ease;
    width: 220px;
    min-height: 52px;
  }
  .compact-tile:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px -2px rgba(15, 23, 42, 0.12);
    border-color: var(--tile-stroke, #cbd5e1);
  }
  .compact-tile-meta {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 10.5px;
    font-weight: 600;
    color: var(--tile-stroke, #475569);
    letter-spacing: 0.01em;
  }
  .compact-tile-title {
    font-size: 13px;
    font-weight: 600;
    line-height: 1.25;
    color: #1e293b;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
