---
import type { CollectionEntry } from "astro:content";
import {
  HIDDEN_EDGE_TYPES,
  edgeStyle,
  fill as orgFillColor,
  stroke as orgStrokeColor,
} from "../lib/graph/constants";
import { normalizeCategories } from "../lib/categories";
import { normalizeOrg } from "../lib/org-display";
import { computeLayout, familyKey, groupByYear } from "../lib/graph/layout";
import { fmtCtx, normalizeTitleCasing, simplifyParams } from "../lib/graph/text";
import type { Layout, Rel, SortMode } from "../lib/graph/types";
import { SORT_MODES } from "../lib/graph/types";
import LegendPanel from "./graph/LegendPanel.astro";
import MobileCardList from "./graph/MobileCardList.astro";
import OrientPane from "./graph/OrientPane.astro";
import InspectorPanel from "./graph/InspectorPanel.astro";

interface Props {
  nodes: CollectionEntry<"nodes">[];
}
const { nodes } = Astro.props;

// Support collapsing SKU-level nodes into a single series node: nodes with
// `graph_hidden: true` should never render in the tree view.
const hasFeatured = nodes.some((n) => n.data.graph_featured);
const graphNodes = nodes.filter((n) => {
  if (n.data.graph_hidden) return false;
  if (hasFeatured) return !!n.data.graph_featured;
  return true;
});

const { byYear, years } = groupByYear(graphNodes);

// Org → count for the LegendPanel "Company" filter. Sorted by count
// desc with alphabetical tiebreaker so the high-volume labs (OpenAI,
// Google, Anthropic, ...) sit at the top of the scrollable list.
// `normalizeOrg` collapses the Google / DeepMind / Google DeepMind
// triad into one "Google/DeepMind" bucket so the filter has a single
// row per real lab.
const orgCountMap = new Map<string, number>();
for (const n of graphNodes) {
  const o = normalizeOrg(n.data.org);
  orgCountMap.set(o, (orgCountMap.get(o) ?? 0) + 1);
}
const orgs = Array.from(orgCountMap.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => (b.count - a.count) || a.name.localeCompare(b.name));

// Category tag → count for the LegendPanel "Capabilities" filter.
// Note: nodes can contribute to multiple capability tags.
const nodeTypeCounts: Record<string, number> = {};
for (const n of graphNodes) {
  for (const c of normalizeCategories(n.data.category)) {
    nodeTypeCounts[c] = (nodeTypeCounts[c] ?? 0) + 1;
  }
}

// License bucket counts for the LegendPanel "License" filter. Must
// match the node filter logic in node-types.ts:
// - "open"   = release_type === "open_weights" (downloadable weights)
// - "closed" = everything else: api, product, demo, paper, or unset.
//   (Papers describe a model but don't ship weights, so they don't
//   belong under "Open source".)
const licenseCounts: Record<"open" | "closed", number> = { open: 0, closed: 0 };
for (const n of graphNodes) {
  const rt = n.data.model_spec?.release_type;
  const lic = rt === "open_weights" ? "open" : "closed";
  licenseCounts[lic]++;
}

// Pre-compute every (orient × sort mode) layout. Layout dimensions are
// the same across sort modes within an orient; only intra-year card
// positions and routed edges change. Default = chronological.
const sortIds = SORT_MODES.map((m) => m.id);
const layouts: Record<"h" | "v", Record<SortMode, Layout>> = {
  h: Object.fromEntries(
    sortIds.map((m) => [m, computeLayout(graphNodes, byYear, years, "h", m)]),
  ) as Record<SortMode, Layout>,
  v: Object.fromEntries(
    sortIds.map((m) => [m, computeLayout(graphNodes, byYear, years, "v", m)]),
  ) as Record<SortMode, Layout>,
};
const horizontal = layouts.h.chronological;
const vertical = layouts.v.chronological;

// Pack a layout into the minimal client shape (edges + node positions).
const packLayout = (layout: Layout) => ({
  edges: layout.edges
    .filter((e) => !HIDDEN_EDGE_TYPES.has(e.type))
    .map((e) => ({ v: e.v, w: e.w, type: e.type, d: e.d, midX: e.midX, midY: e.midY })),
  nodePos: Object.fromEntries(
    layout.placedNodes.map((p) => [
      p.slug,
      { x: p.x, y: p.y, w: p.width, h: p.height },
    ]),
  ),
});

const compactLicense = (n: CollectionEntry<"nodes">) => {
  const rt = n.data.model_spec?.release_type;
  return rt === "open_weights" ? "open" : "closed";
};
const fmtCompactDate = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "short" });
const fmtCompactRelease = (rt?: string) => {
  switch (rt) {
    case "open_weights":
      return "Open";
    case "api":
      return "API";
    case "product":
      return "Product";
    case "demo":
      return "Demo";
    case "paper":
      return "Paper";
    default:
      return "";
  }
};
const compactSpecLine = (n: CollectionEntry<"nodes">) => {
  const parts: string[] = [];
  if (n.data.model_spec?.parameters) {
    parts.push(simplifyParams(n.data.model_spec.parameters));
  }
  if (n.data.model_spec?.context_window) {
    parts.push(`${fmtCtx(n.data.model_spec.context_window)} ctx`);
  }
  return parts.join(" · ");
};
const compactFamilyLabel = (family: string, org: string) => {
  const normOrg = normalizeOrg(org);
  if (family.startsWith(`${normOrg} `)) return family.slice(normOrg.length + 1);
  const orgRaw = String(org);
  if (family.startsWith(`${orgRaw} `)) return family.slice(orgRaw.length + 1);
  return family;
};

const compactNodes = graphNodes.filter((n) => {
  const spec = n.data.model_spec;
  return !!spec && spec.release_type !== "paper";
});
const compactYears = Array.from(
  new Set(compactNodes.map((n) => n.data.date.getFullYear())),
).sort((a, b) => a - b);

const COMPACT_LABEL_W = 170;
const COMPACT_COL_W = 248;
const COMPACT_TILE_W = 208;
const COMPACT_TILE_H = 88;
const COMPACT_TILE_GAP = 10;
const COMPACT_ROW_PAD_Y = 20;
const COMPACT_ROW_MIN_H = 120;

type CompactCell = {
  slug: string;
  x: number;
  y: number;
  year: number;
  yearIdx: number;
};
type CompactRow = {
  family: string;
  familyLabel: string;
  org: string;
  accent: string;
  fill: string;
  rowHeight: number;
  nodes: CollectionEntry<"nodes">[];
  cells: CompactCell[];
  connections: { from: string; to: string; d: string }[];
};

const compactRows: CompactRow[] = (() => {
  const grouped = new Map<string, CollectionEntry<"nodes">[]>();
  for (const n of compactNodes) {
    const key = familyKey(n);
    const bucket = grouped.get(key) ?? [];
    bucket.push(n);
    grouped.set(key, bucket);
  }
  return Array.from(grouped.entries())
    .map(([family, ns]) => {
      const rowNodes = [...ns].sort(
        (a, b) => a.data.date.getTime() - b.data.date.getTime(),
      );
      const byYearMap = new Map<number, CollectionEntry<"nodes">[]>();
      for (const n of rowNodes) {
        const y = n.data.date.getFullYear();
        const bucket = byYearMap.get(y) ?? [];
        bucket.push(n);
        byYearMap.set(y, bucket);
      }
      const maxStack = Math.max(
        1,
        ...compactYears.map((year) => byYearMap.get(year)?.length ?? 0),
      );
      const rowHeight = Math.max(
        COMPACT_ROW_MIN_H,
        COMPACT_ROW_PAD_Y * 2 +
          maxStack * COMPACT_TILE_H +
          Math.max(0, maxStack - 1) * COMPACT_TILE_GAP,
      );

      const cells: CompactCell[] = [];
      for (const [year, yearNodes] of byYearMap.entries()) {
        const yearIdx = compactYears.indexOf(year);
        yearNodes.forEach((node, idx) => {
          cells.push({
            slug: node.data.slug,
            year,
            yearIdx,
            x: yearIdx * COMPACT_COL_W + (COMPACT_COL_W - COMPACT_TILE_W) / 2,
            y: COMPACT_ROW_PAD_Y + idx * (COMPACT_TILE_H + COMPACT_TILE_GAP),
          });
        });
      }
      const cellBySlug = new Map(cells.map((c) => [c.slug, c]));
      const connections = rowNodes.slice(1).flatMap((node, idx) => {
        const prev = rowNodes[idx];
        const from = cellBySlug.get(prev.data.slug);
        const to = cellBySlug.get(node.data.slug);
        if (!from || !to) return [];
        const startX = from.x + COMPACT_TILE_W;
        const startY = from.y + COMPACT_TILE_H / 2;
        const endX = to.x;
        const endY = to.y + COMPACT_TILE_H / 2;
        const dx = Math.max(28, (endX - startX) * 0.45);
        return [{
          from: prev.data.slug,
          to: node.data.slug,
          d: `M ${startX} ${startY} C ${startX + dx} ${startY}, ${endX - dx} ${endY}, ${endX} ${endY}`,
        }];
      });

      const lead = rowNodes[0];
      return {
        family,
        familyLabel: compactFamilyLabel(family, lead.data.org),
        org: normalizeOrg(lead.data.org),
        accent: orgStrokeColor(lead.data.org),
        fill: orgFillColor(lead.data.org),
        rowHeight,
        nodes: rowNodes,
        cells,
        connections,
      };
    })
    .sort((a, b) => {
      const aLatest = a.nodes[a.nodes.length - 1]?.data.date.getTime() ?? 0;
      const bLatest = b.nodes[b.nodes.length - 1]?.data.date.getTime() ?? 0;
      return (bLatest - aLatest) || a.org.localeCompare(b.org) || a.family.localeCompare(b.family);
    });
})();

// Embedded JSON the client script reads on init. Holds all 6 layout
// variants; client swaps by orient + sort mode without recomputing.
const clientPayload = {
  edgeStyle: Object.fromEntries(
    Object.entries(edgeStyle).filter(
      ([t]) => !HIDDEN_EDGE_TYPES.has(t as Rel["type"]) && t !== "open_alt_to",
    ),
  ),
  nodes: Object.fromEntries(
    graphNodes.map((n) => [
      n.data.slug,
      {
        slug: n.data.slug,
        title: n.data.title,
        org: n.data.org,
        date: n.data.date.toISOString(),
        era: n.data.era,
        category: n.data.category,
        breakthrough_score: n.data.breakthrough_score,
        public_view: {
          plain_english: n.data.public_view.plain_english,
        },
        relationships: n.data.relationships,
        model_spec: n.data.model_spec
          ? {
              family: n.data.model_spec.family ?? familyKey(n),
              parameters: n.data.model_spec.parameters,
              context_window: n.data.model_spec.context_window,
              release_type: n.data.model_spec.release_type,
              best_for: n.data.model_spec.best_for,
              availability: n.data.model_spec.availability,
              modalities: n.data.model_spec.modalities,
              modalities_in: n.data.model_spec.modalities_in,
              modalities_out: n.data.model_spec.modalities_out,
              benchmarks: n.data.model_spec.benchmarks,
              homepage: n.data.model_spec.homepage,
              github: n.data.model_spec.github,
              aa_url: n.data.model_spec.aa_url,
              hf_url: n.data.model_spec.hf_url,
              last_verified_at: n.data.model_spec.last_verified_at?.toISOString(),
              variants: n.data.model_spec.variants?.map((v) => ({
                id: v.id,
                label: v.label,
                status: v.status,
                released_at: v.released_at?.toISOString(),
                benchmarks: v.benchmarks,
              })),
            }
          : undefined,
      },
    ]),
  ),
  layouts: {
    h: Object.fromEntries(sortIds.map((m) => [m, packLayout(layouts.h[m])])),
    v: Object.fromEntries(sortIds.map((m) => [m, packLayout(layouts.v[m])])),
  },
};
---

<figure class="ai-tree-graph overflow-hidden rounded-xl shadow-sm">
  <div class="graph-body flex">
    <LegendPanel orgs={orgs} nodeTypeCounts={nodeTypeCounts} licenseCounts={licenseCounts} />

    <div class="canvas-area min-w-0 flex-1">
      {/* Mobile-only card list — replaces the SVG tree on viewports
          ≤720px. Carries the same data-license/data-cats/data-org as
          the SVG cards so the existing LegendPanel filter chain
          (node-types.ts) and search (search.ts) work without forks. */}
      <MobileCardList nodes={graphNodes} />

      {/* 6 panes: 2 orients × 3 sort modes. Only one is visible at a time;
          orient.ts + sort.ts toggle display via data-orient + data-sort. */}
      <div class="panes-wrap">
        {(["h", "v"] as const).flatMap((orient) =>
          sortIds.map((m) => (
            <OrientPane
              layout={layouts[orient][m]}
              orient={orient}
              sortMode={m}
              yearsTotal={layouts[orient][m].bands.length}
              hidden={!(orient === "v" && m === "chronological")}
            />
          )),
        )}
      </div>

      {/* Compact view — switches from the spatial graph to a model-family
          board: family rows, year columns, explicit within-family
          connectors, and denser model briefs. This view intentionally
          focuses on model releases (not method papers) so the board reads
          like a lineage browser rather than a second copy of the SVG. */}
      <div class="compact-list" aria-label="Compact tree view">
        <div
          class="compact-board"
          style={`--compact-label-w:${COMPACT_LABEL_W}px; --compact-col-w:${COMPACT_COL_W}px; --compact-tile-w:${COMPACT_TILE_W}px; --compact-tile-h:${COMPACT_TILE_H}px; --compact-years:${compactYears.length};`}
        >
          <div class="compact-board-head">
            <div class="compact-board-spacer"></div>
            <div class="compact-year-strip">
              {compactYears.map((year) => (
                <div class="compact-year-head">{year}</div>
              ))}
            </div>
          </div>

          <div class="compact-rows">
            {compactRows.map((row) => (
              <section class="compact-row" style={`--row-height:${row.rowHeight}px; --row-accent:${row.accent}; --row-fill:${row.fill};`}>
                <div class="compact-family">
                  <div class="compact-family-name">{row.familyLabel}</div>
                  <div class="compact-family-org">{row.org}</div>
                </div>

                <div class="compact-track">
                  <div class="compact-column-grid" aria-hidden="true">
                    {compactYears.map(() => <span class="compact-col-line"></span>)}
                  </div>

                  <svg
                    class="compact-links"
                    viewBox={`0 0 ${compactYears.length * COMPACT_COL_W} ${row.rowHeight}`}
                    preserveAspectRatio="none"
                    aria-hidden="true"
                  >
                    {row.connections.map((edge) => (
                      <path d={edge.d}></path>
                    ))}
                  </svg>

                  {row.cells.map((cell) => {
                    const n = row.nodes.find((node) => node.data.slug === cell.slug);
                    if (!n) return null;
                    const d = n.data;
                    const lic = compactLicense(n);
                    const releasePill = fmtCompactRelease(d.model_spec?.release_type);
                    const specLine = compactSpecLine(n);
                    return (
                      <a
                        href={`/node/${d.slug}/`}
                        class="node-link compact-tile"
                        data-slug={d.slug}
                        data-cats={normalizeCategories(d.category).join(" ")}
                        data-license={lic}
                        data-org={normalizeOrg(d.org)}
                        style={`--tile-stroke:${orgStrokeColor(d.org)}; --tile-fill:${orgFillColor(d.org)}; left:${cell.x}px; top:${cell.y}px;`}
                      >
                        <div class="compact-tile-topline">
                          <span class="compact-tile-month">{fmtCompactDate(d.date)}</span>
                          {releasePill && <span class="compact-tile-pill">{releasePill}</span>}
                        </div>
                        <div class="compact-tile-title">{normalizeTitleCasing(d.title)}</div>
                        <div class="compact-tile-org">{normalizeOrg(d.org)}</div>
                        {specLine && <div class="compact-tile-spec">{specLine}</div>}
                      </a>
                    );
                  })}
                </div>
              </section>
            ))}
          </div>
        </div>
      </div>
    </div>

    <InspectorPanel />
  </div>

  <script
    type="application/json"
    id="ai-tree-graph-data"
    set:html={JSON.stringify(clientPayload)}
  />
</figure>

<script>
  import "../scripts/graph/main.ts";
</script>

<style is:global>
  /* GLOBAL mobile rules — un-scoped on purpose so they override every
     descendant component's own scoped CSS without hash-matching. The
     SVG tree and compact-list sub-trees live inside Graph.astro's
     descendants (OrientPane, etc.), each with their own scope hashes.
     A scoped media query can't always reach them under Astro's dev-mode
     CSS injection, hence `is:global` here. */
  @media (max-width: 720px) {
    /* Hide the entire SVG tree subtree and compact view on mobile.
       MobileCardList sibling renders the same nodes as a card list. */
    .ai-tree-graph .panes-wrap,
    .ai-tree-graph .compact-list,
    .ai-tree-graph .compact-board,
    .ai-tree-graph .orient-pane,
    .ai-tree-graph .panes-wrap > *,
    .ai-tree-graph .canvas-area > .panes-wrap,
    .ai-tree-graph .canvas-area > .compact-list {
      display: none !important;
      visibility: hidden !important;
      width: 0 !important;
      height: 0 !important;
      max-height: 0 !important;
      overflow: hidden !important;
      contain: strict;
    }
    /* Force the mobile-card-list to be the only thing rendering, and
       give it a sized flex parent so its calc() height resolves. */
    .ai-tree-graph .mobile-card-list {
      display: flex !important;
    }
    .ai-tree-graph .canvas-area {
      height: 100% !important;
      min-height: 0 !important;
      width: 100% !important;
      overflow: hidden !important;
    }
    .ai-tree-graph .graph-body {
      height: 100% !important;
      min-height: 0 !important;
    }
  }
</style>

<style>
  /* Figure shell — each child component owns its own CSS to keep Astro's
     scoping intact. (A parent component's <style> doesn't reach descendant
     component markup because the scope hashes don't match.) */
  .ai-tree-graph {
    background: var(--bg-soft);
    border: 1px solid var(--border);
    height: 100%;
    display: flex;
    flex-direction: column;
    color: var(--fg);
  }
  .ai-tree-graph .graph-body {
    flex: 1;
    min-height: 0;
  }
  .ai-tree-graph .canvas-area {
    display: flex;
    flex-direction: column;
    min-height: 0;
    position: relative;
  }
  @media (max-width: 720px) {
    /* Mobile: graph-body becomes the positioning context for the
       LegendPanel (which slides in as an overlay drawer instead of
       stealing layout space). Canvas takes the full viewport so the
       card list is the primary tap surface. */
    .ai-tree-graph .graph-body {
      flex-direction: row;
      position: relative;
    }
    .ai-tree-graph .canvas-area {
      width: 100%;
    }
  }


  /* ===== Compact view — model-family board with a sticky year header,
     family rows, and explicit within-family connectors. Compact mode is
     a second visualization surface, not just a denser copy of the SVG. */
  .panes-wrap { display: contents; }
  .compact-list {
    display: none;
    padding: 16px 18px 18px 18px;
    overflow-y: auto;
    overflow-x: auto;
  }
  .ai-tree-graph.compact-mode .panes-wrap { display: none; }
  .ai-tree-graph.compact-mode .compact-list { display: block; }
  .ai-tree-graph.compact-mode .compact-tile {
    opacity: 1 !important;
    filter: none !important;
    pointer-events: auto !important;
    display: flex !important;
  }

  .compact-board {
    min-width: calc(var(--compact-label-w) + var(--compact-years) * var(--compact-col-w));
  }
  .compact-board-head {
    position: sticky;
    top: 0;
    z-index: 5;
    display: grid;
    grid-template-columns: var(--compact-label-w) 1fr;
    background:
      linear-gradient(to bottom, rgba(251, 249, 243, 0.98), rgba(251, 249, 243, 0.94));
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
    margin-bottom: 10px;
  }
  .compact-board-spacer {
    border-right: 1px solid rgba(15, 23, 42, 0.06);
  }
  .compact-year-strip {
    display: grid;
    grid-template-columns: repeat(var(--compact-years), minmax(0, 1fr));
  }
  .compact-year-head {
    padding: 12px 0;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 18px;
    font-weight: 700;
    color: var(--fg-muted);
    text-align: center;
    border-left: 1px dashed rgba(15, 23, 42, 0.08);
  }

  .compact-rows {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-bottom: 24px;
  }
  .compact-row {
    display: grid;
    grid-template-columns: var(--compact-label-w) 1fr;
    gap: 18px;
    min-height: var(--row-height);
    padding: 6px 0 12px 0;
    border-bottom: 1px dashed rgba(15, 23, 42, 0.08);
  }
  .compact-family {
    position: sticky;
    left: 0;
    align-self: start;
    padding-top: 14px;
    background: linear-gradient(to right, var(--bg-soft) 78%, rgba(251, 249, 243, 0));
    z-index: 2;
  }
  .compact-family-name {
    font-size: 17px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--fg);
  }
  .compact-family-org {
    margin-top: 4px;
    font-size: 12px;
    color: var(--fg-muted);
  }

  .compact-track {
    position: relative;
    min-height: var(--row-height);
  }
  .compact-column-grid {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: repeat(var(--compact-years), var(--compact-col-w));
    pointer-events: none;
  }
  .compact-col-line {
    border-left: 1px dashed rgba(15, 23, 42, 0.08);
  }
  .compact-col-line:last-child {
    border-right: 1px dashed rgba(15, 23, 42, 0.08);
  }
  .compact-links {
    position: absolute;
    inset: 0;
    width: calc(var(--compact-years) * var(--compact-col-w));
    height: var(--row-height);
    overflow: visible;
    pointer-events: none;
  }
  .compact-links path {
    fill: none;
    stroke: color-mix(in srgb, var(--row-accent) 70%, white 30%);
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    opacity: 0.9;
  }

  .compact-tile {
    position: absolute;
    display: flex;
    flex-direction: column;
    gap: 3px;
    width: var(--compact-tile-w);
    min-height: var(--compact-tile-h);
    padding: 10px 12px 10px 14px;
    background: color-mix(in srgb, white 78%, var(--tile-fill) 22%);
    border: 1px solid color-mix(in srgb, var(--tile-stroke) 30%, white 70%);
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
    border-radius: 18px;
    text-decoration: none;
    color: var(--fg);
    transition: border-color 140ms ease, box-shadow 140ms ease, transform 140ms ease;
  }
  .compact-tile:hover {
    transform: translateY(-1px);
    border-color: var(--tile-stroke);
    box-shadow: 0 14px 30px rgba(15, 23, 42, 0.09);
  }
  .compact-tile.selected-card {
    border-color: var(--tile-stroke);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--tile-stroke) 24%, white 76%), 0 16px 32px rgba(15, 23, 42, 0.12);
  }
  .compact-tile-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .compact-tile-month {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
