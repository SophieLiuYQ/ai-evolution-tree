---
import type { CollectionEntry } from "astro:content";

interface Props {
  current: CollectionEntry<"nodes">;
  all: CollectionEntry<"nodes">[];
}
const { current, all } = Astro.props;

const relTypeLabels: Record<string, string> = {
  builds_on: "Builds on",
  scales: "Scales",
  distills: "Distills from",
  fine_tunes: "Fine-tunes",
  surpasses: "Surpasses",
  competes_with: "Competes with",
  applies: "Applies",
  replaces: "Replaces",
  open_alt_to: "Open alternative to",
};

const relColors: Record<string, string> = {
  builds_on: "border-sky-300 bg-sky-50 text-sky-800",
  scales: "border-violet-300 bg-violet-50 text-violet-800",
  distills: "border-rose-300 bg-rose-50 text-rose-800",
  fine_tunes: "border-emerald-300 bg-emerald-50 text-emerald-800",
  surpasses: "border-amber-300 bg-amber-50 text-amber-800",
  competes_with: "border-indigo-300 bg-indigo-50 text-indigo-800",
  applies: "border-teal-300 bg-teal-50 text-teal-800",
  replaces: "border-red-300 bg-red-50 text-red-800",
  open_alt_to: "border-fuchsia-300 bg-fuchsia-50 text-fuchsia-800",
};

const find = (slug: string) => all.find((n) => n.data.slug === slug);

const outgoing = current.data.relationships.map((r) => ({
  ...r,
  target: find(r.to),
}));

const incoming = all
  .filter((n) => n.data.slug !== current.data.slug)
  .flatMap((n) =>
    n.data.relationships
      .filter((r) => r.to === current.data.slug)
      .map((r) => ({ from: n, type: r.type, note: r.note })),
  );
---

{
  (outgoing.length > 0 || incoming.length > 0) && (
    <section class="mt-12">
      <h2 class="mb-4 text-xl font-semibold text-[var(--accent)]" data-i18n="rel.heading">
        Lineage & relationships
      </h2>
      <div class="grid gap-6 md:grid-cols-2">
        {outgoing.length > 0 && (
          <div>
            <h3 class="mb-3 text-xs uppercase tracking-wider text-[var(--fg-muted)]" data-i18n="rel.dependsOn">
              ↑ This node depends on
            </h3>
            <ul class="space-y-3">
              {outgoing.map((r) => (
                <li
                  class={`rounded border-l-4 bg-white p-3 shadow-sm ${(relColors[r.type] ?? "border-slate-300 bg-slate-50").split(" ")[0]}`}
                >
                  <div class="flex items-center gap-2">
                    <span
                      class={`rounded border px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider ${relColors[r.type] ?? "border-slate-300 bg-slate-50 text-slate-700"}`}
                    >
                      <span data-i18n={`rel.${r.type}`}>{relTypeLabels[r.type] ?? r.type}</span>
                    </span>
                    {r.target ? (
                      <a
                        href={`/node/${r.target.data.slug}/`}
                        class="text-sm font-medium hover:underline"
                      >
                        {r.target.data.title}
                      </a>
                    ) : (
                      <span class="text-sm font-medium text-[var(--fg-muted)] italic">
                        {r.to} <span data-i18n="rel.notYet">(not yet in tree)</span>
                      </span>
                    )}
                  </div>
                  {r.note && (
                    <p class="mt-1.5 text-sm leading-snug text-[var(--fg-muted)]">
                      {r.note}
                    </p>
                  )}
                </li>
              ))}
            </ul>
          </div>
        )}
        {incoming.length > 0 && (
          <div>
            <h3 class="mb-3 text-xs uppercase tracking-wider text-[var(--fg-muted)]">
<span data-i18n="rel.dependedOnBy">↓ Depends on this node</span>
            </h3>
            <ul class="space-y-3">
              {incoming.map((r) => (
                <li
                  class={`rounded border-l-4 bg-white p-3 shadow-sm ${(relColors[r.type] ?? "border-slate-300 bg-slate-50").split(" ")[0]}`}
                >
                  <div class="flex items-center gap-2">
                    <span
                      class={`rounded border px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider ${relColors[r.type] ?? "border-slate-300 bg-slate-50 text-slate-700"}`}
                    >
                      <span data-i18n={`rel.${r.type}`}>{relTypeLabels[r.type] ?? r.type}</span>
                    </span>
                    <a
                      href={`/node/${r.from.data.slug}/`}
                      class="text-sm font-medium hover:underline"
                    >
                      {r.from.data.title}
                    </a>
                  </div>
                  {r.note && (
                    <p class="mt-1.5 text-sm leading-snug text-[var(--fg-muted)]">
                      {r.note}
                    </p>
                  )}
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </section>
  )
}
