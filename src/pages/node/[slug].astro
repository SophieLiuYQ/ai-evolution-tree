(() => {
  // Single-shot audio play/pause — clicking another card stops the prior one.
  let current = null;
  document.querySelectorAll('.audio-play').forEach((btn) => {
    const audio = btn.parentElement?.querySelector('audio');
    if (!audio) return;
    btn.addEventListener('click', () => {
      if (current && current !== audio) { current.pause(); current.currentTime = 0; }
      if (audio.paused) {
        audio.play().catch(() => {});
        btn.classList.add('is-playing');
        current = audio;
      } else {
        audio.pause();
        btn.classList.remove('is-playing');
      }
    });
    audio.addEventListener('ended', () => btn.classList.remove('is-playing'));
  });
})();
