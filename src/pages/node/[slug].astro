                ) : null}.
              </div>
              <div class="aside-list">
                {derivedSameCap.map((r) => {
                  const target = allNodes.find((n) => n.data.slug === r.slug);
                  const targetOrg = target?.data.org ?? r.org;
                  const titleSplit = r.title.match(/^(.+?)\s+[—–-]\s+(.+)$/);
                  const shortTitle = titleSplit ? titleSplit[1] : r.title;
                  return (
                    <a class="aside-item" href={`/node/${r.slug}/`} title={`Shared: ${(r.shared ?? []).join(", ")}`}>
                      <OrgLogo org={targetOrg} size={32} radius={9} class="aside-logo" />
