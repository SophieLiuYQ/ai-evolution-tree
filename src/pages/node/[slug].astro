---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import CitationsBlock from "../../components/CitationsBlock.astro";
import ModelSpec from "../../components/ModelSpec.astro";
import RelationshipsBlock from "../../components/RelationshipsBlock.astro";
import LineageZoom from "../../components/LineageZoom.astro";
import OrgLogo from "../../components/OrgLogo.astro";
import { stroke as orgStrokeColor, fill as orgFillColor, HIDDEN_EDGE_TYPES } from "../../lib/graph/constants";
import { ORG_GITHUB } from "../../lib/org-links";
import { ORG_CHAT_URL, ORG_PRODUCT_NAME, ORG_API_DOCS, ORG_DEV_TOOLS } from "../../lib/org-logos";
import type { DevTool } from "../../lib/org-logos";
import { normalizeOrg } from "../../lib/org-display";
import { normalizeCategories } from "../../lib/categories";
import { benchSource } from "../../lib/benchmark-sources";
import modelRelationshipsRaw from "../../../data/model-relationships.json";

type DerivedRel = {
  slug: string;
  title: string;
  org: string;
  domain?: string;
  shared?: string[];
  overlap: number;
  confidence: number;
  release_gap_mo?: number;
};
const modelRelationships = modelRelationshipsRaw as {
  _meta: unknown;
  models: Record<string, { competes_with: DerivedRel[]; same_capability: DerivedRel[] }>;
};

export async function getStaticPaths() {
  const nodes = await getCollection("nodes");
  return nodes.map((node) => ({
    params: { slug: node.data.slug },
    props: { node },
  }));
}

const { node } = Astro.props;
const { Content } = await render(node);
const d = node.data;
const allNodes = await getCollection("nodes");
const companies = await getCollection("companies");
const company = (() => {
  const matches = companies.filter((c) => c.data.orgs.includes(d.org));
  if (!matches.length) return null;
  // Prefer the most "aggregated" company view (covers multiple org aliases),
  // so Google/DeepMind nodes link to the combined company page rather than
  // a single-org stub.
  matches.sort((a, b) => {
    const ao = a.data.orgs.length;
    const bo = b.data.orgs.length;
    if (bo !== ao) return bo - ao;
    return a.data.name.localeCompare(b.data.name);
  });
  return matches[0];
})();
const orgHref = company ? `/company/${company.data.slug}/` : "/tree/";

// ===== Header data prep =====

const fmtShort = d.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
});

const splitMatch = d.title.match(/^(.+?)\s+[—–-]\s+(.+)$/);
const rawTitleName = splitMatch ? splitMatch[1] : d.title;
const rawTitleTagline = splitMatch ? splitMatch[2] : null;

// "Series" titles like "Claude 4.5 — Series" should read as one phrase
// rather than a name + a separate tagline pill. Inline "Series" into
// the displayed title and skip the tagline render below.
const isSeriesTitle = rawTitleTagline?.trim().toLowerCase() === "series";
const titleName = isSeriesTitle ? `${rawTitleName} Series` : rawTitleName;
const titleTagline = isSeriesTitle ? null : rawTitleTagline;

const splitZh = d.title_zh?.match(/^(.+?)\s+[—–-]\s+(.+)$/);
const rawTitleNameZh = splitZh ? splitZh[1] : d.title_zh ?? null;
const rawTitleTaglineZh = splitZh ? splitZh[2] : null;
const isSeriesTitleZh = rawTitleTaglineZh?.trim() === "系列" ||
  rawTitleTaglineZh?.trim().toLowerCase() === "series";
const titleNameZh = isSeriesTitleZh && rawTitleNameZh
  ? `${rawTitleNameZh} 系列`
  : rawTitleNameZh;
const titleTaglineZh = isSeriesTitleZh ? null : rawTitleTaglineZh;

const RELEASE_LABEL: Record<string, string> = {
  open_weights: "Open weights",
  api: "API",
  product: "Product",
  paper: "Paper",
  demo: "Demo",
};
const releaseType = d.model_spec?.release_type;
const releaseLabel = releaseType ? RELEASE_LABEL[releaseType] : null;

const ERA_LABEL: Record<string, string> = {
  foundations: "Foundations era",
  "classical-ml": "Classical ML era",
  "deep-learning-revival": "Deep-learning revival",
  architectures: "Architectures era",
  transformer: "Transformer era",
  "scale-era": "Scale era",
  alignment: "Alignment era",
  multimodal: "Multimodal era",
  reasoning: "Reasoning era",
  agents: "Agents era",
  frontier: "Frontier",
};
const eraLabel = ERA_LABEL[d.era] ?? d.era;

const hideAuthors =
  d.authors.length <= 1 &&
  d.authors.some((a) => /\bteam\b/i.test(a) || a === d.org);

const summary = d.public_view.plain_english.trim().replace(/\s+/g, " ");
const summaryZh = d.public_view_zh?.plain_english?.trim().replace(/\s+/g, " ");

const orgStroke = orgStrokeColor(d.org);
const orgFill = orgFillColor(d.org);

// "Official ↗" pill links ONLY to the model's own page if the MDX
// declares one — no fallback to the org's generic homepage. Many Chinese
// labs publish only on GitHub or HF; faking an "Official" link to the
// company's marketing site is misleading. The org-name pill on the left
// still routes to the internal /company/<org>/ page for browsing.
const officialUrl = d.model_spec?.homepage;
const isOpenWeights = d.model_spec?.release_type === "open_weights";
const githubUrl =
  d.model_spec?.github ?? (isOpenWeights ? ORG_GITHUB[d.org] : undefined);

// ===== Lineage parent/child counts (for the panel subtitle) =====
// Use the same HIDDEN_EDGE_TYPES set as LineageZoom so the counts here
// match the dots actually drawn in the minigraph.
const slugSet = new Set(allNodes.map((n) => n.data.slug));
const parentCount = d.relationships.filter(
  (r) => slugSet.has(r.to) && !HIDDEN_EDGE_TYPES.has(r.type),
).length;
const childCount = allNodes.reduce((acc, n) => {
  if (n.data.slug === d.slug) return acc;
  return acc + n.data.relationships.filter(
    (r) => r.to === d.slug && !HIDDEN_EDGE_TYPES.has(r.type),
  ).length;
}, 0);
const lineageSubtitle = (() => {
  const parts: string[] = [];
  if (parentCount > 0) parts.push(`${parentCount} parent${parentCount > 1 ? "s" : ""}`);
  if (childCount > 0) parts.push(`${childCount} child${childCount > 1 ? "ren" : ""}`);
  return parts.join(" · ") || null;
})();
// Dense lineage (5+ relationships, e.g. CLIP → 7 children) needs full-width
// rendering so the SVG cards don't get squeezed unreadable. Sparse lineage
// (≤ 4 relationships, e.g. GPT-5 → 1 parent + 1 child) keeps the side-by-side
// 2-col layout next to the comparison-table prose.
const denseLineage = parentCount + childCount > 4;

// ===== Spec table data (right side of hero) =====
const spec = d.model_spec;
const fmtUpdatedLong = spec?.last_verified_at
  ? spec.last_verified_at.toLocaleDateString("en-US", {
      year: "numeric",
      month: "short",
      day: "numeric",
    })
  : null;

const fmtCtx = (n?: number) => {
  if (!n) return null;
  if (n >= 1_000_000) return `${n / 1_000_000}M tokens`;
  if (n >= 1_000) return `${n / 1_000}k tokens`;
  return `${n} tokens`;
};
const ctxHint = (n?: number): string | null => {
  if (!n) return null;
  if (n >= 1_000_000) return `≈ entire codebase`;
  if (n >= 200_000) return `≈ ${Math.round(n / 1300)}+ pages`;
  if (n >= 32_000) return `≈ ${Math.round(n / 1300)} pages`;
  if (n >= 4_000) return `≈ short doc`;
  return `short prompt`;
};
const accessLabel = (t?: string): string => {
  if (t === "api") return "API Only";
  if (t === "open_weights") return "Open Weights";
  if (t === "product") return "Product Only";
  if (t === "paper") return "Research";
  if (t === "demo") return "Demo / Waitlist";
  return "N/A";
};

// Recognise placeholder / undisclosed strings that older MDX rows still
// carry. Anything matching → render as "N/A" in the spec table.
const PLACEHOLDER_TEXT = new Set([
  "undisclosed",
  "Undisclosed",
  "N/A",
  "—",
  "Placeholder scaffold — fill with official specs and benchmark snapshots.",
  "Series node (collapsed variants).",
]);
const isPlaceholder = (s?: string): boolean => {
  if (!s) return true;
  const t = String(s).trim();
  if (!t) return true;
  return PLACEHOLDER_TEXT.has(t);
};
const naOr = (s?: string): string => (isPlaceholder(s) ? "N/A" : String(s));

// Modality formatter — Title-Case the AA-derived tokens (text, image,
// audio, video) and join with " · " so multiple modalities read as a
// row of distinct items rather than a sentence.
const MODALITY_LABEL: Record<string, string> = {
  text: "Text",
  image: "Image",
  audio: "Audio",
  video: "Video",
  speech: "Audio",
};
const fmtModalities = (arr?: readonly string[]): string => {
  if (!arr || arr.length === 0) return "N/A";
  const seen = new Set<string>();
  const out: string[] = [];
  for (const m of arr) {
    const label = MODALITY_LABEL[m] ?? m;
    if (!seen.has(label)) {
      out.push(label);
      seen.add(label);
    }
  }
  return out.length ? out.join(" · ") : "N/A";
};

// Capabilities label map — same labels as the lower ModelSpec card
// uses for type tags + the LegendPanel filter rows. Keep in sync.
const CAPABILITY_LABEL: Record<string, string> = {
  agents: "Agent",
  multimodal: "Multimodal",
  reasoning: "Reasoning",
  generative: "Generative",
  nlp: "Text / NLP",
  cv: "Vision",
  audio: "Audio",
  video: "Video",
  code: "Code",
  science: "Science",
  world_model: "World model",
  paper: "Paper",
};
const fmtCapabilities = (cats: readonly string[]): string => {
  const norm = normalizeCategories(cats ?? []);
  const labels = norm.map((c) => CAPABILITY_LABEL[c] ?? c);
  return labels.length ? labels.join(", ") : "N/A";
};

// Compact architecture for the spec table (long descriptions get truncated
// to first 2 words for the right-aligned cell — full text stays on hover)
const archCompact = (s?: string): string => {
  if (isPlaceholder(s)) return "N/A";
  // Strip everything after first em-dash / period; take first ~3 words
  const head = s!.split(/[—.]/)[0].trim();
  const words = head.split(/\s+/);
  if (words.length <= 3) return head;
  return words.slice(0, 3).join(" ");
};

// ===== Capability cards (left half of row 2) =====
const normalizedCats = normalizeCategories(d.category ?? []);
const normalizedCatSet = new Set(normalizedCats);
type Capability = { icon: string; title: string; desc: string; color: string };
const CAP_LIBRARY: Record<string, Capability> = {
  reasoning: {
    icon: "brain",
    title: "Reasoning",
    desc: "Solves complex math, logic, and planning tasks.",
    color: "blue",
  },
  code: {
    icon: "code",
    title: "Coding",
    desc: "Strong real-world software engineering.",
    color: "purple",
  },
  nlp: {
    icon: "doc",
    title: "Long Documents",
    desc: "Handles entire codebases, books, and multi-doc RAG.",
    color: "blue",
  },
  agents: {
    icon: "robot",
    title: "Agent Workflows",
    desc: "Built for tool use and autonomous tasks.",
    color: "green",
  },
  multimodal: {
    icon: "layers",
    title: "Multimodal",
    desc: "Combines text, vision, and audio in one model.",
    color: "purple",
  },
  generative: {
    icon: "sparkle",
    title: "Generative",
    desc: "Produces images, video, audio, or other media.",
    color: "pink",
  },
  cv: {
    icon: "eye",
    title: "Vision",
    desc: "Understands images, scenes, and visual context.",
    color: "amber",
  },
  audio: {
    icon: "wave",
    title: "Audio",
    desc: "Speech, music, or other audio understanding/synthesis.",
    color: "cyan",
  },
  paper: {
    icon: "book",
    title: "Research",
    desc: "Foundational paper or scientific contribution.",
    color: "slate",
  },
  science: {
    icon: "atom",
    title: "Science",
    desc: "Built for biology, chemistry, materials, weather, or math research.",
    color: "teal",
  },
};
const longDocFromCtx = spec?.context_window && spec.context_window >= 128_000;
const capabilityKeys: string[] = [];
for (const k of normalizedCats) {
  if (CAP_LIBRARY[k] && !capabilityKeys.includes(k)) capabilityKeys.push(k);
}
if (longDocFromCtx && !capabilityKeys.includes("nlp")) capabilityKeys.unshift("nlp");
const capabilities = capabilityKeys.slice(0, 4).map((k) => CAP_LIBRARY[k]);

// ===== Performance: benchmarks =====
type Bench = { name: string; score: string; vs_baseline?: string; source_url?: string };
type RankMeta = { rank: number; total: number; scope?: string | null };
function parseRank(vs?: string): RankMeta | null {
  if (!vs) return null;
  const m = vs.match(/Rank #(\d+)\s+of\s+(\d+)/i);
  if (!m) return null;
  const rank = parseInt(m[1], 10);
  const total = parseInt(m[2], 10);
  if (!Number.isFinite(rank) || !Number.isFinite(total) || total <= 0) return null;
  const rest = vs.slice(m.index! + m[0].length).trim();
  const scope = rest ? rest.replace(/^[·•,\-\s]+/, "").trim() : null;
  return { rank, total, scope: scope || null };
}

type ScoreMeta = {
  unit: "pct" | "num" | null;
  value: number | null; // primary / best value for bar marker
  rangeMin: number | null;
  rangeMax: number | null;
};

function parseScoreMeta(score: string): ScoreMeta {
  if (typeof score !== "string") return { unit: null, value: null, rangeMin: null, rangeMax: null };

  const pctValueMatch = score.match(/(\d+(?:\.\d+)?)\s*%/);
  const pctRangeMatch = score.match(/(\d+(?:\.\d+)?)\s*[–-]\s*(\d+(?:\.\d+)?)\s*%/);
  if (pctValueMatch) {
    const value = parseFloat(pctValueMatch[1]);
    const rangeMin = pctRangeMatch ? parseFloat(pctRangeMatch[1]) : null;
    const rangeMax = pctRangeMatch ? parseFloat(pctRangeMatch[2]) : null;
    return { unit: "pct", value, rangeMin, rangeMax };
  }

  const numValueMatch = score.match(/(\d+(?:\.\d+)?)/);
  const numRangeMatch = score.match(/(\d+(?:\.\d+)?)\s*[–-]\s*(\d+(?:\.\d+)?)/);
  const value = numValueMatch ? parseFloat(numValueMatch[1]) : null;
  const rangeMin = numRangeMatch ? parseFloat(numRangeMatch[1]) : null;
  const rangeMax = numRangeMatch ? parseFloat(numRangeMatch[2]) : null;
  return { unit: value === null ? null : "num", value, rangeMin, rangeMax };
}

function clamp01to100(v: number | null): number | null {
  if (v === null || !Number.isFinite(v)) return null;
  return Math.max(0, Math.min(100, v));
}

function formatTopPct(rank: number, total: number): string {
  const pct = (rank / total) * 100;
  if (pct < 1) return "Top <1%";
  if (pct < 10) return `Top ${pct.toFixed(1)}%`;
  return `Top ${Math.round(pct)}%`;
}
const allBench = (spec?.benchmarks ?? []) as Bench[];
type DecoratedBench = Bench & { rank: RankMeta | null; scoreMeta: ScoreMeta };
function decorateBench(benchArr: Bench[]): DecoratedBench[] {
  return benchArr.map((b) => ({ ...b, rank: parseRank(b.vs_baseline), scoreMeta: parseScoreMeta(b.score) }));
}

function byBenchName(benchArr: Bench[]) {
  const map = new Map<string, DecoratedBench>();
  for (const b of decorateBench(benchArr)) {
    map.set(String(b.name).toLowerCase(), b);
  }
  return map;
}

const benchByName = byBenchName(allBench);
function benchNum(name: string): number | null {
  const b = benchByName.get(name.toLowerCase());
  const v = b?.scoreMeta?.value ?? null;
  return typeof v === "number" && Number.isFinite(v) ? v : null;
}
function benchPct(name: string): number | null {
  const b = benchByName.get(name.toLowerCase());
  if (!b || b.scoreMeta.unit !== "pct") return null;
  const v = b.scoreMeta.value;
  return typeof v === "number" && Number.isFinite(v) ? v : null;
}

function clamp10(v: number): number {
  return Math.max(0, Math.min(10, v));
}

function ctxScore10(ctx?: number): number | null {
  if (!ctx || !Number.isFinite(ctx) || ctx <= 0) return null;
  // 2k..2M (log scale) mapped to 0..10
  const lo = Math.log10(2_000);
  const hi = Math.log10(2_000_000);
  const x = (Math.log10(ctx) - lo) / (hi - lo);
  return clamp10(x * 10);
}

function priceTierScore10(priceStr?: string): number | null {
  // Heuristic: lower price → higher score. Uses input $/M if parseable.
  if (!priceStr) return null;
  const m = String(priceStr).match(/\$([0-9]+(?:\.[0-9]+)?)\s*in/i);
  if (!m) return null;
  const inputPerM = parseFloat(m[1]);
  if (!Number.isFinite(inputPerM) || inputPerM <= 0) return null;
  // 0.5..20 $/M mapped (log) to 10..0
  const lo = Math.log10(0.5);
  const hi = Math.log10(20);
  const x = (Math.log10(inputPerM) - lo) / (hi - lo);
  return clamp10((1 - Math.max(0, Math.min(1, x))) * 10);
}

type CapBar = {
  key: string;
  label: string;
  score: number;
  // Per-row methodology shown under the label so a reader can see
  // exactly which benchmark drove this number and how it was scaled.
  method: {
    source: string;       // benchmark name (e.g. "AA Intelligence Index", "SciCode")
    formula: string;      // human-readable scaling (e.g. "÷ 70 × 10", "log scale 2k–2M")
    url?: string;         // public methodology / leaderboard URL
  };
};
type KV = { k: string; v: string };

const outMods = new Set((spec?.modalities_out ?? spec?.modalities ?? []).map((m) => String(m).toLowerCase()));
const isMediaOutput = outMods.has("audio") || outMods.has("image") || outMods.has("video");
const isTextOutput = outMods.has("text") || (!isMediaOutput && (spec?.modalities ?? []).includes("text"));
const isLLM = isTextOutput && !outMods.has("image") && !outMods.has("video") && !outMods.has("audio");

const modelKind = (() => {
  if (outMods.has("audio")) return { key: "audio", label: "Audio model", primaryLabel: "Listen" };
  if (outMods.has("image")) return { key: "image", label: "Image model", primaryLabel: "Gallery" };
  if (outMods.has("video")) return { key: "video", label: "Video model", primaryLabel: "Watch" };
  if ([...normalizedCatSet].some((c) => /embed|embedding|rerank/i.test(c)))
    return { key: "embedding", label: "Embedding model", primaryLabel: "Experience" };
  if (isLLM) return { key: "llm", label: "Language model", primaryLabel: "Experience" };
  return { key: "model", label: "Model", primaryLabel: "Experience" };
})();

const orgMonogram = (() => {
  const org = normalizeOrg(d.org);
  const parts = org.split(/[^A-Za-z0-9]+/).filter(Boolean);
  const a = (parts[0]?.[0] ?? "A").toUpperCase();
  const b = (parts[1]?.[0] ?? parts[0]?.[1] ?? "").toUpperCase();
  return `${a}${b}`.slice(0, 2);
})();

type AttrCard = {
  icon: "star" | "brain" | "bolt" | "dollar" | "stack" | "globe" | "wave" | "sparkle" | "gallery";
  color: "violet" | "green" | "amber" | "rose" | "blue" | "cyan" | "pink";
  k: string;
  // Single value (e.g. "#2", "Moderate") or a short list rendered as
  // stacked lines (Strength: ["Reasoning", "Coding", "Agent tasks"]).
  v: string | string[];
  desc: string;
};

const aaInt = benchNum("Intelligence · AA Intelligence Index");
const aaIntRank = parseRank(benchByName.get("intelligence · aa intelligence index")?.vs_baseline);
const aaCodingIdx = benchNum("Coding · AA Coding Index");
const sciCode = benchPct("Coding · SciCode");
const terminalHard = benchPct("Agentic · Terminal-Bench Hard");
const speedTok = benchNum("Speed · Output tok/s");
const speedRank = parseRank(benchByName.get("speed · output tok/s")?.vs_baseline);
const priceStr = benchByName.get("price ($/m tokens)".toLowerCase())?.score ?? null;
const priceRank = parseRank(benchByName.get("price ($/m tokens)")?.vs_baseline);

// Helpers for the attribute-card row.
function tierLabel(r: RankMeta | null, lo: string, mid: string, hi: string): string | null {
  if (!r) return null;
  const p = r.rank / r.total;
  if (p <= 1 / 3) return lo;
  if (p <= 2 / 3) return mid;
  return hi;
}

const attrCards: AttrCard[] = (() => {
  const out: AttrCard[] = [];

  // INTELLIGENCE — rank in AA's Intelligence Index, expressed as a
  // friendly bucket ("Top 1% smart", "Smart", "Not very smart") rather
  // than a raw rank. The "of N" denominator drifts as AA adds models;
  // bucket framing stays readable across drift.
  //
  // Only show the card when the model has a real AA model page (the
  // hero "Artificial Analysis" pill points there). If aa_url is empty
  // or the leaderboards-root fallback, the rank is from a stale auto-
  // import and there's nothing on AA to verify it against — hide it.
  const hasRealAaPage =
    typeof spec?.aa_url === "string" &&
    spec.aa_url.includes("/models/") &&
    !spec.aa_url.endsWith("/leaderboards/models");
  if (aaIntRank && hasRealAaPage) {
    const pct = aaIntRank.rank / aaIntRank.total;
    const bucket = pct <= 0.01 ? { v: "Top 1%",  label: "Top 1% good" }
      :            pct <= 0.05 ? { v: "Top 5%",  label: "Top 5% good" }
      :            pct <= 0.10 ? { v: "Top 10%", label: "Top 10% good" }
      :            pct <= 0.25 ? { v: "Good",    label: "Good" }
      :            pct <= 0.50 ? { v: "Medium",  label: "Medium good" }
      :                          { v: "Below avg", label: "Not very good" };
    out.push({
      icon: "star",
      color: "violet",
      k: "Intelligence",
      v: bucket.v,
      desc: `${bucket.label} · from Artificial Analysis`,
    });
  }

  // STRENGTH — top 2–3 capability tags from normalized categories.
  // Rendered as a stacked list (one per line) so a long set doesn't
  // word-break inside the narrow card.
  // STRENGTH card temporarily commented out — covered by the
  // capability/performance bars below, and the comma-separated list
  // wrapped awkwardly in the narrow attr card.
  // const strengthLabels = normalizedCats
  //   .map((c) => CAPABILITY_LABEL[c] ?? c)
  //   .filter((s) => s !== "Paper" && s !== "Generative")
  //   .slice(0, 3);
  // if (strengthLabels.length) {
  //   out.push({
  //     icon: "brain",
  //     color: "green",
  //     k: "Strength",
  //     v: strengthLabels,
  //     desc: "Best-known capabilities",
  //   });
  // }

  // SPEED — tier ("Fast" / "Moderate" / "Slow") from speed rank, with tok/s in desc
  const speedTier = tierLabel(speedRank, "Fast", "Moderate", "Slow");
  if (speedTier && speedTok !== null) {
    out.push({
      icon: "bolt",
      color: "amber",
      k: "Speed",
      v: speedTier,
      desc: `${Math.round(speedTok)} tok/s output`,
    });
  } else if (speedTok !== null) {
    out.push({
      icon: "bolt",
      color: "amber",
      k: "Speed",
      v: `${Math.round(speedTok)} tok/s`,
      desc: "Output throughput",
    });
  }

  // COST — tier ("Low" / "Moderate" / "High") from price rank, with $/M in desc
  const costTier = tierLabel(priceRank, "Low", "Moderate", "High");
  if (costTier && priceStr) {
    out.push({
      icon: "dollar",
      color: "rose",
      k: "Cost",
      v: costTier,
      desc: priceStr,
    });
  } else if (priceStr) {
    out.push({
      icon: "dollar",
      color: "rose",
      k: "Cost",
      v: priceStr,
      desc: "Per million tokens",
    });
  }

  // CONTEXT — for LLMs, a big number ("200K" / "1M") + tokens hint
  if (spec?.context_window) {
    const ctx = fmtCtx(spec.context_window) ?? String(spec.context_window);
    const big = ctx.replace(" tokens", "").toUpperCase();
    out.push({
      icon: "stack",
      color: "blue",
      k: "Context",
      v: big,
      desc: `Up to ${spec.context_window.toLocaleString()} tokens`,
    });
  }

  // OUTPUT card temporarily commented out — modality is already
  // covered by the kind pill above the title and the model-type row
  // in the right-rail Quick facts.
  // if (isMediaOutput) {
  //   const mods = fmtModalities(spec?.modalities_out ?? spec?.modalities);
  //   out.unshift({
  //     icon: outMods.has("audio") ? "wave" : outMods.has("video") ? "sparkle" : "gallery",
  //     color: outMods.has("audio") ? "cyan" : outMods.has("video") ? "pink" : "violet",
  //     k: "Output",
  //     v: mods,
  //     desc: "Model produces this modality",
  //   });
  // }

  // DEVELOPER card temporarily commented out — the org is already
  // shown in the hero meta row (pill next to the date) and again in
  // the right-rail Quick facts.
  // if (out.length < 5) {
  //   out.push({
  //     icon: "globe",
  //     color: "blue",
  //     k: "Developer",
  //     v: normalizeOrg(d.org),
