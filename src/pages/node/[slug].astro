(() => {
  const params = new URLSearchParams(location.search);
  const stored = (() => { try { return localStorage.getItem('ai-tree:variant'); } catch { return null; } })();
  const initial = params.get('variant') || stored || 'auto';

  function setVariant(id) {
    document.documentElement.dataset.variant = id;
    document.querySelectorAll('[data-variant-block]').forEach((el) => {
      el.hidden = el.getAttribute('data-variant-block') !== id;
    });
    document.querySelectorAll('[data-variant-meta]').forEach((el) => {
      el.hidden = el.getAttribute('data-variant-meta') !== id;
    });
    document.querySelectorAll('[data-variant-btn]').forEach((btn) => {
      const isActive = btn.getAttribute('data-variant-btn') === id;
      btn.classList.toggle('variant-active', isActive);
      btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });
    try { localStorage.setItem('ai-tree:variant', id); } catch {}
    const u = new URL(location.href);
    u.searchParams.set('variant', id);
    history.replaceState(null, '', u);
  }

  document.addEventListener('click', (e) => {
    const t = e.target instanceof Element ? e.target.closest('[data-variant-btn]') : null;
    if (!t) return;
    const id = t.getAttribute('data-variant-btn');
    if (id) setVariant(id);
  });

  setVariant(initial);
})();
        `}
