---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import CitationsBlock from "../../components/CitationsBlock.astro";
import ModelSpec from "../../components/ModelSpec.astro";
import RelationshipsBlock from "../../components/RelationshipsBlock.astro";
import LineageZoom from "../../components/LineageZoom.astro";
import { stroke as orgStrokeColor, fill as orgFillColor, HIDDEN_EDGE_TYPES } from "../../lib/graph/constants";
import { ORG_GITHUB } from "../../lib/org-links";
import { normalizeOrg } from "../../lib/org-display";
import { normalizeCategories } from "../../lib/categories";
import { benchSource } from "../../lib/benchmark-sources";

export async function getStaticPaths() {
  const nodes = await getCollection("nodes");
  return nodes.map((node) => ({
    params: { slug: node.data.slug },
    props: { node },
  }));
}

const { node } = Astro.props;
const { Content } = await render(node);
const d = node.data;
const allNodes = await getCollection("nodes");
const companies = await getCollection("companies");
const company = (() => {
  const matches = companies.filter((c) => c.data.orgs.includes(d.org));
  if (!matches.length) return null;
  // Prefer the most "aggregated" company view (covers multiple org aliases),
  // so Google/DeepMind nodes link to the combined company page rather than
  // a single-org stub.
  matches.sort((a, b) => {
    const ao = a.data.orgs.length;
    const bo = b.data.orgs.length;
    if (bo !== ao) return bo - ao;
    return a.data.name.localeCompare(b.data.name);
  });
  return matches[0];
})();
const orgHref = company ? `/company/${company.data.slug}/` : "/tree/";

// ===== Header data prep =====

const fmtShort = d.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
});

const splitMatch = d.title.match(/^(.+?)\s+[—–-]\s+(.+)$/);
const rawTitleName = splitMatch ? splitMatch[1] : d.title;
const rawTitleTagline = splitMatch ? splitMatch[2] : null;

// "Series" titles like "Claude 4.5 — Series" should read as one phrase
// rather than a name + a separate tagline pill. Inline "Series" into
// the displayed title and skip the tagline render below.
const isSeriesTitle = rawTitleTagline?.trim().toLowerCase() === "series";
const titleName = isSeriesTitle ? `${rawTitleName} Series` : rawTitleName;
const titleTagline = isSeriesTitle ? null : rawTitleTagline;

const splitZh = d.title_zh?.match(/^(.+?)\s+[—–-]\s+(.+)$/);
const rawTitleNameZh = splitZh ? splitZh[1] : d.title_zh ?? null;
const rawTitleTaglineZh = splitZh ? splitZh[2] : null;
const isSeriesTitleZh = rawTitleTaglineZh?.trim() === "系列" ||
  rawTitleTaglineZh?.trim().toLowerCase() === "series";
const titleNameZh = isSeriesTitleZh && rawTitleNameZh
  ? `${rawTitleNameZh} 系列`
  : rawTitleNameZh;
const titleTaglineZh = isSeriesTitleZh ? null : rawTitleTaglineZh;

const RELEASE_LABEL: Record<string, string> = {
  open_weights: "Open weights",
  api: "API",
  product: "Product",
  paper: "Paper",
  demo: "Demo",
};
const releaseType = d.model_spec?.release_type;
const releaseLabel = releaseType ? RELEASE_LABEL[releaseType] : null;

const ERA_LABEL: Record<string, string> = {
  foundations: "Foundations era",
  "classical-ml": "Classical ML era",
  "deep-learning-revival": "Deep-learning revival",
  architectures: "Architectures era",
  transformer: "Transformer era",
  "scale-era": "Scale era",
  alignment: "Alignment era",
  multimodal: "Multimodal era",
  reasoning: "Reasoning era",
  agents: "Agents era",
  frontier: "Frontier",
};
const eraLabel = ERA_LABEL[d.era] ?? d.era;

const hideAuthors =
  d.authors.length <= 1 &&
  d.authors.some((a) => /\bteam\b/i.test(a) || a === d.org);

const summary = d.public_view.plain_english.trim().replace(/\s+/g, " ");
const summaryZh = d.public_view_zh?.plain_english?.trim().replace(/\s+/g, " ");

const orgStroke = orgStrokeColor(d.org);
const orgFill = orgFillColor(d.org);

// "Official ↗" pill links ONLY to the model's own page if the MDX
// declares one — no fallback to the org's generic homepage. Many Chinese
// labs publish only on GitHub or HF; faking an "Official" link to the
// company's marketing site is misleading. The org-name pill on the left
// still routes to the internal /company/<org>/ page for browsing.
const officialUrl = d.model_spec?.homepage;
const isOpenWeights = d.model_spec?.release_type === "open_weights";
const githubUrl =
  d.model_spec?.github ?? (isOpenWeights ? ORG_GITHUB[d.org] : undefined);

// ===== Lineage parent/child counts (for the panel subtitle) =====
// Use the same HIDDEN_EDGE_TYPES set as LineageZoom so the counts here
// match the dots actually drawn in the minigraph.
const slugSet = new Set(allNodes.map((n) => n.data.slug));
const parentCount = d.relationships.filter(
  (r) => slugSet.has(r.to) && !HIDDEN_EDGE_TYPES.has(r.type),
).length;
const childCount = allNodes.reduce((acc, n) => {
  if (n.data.slug === d.slug) return acc;
  return acc + n.data.relationships.filter(
    (r) => r.to === d.slug && !HIDDEN_EDGE_TYPES.has(r.type),
  ).length;
}, 0);
const lineageSubtitle = (() => {
  const parts: string[] = [];
  if (parentCount > 0) parts.push(`${parentCount} parent${parentCount > 1 ? "s" : ""}`);
  if (childCount > 0) parts.push(`${childCount} child${childCount > 1 ? "ren" : ""}`);
  return parts.join(" · ") || null;
})();
// Dense lineage (5+ relationships, e.g. CLIP → 7 children) needs full-width
// rendering so the SVG cards don't get squeezed unreadable. Sparse lineage
// (≤ 4 relationships, e.g. GPT-5 → 1 parent + 1 child) keeps the side-by-side
// 2-col layout next to the comparison-table prose.
const denseLineage = parentCount + childCount > 4;

// ===== Spec table data (right side of hero) =====
const spec = d.model_spec;

const fmtCtx = (n?: number) => {
  if (!n) return null;
  if (n >= 1_000_000) return `${n / 1_000_000}M tokens`;
  if (n >= 1_000) return `${n / 1_000}k tokens`;
  return `${n} tokens`;
};
const ctxHint = (n?: number): string | null => {
  if (!n) return null;
  if (n >= 1_000_000) return `≈ entire codebase`;
  if (n >= 200_000) return `≈ ${Math.round(n / 1300)}+ pages`;
  if (n >= 32_000) return `≈ ${Math.round(n / 1300)} pages`;
  if (n >= 4_000) return `≈ short doc`;
  return `short prompt`;
};
const accessLabel = (t?: string): string => {
  if (t === "api") return "API Only";
  if (t === "open_weights") return "Open Weights";
  if (t === "product") return "Product Only";
  if (t === "paper") return "Research";
  if (t === "demo") return "Demo / Waitlist";
  return "N/A";
};

// Recognise placeholder / undisclosed strings that older MDX rows still
// carry. Anything matching → render as "N/A" in the spec table.
const PLACEHOLDER_TEXT = new Set([
  "undisclosed",
  "Undisclosed",
  "N/A",
  "—",
  "Placeholder scaffold — fill with official specs and benchmark snapshots.",
  "Series node (collapsed variants).",
]);
const isPlaceholder = (s?: string): boolean => {
  if (!s) return true;
  const t = String(s).trim();
  if (!t) return true;
  return PLACEHOLDER_TEXT.has(t);
};
const naOr = (s?: string): string => (isPlaceholder(s) ? "N/A" : String(s));

// Modality formatter — Title-Case the AA-derived tokens (text, image,
// audio, video) and join with " · " so multiple modalities read as a
// row of distinct items rather than a sentence.
const MODALITY_LABEL: Record<string, string> = {
  text: "Text",
  image: "Image",
  audio: "Audio",
  video: "Video",
  speech: "Audio",
};
const fmtModalities = (arr?: readonly string[]): string => {
  if (!arr || arr.length === 0) return "N/A";
  const seen = new Set<string>();
  const out: string[] = [];
  for (const m of arr) {
    const label = MODALITY_LABEL[m] ?? m;
    if (!seen.has(label)) {
      out.push(label);
      seen.add(label);
    }
  }
  return out.length ? out.join(" · ") : "N/A";
};

// Capabilities label map — same labels as the lower ModelSpec card
// uses for type tags + the LegendPanel filter rows. Keep in sync.
const CAPABILITY_LABEL: Record<string, string> = {
  agents: "Agent",
  multimodal: "Multimodal",
  reasoning: "Reasoning",
  generative: "Generative",
  nlp: "Text / NLP",
  cv: "Vision",
  audio: "Audio",
  video: "Video",
  code: "Code",
  science: "Science",
  world_model: "World model",
  paper: "Paper",
};
const fmtCapabilities = (cats: readonly string[]): string => {
  const norm = normalizeCategories(cats ?? []);
  const labels = norm.map((c) => CAPABILITY_LABEL[c] ?? c);
  return labels.length ? labels.join(", ") : "N/A";
};

// Compact architecture for the spec table (long descriptions get truncated
// to first 2 words for the right-aligned cell — full text stays on hover)
const archCompact = (s?: string): string => {
  if (isPlaceholder(s)) return "N/A";
  // Strip everything after first em-dash / period; take first ~3 words
  const head = s!.split(/[—.]/)[0].trim();
  const words = head.split(/\s+/);
  if (words.length <= 3) return head;
  return words.slice(0, 3).join(" ");
};

// ===== Capability cards (left half of row 2) =====
const normalizedCats = normalizeCategories(d.category ?? []);
const normalizedCatSet = new Set(normalizedCats);
type Capability = { icon: string; title: string; desc: string; color: string };
const CAP_LIBRARY: Record<string, Capability> = {
  reasoning: {
    icon: "brain",
    title: "Reasoning",
    desc: "Solves complex math, logic, and planning tasks.",
    color: "blue",
  },
  code: {
    icon: "code",
    title: "Coding",
    desc: "Strong real-world software engineering.",
    color: "purple",
  },
  nlp: {
    icon: "doc",
    title: "Long Documents",
    desc: "Handles entire codebases, books, and multi-doc RAG.",
    color: "blue",
  },
  agents: {
    icon: "robot",
    title: "Agent Workflows",
    desc: "Built for tool use and autonomous tasks.",
    color: "green",
  },
  multimodal: {
    icon: "layers",
    title: "Multimodal",
    desc: "Combines text, vision, and audio in one model.",
    color: "purple",
  },
  generative: {
    icon: "sparkle",
    title: "Generative",
    desc: "Produces images, video, audio, or other media.",
    color: "pink",
  },
  cv: {
    icon: "eye",
    title: "Vision",
    desc: "Understands images, scenes, and visual context.",
    color: "amber",
  },
  audio: {
    icon: "wave",
    title: "Audio",
    desc: "Speech, music, or other audio understanding/synthesis.",
    color: "cyan",
  },
  paper: {
    icon: "book",
    title: "Research",
    desc: "Foundational paper or scientific contribution.",
    color: "slate",
  },
  science: {
    icon: "atom",
    title: "Science",
    desc: "Built for biology, chemistry, materials, weather, or math research.",
    color: "teal",
  },
};
const longDocFromCtx = spec?.context_window && spec.context_window >= 128_000;
const capabilityKeys: string[] = [];
for (const k of normalizedCats) {
  if (CAP_LIBRARY[k] && !capabilityKeys.includes(k)) capabilityKeys.push(k);
}
if (longDocFromCtx && !capabilityKeys.includes("nlp")) capabilityKeys.unshift("nlp");
const capabilities = capabilityKeys.slice(0, 4).map((k) => CAP_LIBRARY[k]);

// ===== Performance: benchmarks =====
type Bench = { name: string; score: string; vs_baseline?: string; source_url?: string };
type RankMeta = { rank: number; total: number; scope?: string | null };
function parseRank(vs?: string): RankMeta | null {
  if (!vs) return null;
  const m = vs.match(/Rank #(\d+)\s+of\s+(\d+)/i);
  if (!m) return null;
  const rank = parseInt(m[1], 10);
  const total = parseInt(m[2], 10);
  if (!Number.isFinite(rank) || !Number.isFinite(total) || total <= 0) return null;
  const rest = vs.slice(m.index! + m[0].length).trim();
  const scope = rest ? rest.replace(/^[·•,\-\s]+/, "").trim() : null;
  return { rank, total, scope: scope || null };
}

type ScoreMeta = {
  unit: "pct" | "num" | null;
  value: number | null; // primary / best value for bar marker
  rangeMin: number | null;
  rangeMax: number | null;
};

function parseScoreMeta(score: string): ScoreMeta {
  if (typeof score !== "string") return { unit: null, value: null, rangeMin: null, rangeMax: null };

  const pctValueMatch = score.match(/(\d+(?:\.\d+)?)\s*%/);
  const pctRangeMatch = score.match(/(\d+(?:\.\d+)?)\s*[–-]\s*(\d+(?:\.\d+)?)\s*%/);
  if (pctValueMatch) {
    const value = parseFloat(pctValueMatch[1]);
    const rangeMin = pctRangeMatch ? parseFloat(pctRangeMatch[1]) : null;
    const rangeMax = pctRangeMatch ? parseFloat(pctRangeMatch[2]) : null;
    return { unit: "pct", value, rangeMin, rangeMax };
  }

  const numValueMatch = score.match(/(\d+(?:\.\d+)?)/);
  const numRangeMatch = score.match(/(\d+(?:\.\d+)?)\s*[–-]\s*(\d+(?:\.\d+)?)/);
  const value = numValueMatch ? parseFloat(numValueMatch[1]) : null;
  const rangeMin = numRangeMatch ? parseFloat(numRangeMatch[1]) : null;
  const rangeMax = numRangeMatch ? parseFloat(numRangeMatch[2]) : null;
  return { unit: value === null ? null : "num", value, rangeMin, rangeMax };
}

function clamp01to100(v: number | null): number | null {
  if (v === null || !Number.isFinite(v)) return null;
  return Math.max(0, Math.min(100, v));
}

function formatTopPct(rank: number, total: number): string {
  const pct = (rank / total) * 100;
  if (pct < 1) return "Top <1%";
  if (pct < 10) return `Top ${pct.toFixed(1)}%`;
  return `Top ${Math.round(pct)}%`;
}
const allBench = (spec?.benchmarks ?? []) as Bench[];
type DecoratedBench = Bench & { rank: RankMeta | null; scoreMeta: ScoreMeta };
function decorateBench(benchArr: Bench[]): DecoratedBench[] {
  return benchArr.map((b) => ({ ...b, rank: parseRank(b.vs_baseline), scoreMeta: parseScoreMeta(b.score) }));
}

function benchBucket(name: string): "general" | "reasoning" | "coding" | "agentic" | "multimodal" | "cost" | "other" {
  if (/^Intelligence\s*·/i.test(name) || /MMLU/i.test(name) || /Open LLM Leaderboard/i.test(name)) return "general";
  if (/GPQA/i.test(name) || /HLE/i.test(name) || /\bAIME\b/i.test(name) || /\bMATH\b/i.test(name)) return "reasoning";
  if (/^Coding\s*·/i.test(name) || /HumanEval/i.test(name) || /SWE-?bench/i.test(name) || /Codeforces/i.test(name)) return "coding";
  if (/^Agentic\s*·/i.test(name) || /Terminal-?Bench/i.test(name)) return "agentic";
  if (/MMMU/i.test(name) || /Vision/i.test(name) || /Image/i.test(name) || /Video/i.test(name) || /Audio/i.test(name)) return "multimodal";
  if (/^Speed\s*·/i.test(name) || /^Price\b/i.test(name) || /Latency/i.test(name)) return "cost";
  return "other";
}

function sortBench(a: DecoratedBench, b: DecoratedBench) {
  const ar = a.rank ? a.rank.rank / a.rank.total : null;
  const br = b.rank ? b.rank.rank / b.rank.total : null;
  if (ar !== null && br !== null) return ar - br;
  if (ar !== null) return -1;
  if (br !== null) return 1;
  return (b.scoreMeta.value ?? -Infinity) - (a.scoreMeta.value ?? -Infinity);
}

function pickKeyBenchmarks(benchArr: Bench[], cats: Set<string>): DecoratedBench[] {
  const decorated = decorateBench(benchArr).filter((b) => b.rank !== null || b.scoreMeta.value !== null);
  const byName = new Map(decorated.map((b) => [b.name.toLowerCase(), b]));
  const picked: DecoratedBench[] = [];
  const takeByExact = (name: string) => {
    const b = byName.get(name.toLowerCase());
    if (b && !picked.some((x) => x.name === b.name)) picked.push(b);
  };

  takeByExact("Intelligence · AA Intelligence Index");
  takeByExact("Speed · Output tok/s");
  takeByExact("Price ($/M tokens)");

  const taskCandidates: string[] = [];
  if (cats.has("agents")) taskCandidates.push("Agentic · Terminal-Bench Hard");
  if (cats.has("coding")) taskCandidates.push("Coding · SciCode", "Coding · AA Coding Index");
  if (cats.has("multimodal") || cats.has("cv") || cats.has("audio")) taskCandidates.push("MMMU");
  taskCandidates.push("GPQA", "MMLU-Pro");

  for (const name of taskCandidates) {
    const hit = decorated.find((b) => b.name.toLowerCase() === name.toLowerCase() || b.name.toLowerCase().includes(name.toLowerCase()));
    if (hit && !picked.some((x) => x.name === hit.name)) {
      picked.push(hit);
      break;
    }
  }

  // Fill any remaining slots with strongest remaining rows.
  for (const b of decorated.sort(sortBench)) {
    if (picked.length >= 4) break;
    if (picked.some((x) => x.name === b.name)) continue;
    picked.push(b);
  }
  return picked.slice(0, 4);
}

function groupBenchmarks(benchArr: Bench[]): Array<{ bucket: string; items: DecoratedBench[] }> {
  const decorated = decorateBench(benchArr).filter((b) => b.rank !== null || b.scoreMeta.value !== null);
  const buckets = new Map<string, DecoratedBench[]>();
  for (const b of decorated) {
    const key = benchBucket(b.name);
    const label =
      key === "general" ? "General" :
      key === "reasoning" ? "Reasoning" :
      key === "coding" ? "Coding" :
      key === "agentic" ? "Agentic" :
      key === "multimodal" ? "Multimodal" :
      key === "cost" ? "Cost & Speed" :
      "Other";
    const arr = buckets.get(label) ?? [];
    arr.push(b);
    buckets.set(label, arr);
  }

  const order = ["General", "Reasoning", "Coding", "Agentic", "Multimodal", "Cost & Speed", "Other"];
  return order
    .map((k) => ({ bucket: k, items: (buckets.get(k) ?? []).sort(sortBench) }))
    .filter((g) => g.items.length > 0);
}

function tierFromRank(rank: RankMeta | null): "budget" | "mid" | "premium" | null {
  if (!rank || rank.total <= 0) return null;
  const p = rank.rank / rank.total;
  if (p <= 1 / 3) return "budget";
  if (p <= 2 / 3) return "mid";
  return "premium";
}

function takeawayLine(benchArr: Bench[], cats: Set<string>): string | null {
  const key = pickKeyBenchmarks(benchArr, cats);
  if (!key.length) return null;
  const task = key.find((b) => !["general", "cost"].includes(benchBucket(b.name)));
  const price = key.find((b) => /^Price\b/i.test(b.name));
  const speed = key.find((b) => /^Speed\s*·/i.test(b.name));

  const parts: string[] = [];
  if (task) parts.push(`Best at: ${benchBucket(task.name) === "agentic" ? "Agentic" : benchBucket(task.name) === "coding" ? "Coding" : benchBucket(task.name) === "reasoning" ? "Reasoning" : "Multimodal"}`);
  const priceTier = tierFromRank(price?.rank ?? null);
  if (priceTier) parts.push(`Price tier: ${priceTier}`);
  const speedTier = tierFromRank(speed?.rank ?? null);
  if (speedTier) parts.push(`Speed tier: ${speedTier}`);
  return parts.length ? parts.join(" · ") : null;
}

// ===== Variant surfaces (versioned / tiered) =====
type Variant = {
  id: string;
  label: string;
  status?: "preview" | "active" | "legacy" | "retired";
  released_at?: Date;
  retired_at?: Date;
  api_model?: string;
  benchmarks?: Bench[];
};
const variants = (spec?.variants ?? []) as Variant[];
const hasVariants = variants.length > 0;
const variantOptions = [{ id: "auto", label: "Auto (family)" }, ...variants.map((v) => ({ id: v.id, label: v.label }))];

function pickHeadline(benchArr: Bench[]) {
  return benchArr
    .map((b) => ({
      ...b,
      rank: parseRank(b.vs_baseline),
      scoreMeta: parseScoreMeta(b.score),
    }))
    .filter((b) => b.rank !== null || b.scoreMeta.value !== null)
    .sort((a, b) => {
      const ar = a.rank ? a.rank.rank / a.rank.total : null;
      const br = b.rank ? b.rank.rank / b.rank.total : null;
      if (ar !== null && br !== null) return ar - br;
      if (ar !== null) return -1;
      if (br !== null) return 1;
      return (b.scoreMeta.value ?? -Infinity) - (a.scoreMeta.value ?? -Infinity);
    })
    .slice(0, 3);
}

function fmtIso(d?: Date) {
  if (!d) return null;
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, "0");
  const day = String(d.getDate()).padStart(2, "0");
  return `${y}-${m}-${day}`;
}

const variantBench = new Map<string, Bench[]>();
variantBench.set("auto", allBench);
for (const v of variants) variantBench.set(v.id, (v.benchmarks ?? allBench) as Bench[]);

function benchNote(name: string): string {
  if (/AIME/i.test(name)) return "Mathematical reasoning (with chain-of-thought)";
  if (/SWE-?bench/i.test(name)) return "Real-world software engineering";
  if (/Humanity'?s Last Exam/i.test(name)) return "Hardest mixed reasoning benchmark";
  if (/MMLU/i.test(name)) return "Broad academic knowledge";
  if (/GPQA/i.test(name)) return "Graduate-level science Q&A";
  if (/HumanEval/i.test(name)) return "Function-level code synthesis";
  if (/MATH\b/i.test(name)) return "High-school competition math";
  if (/MMMU/i.test(name)) return "Multimodal academic understanding";
  if (/Codeforces/i.test(name)) return "Competitive programming";
  if (/Arena|Elo/i.test(name)) return "Human preference (head-to-head)";
  return "Standardized capability benchmark";
}
function benchVsLabel(vs?: string): string | null {
  if (!vs) return null;
  // Capture first competitor name + score
  const m = vs.match(/^\s*([^,]+?)\s+(\d+(?:\.\d+)?\s*%)/);
  if (!m) return vs.split(",")[0].trim();
  return `vs ${m[1].trim()} (${m[2].trim()})`;
}

// ===== Context window timeline =====
// Each tick is bilingual — short English (1-2 words) + Chinese to match the
// design (which shows 聊天 / 长文档 / 长文档 / 本模型 / 整个代码库). Long
// English phrases like "Multi-doc RAG" overflowed when ticks were close in
// log-space; trimmed to single words.
const CTX_TICKS: Array<{
  v: number;
  label: string;
  note: string;
  noteZh: string;
}> = [
  { v: 4_000, label: "4k", note: "Chat", noteZh: "聊天" },
  { v: 32_000, label: "32k", note: "Long docs", noteZh: "长文档" },
  { v: 128_000, label: "128k", note: "Books", noteZh: "整本书" },
  { v: 400_000, label: "400k", note: "Multi-doc", noteZh: "多文档" },
  { v: 1_000_000, label: "1M", note: "Codebase", noteZh: "整个代码库" },
  { v: 10_000_000, label: "10M", note: "", noteZh: "" },
];
const CTX_MIN_LOG = Math.log10(2_000);
const CTX_MAX_LOG = Math.log10(20_000_000);
function ctxLogPos(v: number): number {
  const lv = Math.log10(Math.max(v, 1));
  return Math.max(
    0,
    Math.min(100, ((lv - CTX_MIN_LOG) / (CTX_MAX_LOG - CTX_MIN_LOG)) * 100),
  );
}
const ctxValue = spec?.context_window;
const ctxThisModelPos = ctxValue ? ctxLogPos(ctxValue) : null;
const ctxThisModelHint = ctxValue ? ctxHint(ctxValue) : null;
// Active-tick detection: model is "on a tick" only if its log-distance to
// the nearest tick is within ON_TICK_TOLERANCE (≈ within 1.26× of the tick
// value). 128k model → on the 128k tick. 200k model → between 128k and 400k,
// no active tick → marker label visible above the axis.
const ON_TICK_TOLERANCE = 0.16; // log10 distance ≈ 45% multiplicative — 163.84k → 128k tick
function findActiveTickIdx(v: number): number {
  let bestI = -1;
  let bestD = Infinity;
  CTX_TICKS.forEach((t, i) => {
    const d = Math.abs(Math.log10(t.v) - Math.log10(v));
    if (d < bestD) {
      bestD = d;
      bestI = i;
    }
  });
  return bestD < ON_TICK_TOLERANCE ? bestI : -1;
}
const activeTickIdx = ctxValue ? findActiveTickIdx(ctxValue) : -1;
const isOnTick = activeTickIdx >= 0;

// ===== Availability matrix =====
// Source of truth: model_spec.availability[] (multi-channel array). When
// missing (older nodes not yet migrated), fall back to deriving from the
// single-valued release_type so the row never crashes on legacy data.
type AvailState = "available" | "not-released" | "not-available" | "contact";
type AvailRow = { key: string; label: string; status: AvailState; sub: string };

const availChannels = new Set<string>(spec?.availability ?? []);
// Back-compat fallback: if the new field is absent, project release_type
// onto a minimal channel set (api → api; open_weights → open_weights;
// product → product; etc.) so older nodes still render something useful.
if (!availChannels.size && releaseType) {
  if (releaseType === "api") availChannels.add("api");
  else if (releaseType === "open_weights") availChannels.add("open_weights");
  else if (releaseType === "product") availChannels.add("product");
  else if (releaseType === "paper") availChannels.add("research");
  else if (releaseType === "demo") availChannels.add("demo");
}

const availability: AvailRow[] = [
  {
    key: "api",
    label: "API",
    status: availChannels.has("api") ? "available" : "not-available",
    sub: availChannels.has("api") ? "Available" : "Not available",
  },
  {
    key: "product",
    label: "Product / App",
    status: availChannels.has("product") ? "available" : "not-available",
    sub: availChannels.has("product") ? "Available" : "Not available",
  },
  {
    key: "open-source",
    label: "Open Source",
    status: availChannels.has("open_weights") ? "available" : "not-released",
    sub: availChannels.has("open_weights") ? "Released" : "Not released",
  },
  {
    key: "enterprise",
    label: "Enterprise",
    status: availChannels.has("enterprise")
      ? "available"
      : (availChannels.has("api") || availChannels.has("product"))
        ? "contact"
        : "not-available",
    sub: availChannels.has("enterprise")
      ? "Available"
      : (availChannels.has("api") || availChannels.has("product"))
        ? "Contact sales"
        : "—",
  },
];

// ===== Pricing model =====
const pricingModel = (() => {
  if (releaseType === "api") {
    return { title: "Pay per token", body: "Input and output billed separately.", pill: "Pay-per-token" };
  }
  if (releaseType === "open_weights") {
    return { title: "Free / self-host", body: "Open weights — pay only for compute.", pill: "Self-host" };
  }
  if (releaseType === "product") {
    return { title: "Subscription", body: "Bundled inside the host product.", pill: "Subscription" };
  }
  if (releaseType === "paper") {
    return { title: "Research artifact", body: "Not commercially released.", pill: "Research" };
  }
  if (releaseType === "demo") {
    return { title: "Demo access", body: "Limited / waitlisted.", pill: "Demo" };
  }
  return { title: "Not disclosed", body: "Pricing not disclosed.", pill: null };
})();

const heroDescription = summary;
const heroDescriptionZh = summaryZh;
---

<Base title={`${d.title} · AI Evolution Tree`} description={d.public_view.plain_english}>
  <article class="model-page">
    {/* ============== Breadcrumb ============== */}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/" data-i18n="nav.home">Home</a>
      <span class="bc-sep">›</span>
      <a href="/tree/" data-i18n="nav.graph">Graph</a>
      <span class="bc-sep">›</span>
      <span class="bc-current">{titleName}</span>
    </nav>

    {/* ============== HERO (left/right split) ============== */}
    <section class="hero">
      <div class="hero-accent" style={`background: ${orgStroke};`} />
      <div class="hero-grid">
        {/* LEFT: title block */}
        <div class="hero-left">
          <div class="hero-meta">
            <time datetime={d.date.toISOString()} class="hero-date">{fmtShort}</time>
            <a
              href={orgHref}
              class="pill pill-org hero-meta-org"
              style={`--pill-stroke: ${orgStroke}; --pill-fill: ${orgFill};`}
              title={`See models from ${normalizeOrg(d.org)}`}
            >
              {normalizeOrg(d.org)}
            </a>
          </div>
          <h1 class="hero-title">{titleName}</h1>
          {(titleTagline || titleTaglineZh) && (
            <div class="hero-tagline-pill">
              <span class={titleTaglineZh ? "lang-en has-zh" : "lang-en"}>{titleTagline}</span>
              {titleTaglineZh && <span class="lang-zh">{titleTaglineZh}</span>}
            </div>
          )}
          <p class="hero-desc">
            <span class={heroDescriptionZh ? "lang-en has-zh" : "lang-en"}>{heroDescription}</span>
            {heroDescriptionZh && <span class="lang-zh">{heroDescriptionZh}</span>}
          </p>
          <div class="hero-pills">
            {officialUrl && (
              <a href={officialUrl} target="_blank" rel="noopener" class="pill pill-link" data-i18n="detail.official">
                Official ↗
              </a>
            )}
            {githubUrl && (
              <a href={githubUrl} target="_blank" rel="noopener" class="pill pill-link pill-github" data-i18n="detail.github">
                GitHub ↗
              </a>
            )}
            {spec?.aa_url && (
              <a href={spec.aa_url} target="_blank" rel="noopener" class="pill pill-link" data-i18n="detail.aa">
                Artificial Analysis ↗
              </a>
            )}
            {spec?.hf_url && (
              <a href={spec.hf_url} target="_blank" rel="noopener" class="pill pill-link" data-i18n="detail.hf">
                Hugging Face ↗
              </a>
            )}
          </div>
        </div>

        {/* RIGHT: spec table */}
        <div class="hero-right">
          <div class="spec-table">
            <div class="spec-row">
              <div class="spec-row-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                  <rect x="6" y="6" width="12" height="12" rx="2"/>
                  <rect x="9" y="9" width="6" height="6" rx="1"/>
                  <path d="M6 10h-2 M6 14h-2 M20 10h2 M20 14h2 M10 6v-2 M14 6v-2 M10 20v-2 M14 20v-2"/>
                </svg>
              </div>
              <div class="spec-row-label" data-i18n="spec.parameters">Parameters</div>
              <div class="spec-row-value">{naOr(spec?.parameters)}</div>
            </div>
            <div class="spec-row">
              <div class="spec-row-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                  <circle cx="12" cy="6" r="2"/>
                  <circle cx="6" cy="18" r="2"/>
                  <circle cx="18" cy="18" r="2"/>
                  <path d="M12 8v4 M12 12l-6 4 M12 12l6 4"/>
                </svg>
              </div>
              <div class="spec-row-label" data-i18n="spec.architecture">Architecture</div>
              <div
                class="spec-row-value"
                title={isPlaceholder(spec?.architecture) ? "" : spec?.architecture ?? ""}
              >{archCompact(spec?.architecture)}</div>
            </div>
            <div class="spec-row">
              <div class="spec-row-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                  <path d="M4 7h16 M4 12h16 M4 17h10"/>
                </svg>
              </div>
              <div class="spec-row-label" data-i18n="spec.context_window">Context Window</div>
              <div class="spec-row-value">{fmtCtx(spec?.context_window) ?? "N/A"}</div>
            </div>
            <div class="spec-row">
              <div class="spec-row-icon">
                {/* Inbox arrow — input modality */}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                  <path d="M4 14v4a2 2 0 002 2h12a2 2 0 002-2v-4"/>
                  <path d="M12 4v11 M8 11l4 4 4-4"/>
                </svg>
              </div>
              <div class="spec-row-label" data-i18n="spec.modality_in">Modality in</div>
              <div class="spec-row-value">{fmtModalities(spec?.modalities_in)}</div>
            </div>
            <div class="spec-row">
              <div class="spec-row-icon">
                {/* Outbox arrow — output modality */}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                  <path d="M4 14v4a2 2 0 002 2h12a2 2 0 002-2v-4"/>
                  <path d="M12 15V4 M8 8l4-4 4 4"/>
                </svg>
              </div>
              <div class="spec-row-label" data-i18n="spec.modality_out">Modality out</div>
              <div class="spec-row-value">{fmtModalities(spec?.modalities_out)}</div>
            </div>
            <div class="spec-row">
              <div class="spec-row-icon">
                {/* Sparkle — capabilities */}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                  <path d="M12 3l2 6 6 2-6 2-2 6-2-6-6-2 6-2z"/>
                </svg>
              </div>
              <div class="spec-row-label" data-i18n="spec.capabilities">Capabilities</div>
              <div
                class="spec-row-value"
                title={fmtCapabilities(d.category ?? [])}
              >{fmtCapabilities(d.category ?? [])}</div>
            </div>
            <div class="spec-row">
              <div class="spec-row-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                  <circle cx="12" cy="12" r="8"/>
                  <path d="M12 4v8l5 3"/>
                </svg>
              </div>
              <div class="spec-row-label" data-i18n="spec.release_type">Release</div>
              <div class="spec-row-value">{accessLabel(releaseType)}</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ============== ROW: Capabilities + Context Window ============== */}
    <section class="dual-row">
      {/* Capabilities */}
      <div class="panel">
        <h2 class="block-heading">Core Capabilities</h2>
        {capabilities.length > 0 ? (
          <div class="capability-grid">
            {capabilities.map((c) => (
              <div class="capability-card">
                <div class={`capability-icon icon-color-${c.color}`}>
                  {c.icon === "brain" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M9 4a3 3 0 00-3 3v1a3 3 0 00-1 5.7V15a3 3 0 003 3h1v2a1 1 0 002 0V4z"/><path d="M15 4a3 3 0 013 3v1a3 3 0 011 5.7V15a3 3 0 01-3 3h-1v2a1 1 0 01-2 0V4z"/></svg>
                  )}
                  {c.icon === "code" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M8 8l-4 4 4 4 M16 8l4 4-4 4 M14 6l-4 12"/></svg>
                  )}
                  {c.icon === "doc" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M6 3h9l4 4v14H6z"/><path d="M14 3v5h5 M9 12h7 M9 16h7"/></svg>
                  )}
                  {c.icon === "robot" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="4" y="8" width="16" height="11" rx="2"/><circle cx="9" cy="13" r="1.2" fill="currentColor"/><circle cx="15" cy="13" r="1.2" fill="currentColor"/><path d="M12 4v4 M9 19v2 M15 19v2 M2 13h2 M20 13h2"/></svg>
                  )}
                  {c.icon === "layers" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M12 3l9 5-9 5-9-5 9-5z"/><path d="M3 13l9 5 9-5 M3 17l9 5 9-5"/></svg>
                  )}
                  {c.icon === "sparkle" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M12 3l2 6 6 2-6 2-2 6-2-6-6-2 6-2z"/></svg>
                  )}
                  {c.icon === "eye" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M2 12s4-7 10-7 10 7 10 7-4 7-10 7S2 12 2 12z"/><circle cx="12" cy="12" r="3"/></svg>
                  )}
                  {c.icon === "wave" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M3 12h2 M7 8v8 M11 4v16 M15 8v8 M19 12h2"/></svg>
                  )}
                  {c.icon === "book" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M4 5a2 2 0 012-2h13v18H6a2 2 0 01-2-2V5z"/><path d="M9 3v18"/></svg>
                  )}
                  {c.icon === "atom" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="1.6" fill="currentColor"/><ellipse cx="12" cy="12" rx="9" ry="3.5"/><ellipse cx="12" cy="12" rx="9" ry="3.5" transform="rotate(60 12 12)"/><ellipse cx="12" cy="12" rx="9" ry="3.5" transform="rotate(120 12 12)"/></svg>
                  )}
                </div>
                <div class="capability-title">{c.title}</div>
                <div class="capability-desc">{c.desc}</div>
              </div>
            ))}
          </div>
        ) : (
          <p class="block-empty">Capability tags not provided.</p>
        )}
      </div>

      {/* Context Window panel (centered big number + timeline) */}
      <div class="panel ctx-panel">
        <h2 class="block-heading">Context Window</h2>
        {ctxValue ? (
          <>
            <div class="ctx-bigvalue">
              <span class="ctx-bignum">{fmtCtx(ctxValue)?.replace(" tokens", "")}</span>
              <span class="ctx-bigunit">tokens</span>
            </div>
            <div class="ctx-bighint">{ctxThisModelHint}</div>
            <div class="ctx-timeline" style={`--marker-color: ${orgStroke};`}>
              <div class="ctx-axis"></div>
              {CTX_TICKS.map((t, i) => {
                const isActive = i === activeTickIdx;
                const hasNote = isActive || !!t.note;
                return (
                  <div class={`ctx-tick ${isActive ? "ctx-tick-active" : ""} ctx-tick-row-${i % 2}`} style={`left: ${ctxLogPos(t.v)}%;`}>
                    <span class="ctx-tick-mark"></span>
                    <span class="ctx-tick-label">{t.label}</span>
                    {hasNote && (
                      <span class={`ctx-tick-note ${isActive ? "ctx-tick-note-active" : ""}`}>
                        {isActive ? (
                          <>
                            <span class="lang-en has-zh">This model</span>
                            <span class="lang-zh">本模型</span>
                          </>
                        ) : (
                          <>
                            <span class={t.noteZh ? "lang-en has-zh" : "lang-en"}>{t.note}</span>
                            {t.noteZh && <span class="lang-zh">{t.noteZh}</span>}
                          </>
                        )}
                      </span>
                    )}
                  </div>
                );
              })}
              {ctxThisModelPos !== null && (
                <div class="ctx-marker" style={`left: ${ctxThisModelPos}%;`}>
                  {/* Value label only shown when model lands BETWEEN ticks —
                      on-tick the active tick already labels itself, so the
                      marker is just a dot. */}
                  {!isOnTick && (
                    <span class="ctx-marker-label">{fmtCtx(ctxValue)?.replace(" tokens", "")}</span>
                  )}
                  <span class="ctx-marker-dot"></span>
                </div>
              )}
            </div>
          </>
        ) : (
          <p class="block-empty">Context window not disclosed.</p>
        )}
      </div>
    </section>

    {/* ============== ROW: Availability + Pricing ============== */}
    <section class="dual-row avail-pricing">
      <div class="panel">
        <h2 class="block-heading">Availability</h2>
        <div class="avail-grid">
          {availability.map((a) => (
            <div class={`avail-pill avail-${a.status}`}>
              <span class="avail-dot"></span>
              <div class="avail-text">
                <div class="avail-label">{a.label}</div>
                <div class="avail-sub">{a.sub}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="panel pricing-panel">
        <h2 class="block-heading pricing-heading">Pricing Model</h2>
        <div class="pricing-title">{pricingModel.title}</div>
        <div class="pricing-body">{pricingModel.body}</div>
        {pricingModel.pill && <span class="pricing-pill">{pricingModel.pill}</span>}
      </div>
    </section>

    {/* ============== Performance (Benchmarks) ============== */}
    {allBench.length > 0 && (
      <section class="panel perf-panel" data-variant-scope>
        <div class="perf-head-row">
          <h2 class="block-heading">Benchmark Performance</h2>
          <span class="block-sub-inline">All scores from authoritative leaderboards (click "source" to verify)</span>
          <a href="#tech-details" class="perf-see-all">View all benchmarks →</a>
        </div>
        <details class="perf-how">
          <summary>How to read this</summary>
          <ul>
            <li><b>Rank</b> shows position among models measured by the same source.</li>
            <li><b>Range</b> is min–max across modes/variants (e.g. high/xhigh/thinking).</li>
            <li><b>Index</b> scores are not percentages (higher is better).</li>
            <li><b>Confidence</b> is a heuristic based on available metadata.</li>
          </ul>
        </details>
        {hasVariants && (
          <div class="variant-strip" role="tablist" aria-label="Model variants">
            {variantOptions.map((v) => (
              <button
                type="button"
                class="variant-btn"
                data-variant-btn={v.id}
                role="tab"
                aria-selected={v.id === "auto" ? "true" : "false"}
              >
                {v.label}
              </button>
            ))}
          </div>
        )}
        {hasVariants && (
          <div class="variant-meta-row">
            <div class="variant-meta" data-variant-meta="auto">
              Showing family-level rollup (includes multiple modes).
            </div>
            {variants.map((v) => (
              <div class="variant-meta" data-variant-meta={v.id} hidden>
                {v.status && <span class={`variant-pill variant-${v.status}`}>{v.status}</span>}
                {fmtIso(v.released_at) && <span class="variant-kv">Released {fmtIso(v.released_at)}</span>}
                {fmtIso(v.retired_at) && <span class="variant-kv">Retired {fmtIso(v.retired_at)}</span>}
                {v.api_model && <span class="variant-kv">API: {v.api_model}</span>}
              </div>
            ))}
          </div>
        )}

        {variantOptions.map((v) => {
          const benchArr = variantBench.get(v.id) ?? allBench;
          const key = pickKeyBenchmarks(benchArr, normalizedCatSet);
          const groups = groupBenchmarks(benchArr);
          const takeaway = takeawayLine(benchArr, normalizedCatSet);
          return (
            <div data-variant-block={v.id} hidden={v.id !== "auto"}>
              {takeaway && <div class="perf-takeaway">{takeaway}</div>}
              <div class={key.length === 4 ? "perf-grid four" : key.length === 3 ? "perf-grid three" : key.length === 2 ? "perf-grid two" : "perf-grid one"}>
                {key.map((b) => (
                  <div class="perf-card">
                    <div class="perf-name-row">
                      <span class="perf-name">{b.name}</span>
                      {b.scoreMeta.unit === "num" && (
                        <span class="perf-unit" title="Index score (higher is better; not a percent).">Index</span>
                      )}
                      {(() => { const s = benchSource(b); return (
                        <a class="perf-source" href={s.url} target="_blank" rel="noopener">{s.label} ↗</a>
                      ); })()}
                    </div>
                    <div class="perf-bar-row">
                      <div class="perf-bar">
                        <div class="perf-bar-track"></div>
                        {(() => {
                          const v = clamp01to100(b.scoreMeta.value);
                          const r0 = clamp01to100(b.scoreMeta.rangeMin);
                          const r1 = clamp01to100(b.scoreMeta.rangeMax);
                          const hasRange = r0 !== null && r1 !== null && Math.abs(r1 - r0) > 0.01;
                          const min = hasRange ? Math.min(r0!, r1!) : null;
                          const max = hasRange ? Math.max(r0!, r1!) : null;
                          return (
                            <>
                              {hasRange && (
                                <div
                                  class="perf-bar-range"
                                  title="Mode range across variants (e.g. thinking/max/high)."
                                  style={`left: ${min}%; width: ${Math.max(0, max! - min!)}%;`}
                                />
                              )}
                              {v !== null && <div class="perf-bar-fill" style={`width: ${v}%;`}></div>}
                              {v !== null && <div class="perf-bar-dot" style={`left: ${v}%;`}></div>}
                            </>
                          );
                        })()}
                      </div>
                      <div class="perf-bar-value">{b.score.replace(/\s*\([^)]*\)\s*/g, "").trim()}</div>
                    </div>
                    <div class="perf-note">{benchNote(b.name)}</div>
                    {(() => {
                      const r = b.rank;
                      const top = r ? formatTopPct(r.rank, r.total) : null;
                      const range =
                        b.scoreMeta.rangeMin !== null && b.scoreMeta.rangeMax !== null
                          ? `${b.scoreMeta.rangeMin.toFixed(b.scoreMeta.unit === "pct" ? 1 : 2)}–${b.scoreMeta.rangeMax.toFixed(b.scoreMeta.unit === "pct" ? 1 : 2)}${b.scoreMeta.unit === "pct" ? "%" : ""}`
                          : null;
                      const confidence = r ? (range ? "High" : "Medium") : "Low";
                      return (
                        <div class="perf-meta">
                          {r && (
                            <span class="perf-meta-chip" title="Leaderboard position.">
                              Rank {r.rank} / {r.total} · {top}{r.scope ? ` · ${r.scope}` : ""}
                            </span>
                          )}
                          {range && (
                            <span class="perf-meta-chip" title="Min–max across variants/modes.">
                              Range {range}
                            </span>
                          )}
                          <span class={`perf-meta-chip perf-conf perf-conf-${confidence.toLowerCase()}`} title="Heuristic confidence based on available metadata.">
                            Confidence: {confidence}
                          </span>
                        </div>
                      );
                    })()}
                  </div>
                ))}
              </div>
              {groups.length > 1 && (
                <details class="perf-more">
                  <summary>Grouped benchmarks</summary>
                  <div class="perf-buckets">
                    {groups.map((g) => (
                      <div class="perf-bucket">
                        <div class="perf-bucket-title">{g.bucket}</div>
                        <div class="perf-bucket-items">
                          {g.items.slice(0, 2).map((b) => (
                            <div class="perf-bucket-row">
                              <span class="perf-bucket-name">{b.name}</span>
                              <span class="perf-bucket-score">{b.score.replace(/\s*\([^)]*\)\s*/g, "").trim()}</span>
                            </div>
                          ))}
                        </div>
