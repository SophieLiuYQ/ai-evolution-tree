function benchBucket(name: string): "general" | "reasoning" | "coding" | "agentic" | "multimodal" | "cost" | "other" {
  if (/^Intelligence\s*·/i.test(name) || /MMLU/i.test(name) || /Open LLM Leaderboard/i.test(name)) return "general";
  if (/GPQA/i.test(name) || /HLE/i.test(name) || /\bAIME\b/i.test(name) || /\bMATH\b/i.test(name)) return "reasoning";
  if (/^Coding\s*·/i.test(name) || /HumanEval/i.test(name) || /SWE-?bench/i.test(name) || /Codeforces/i.test(name)) return "coding";
  if (/^Agentic\s*·/i.test(name) || /Terminal-?Bench/i.test(name)) return "agentic";
  if (/MMMU/i.test(name) || /Vision/i.test(name) || /Image/i.test(name) || /Video/i.test(name) || /Audio/i.test(name)) return "multimodal";
  if (/^Speed\s*·/i.test(name) || /^Price\b/i.test(name) || /Latency/i.test(name)) return "cost";
  return "other";
}

function sortBench(a: DecoratedBench, b: DecoratedBench) {
  const ar = a.rank ? a.rank.rank / a.rank.total : null;
  const br = b.rank ? b.rank.rank / b.rank.total : null;
  if (ar !== null && br !== null) return ar - br;
  if (ar !== null) return -1;
  if (br !== null) return 1;
  return (b.scoreMeta.value ?? -Infinity) - (a.scoreMeta.value ?? -Infinity);
}

function pickKeyBenchmarks(benchArr: Bench[], cats: Set<string>): DecoratedBench[] {
  const decorated = decorateBench(benchArr).filter((b) => b.rank !== null || b.scoreMeta.value !== null);
  const byName = new Map(decorated.map((b) => [b.name.toLowerCase(), b]));
  const picked: DecoratedBench[] = [];
  const takeByExact = (name: string) => {
    const b = byName.get(name.toLowerCase());
    if (b && !picked.some((x) => x.name === b.name)) picked.push(b);
  };

  takeByExact("Intelligence · AA Intelligence Index");
  takeByExact("Speed · Output tok/s");
  takeByExact("Price ($/M tokens)");

  const taskCandidates: string[] = [];
  if (cats.has("agents")) taskCandidates.push("Agentic · Terminal-Bench Hard");
  if (cats.has("coding")) taskCandidates.push("Coding · SciCode", "Coding · AA Coding Index");
  if (cats.has("multimodal") || cats.has("cv") || cats.has("audio")) taskCandidates.push("MMMU");
  taskCandidates.push("GPQA", "MMLU-Pro");

  for (const name of taskCandidates) {
    const hit = decorated.find((b) => b.name.toLowerCase() === name.toLowerCase() || b.name.toLowerCase().includes(name.toLowerCase()));
    if (hit && !picked.some((x) => x.name === hit.name)) {
      picked.push(hit);
      break;
    }
  }

  // Fill any remaining slots with strongest remaining rows.
  for (const b of decorated.sort(sortBench)) {
    if (picked.length >= 4) break;
    if (picked.some((x) => x.name === b.name)) continue;
    picked.push(b);
  }
  return picked.slice(0, 4);
}

function groupBenchmarks(benchArr: Bench[]): Array<{ bucket: string; items: DecoratedBench[] }> {
  const decorated = decorateBench(benchArr).filter((b) => b.rank !== null || b.scoreMeta.value !== null);
  const buckets = new Map<string, DecoratedBench[]>();
  for (const b of decorated) {
    const key = benchBucket(b.name);
    const label =
      key === "general" ? "General" :
      key === "reasoning" ? "Reasoning" :
      key === "coding" ? "Coding" :
      key === "agentic" ? "Agentic" :
      key === "multimodal" ? "Multimodal" :
      key === "cost" ? "Cost & Speed" :
      "Other";
    const arr = buckets.get(label) ?? [];
    arr.push(b);
    buckets.set(label, arr);
  }

  const order = ["General", "Reasoning", "Coding", "Agentic", "Multimodal", "Cost & Speed", "Other"];
  return order
    .map((k) => ({ bucket: k, items: (buckets.get(k) ?? []).sort(sortBench) }))
    .filter((g) => g.items.length > 0);
}

function tierFromRank(rank: RankMeta | null): "budget" | "mid" | "premium" | null {
  if (!rank || rank.total <= 0) return null;
  const p = rank.rank / rank.total;
  if (p <= 1 / 3) return "budget";
  if (p <= 2 / 3) return "mid";
  return "premium";
}

function takeawayLine(benchArr: Bench[], cats: Set<string>): string | null {
  const key = pickKeyBenchmarks(benchArr, cats);
  if (!key.length) return null;
  const task = key.find((b) => !["general", "cost"].includes(benchBucket(b.name)));
  const price = key.find((b) => /^Price\b/i.test(b.name));
  const speed = key.find((b) => /^Speed\s*·/i.test(b.name));

  const parts: string[] = [];
  if (task) parts.push(`Best at: ${benchBucket(task.name) === "agentic" ? "Agentic" : benchBucket(task.name) === "coding" ? "Coding" : benchBucket(task.name) === "reasoning" ? "Reasoning" : "Multimodal"}`);
  const priceTier = tierFromRank(price?.rank ?? null);
  if (priceTier) parts.push(`Price tier: ${priceTier}`);
  const speedTier = tierFromRank(speed?.rank ?? null);
  if (speedTier) parts.push(`Speed tier: ${speedTier}`);
  return parts.length ? parts.join(" · ") : null;
}

// ===== Variant surfaces (versioned / tiered) =====
type Variant = {
  id: string;
  label: string;
  status?: "preview" | "active" | "legacy" | "retired";
  released_at?: Date;
  retired_at?: Date;
  api_model?: string;
  benchmarks?: Bench[];
};
const variants = (spec?.variants ?? []) as Variant[];
const hasVariants = variants.length > 0;
const variantOptions = [{ id: "auto", label: "Auto (family)" }, ...variants.map((v) => ({ id: v.id, label: v.label }))];

function pickHeadline(benchArr: Bench[]) {
  return benchArr
    .map((b) => ({
      ...b,
      rank: parseRank(b.vs_baseline),
      scoreMeta: parseScoreMeta(b.score),
    }))
    .filter((b) => b.rank !== null || b.scoreMeta.value !== null)
    .sort((a, b) => {
      const ar = a.rank ? a.rank.rank / a.rank.total : null;
      const br = b.rank ? b.rank.rank / b.rank.total : null;
      if (ar !== null && br !== null) return ar - br;
      if (ar !== null) return -1;
      if (br !== null) return 1;
      return (b.scoreMeta.value ?? -Infinity) - (a.scoreMeta.value ?? -Infinity);
    })
    .slice(0, 3);
}

function fmtIso(d?: Date) {
  if (!d) return null;
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, "0");
  const day = String(d.getDate()).padStart(2, "0");
  return `${y}-${m}-${day}`;
}

const variantBench = new Map<string, Bench[]>();
variantBench.set("auto", allBench);
for (const v of variants) variantBench.set(v.id, (v.benchmarks ?? allBench) as Bench[]);

function benchNote(name: string): string {
  if (/AIME/i.test(name)) return "Mathematical reasoning (with chain-of-thought)";
  if (/SWE-?bench/i.test(name)) return "Real-world software engineering";
  if (/SciCode/i.test(name)) return "Scientific & research-grade coding";
  if (/Terminal-?Bench/i.test(name)) return "Agentic command-line task completion";
  if (/Humanity'?s Last Exam|HLE/i.test(name)) return "Hardest mixed reasoning benchmark";
  if (/MMLU-Pro/i.test(name)) return "Hard expert knowledge (MMLU successor)";
  if (/MMLU/i.test(name)) return "Broad academic knowledge";
  if (/GPQA/i.test(name)) return "Graduate-level science Q&A";
  if (/HumanEval/i.test(name)) return "Function-level code synthesis";
  if (/LiveCodeBench/i.test(name)) return "Recent competitive-coding problems";
  if (/MATH\b|MathArena/i.test(name)) return "Competition mathematics";
  if (/MMMU/i.test(name)) return "Multimodal academic understanding";
  if (/Codeforces/i.test(name)) return "Competitive programming";
  if (/Arena|Elo|LMSYS|Chatbot/i.test(name)) return "Human preference (head-to-head)";
  if (/Long\s*Context|Needle/i.test(name)) return "Long-context retrieval";
  if (/^Coding\s*·\s*AA Coding/i.test(name)) return "AA aggregate coding index";
  if (/^Intelligence\s*·\s*AA Intelligence/i.test(name)) return "AA aggregate intelligence index";
  if (/Agentic\s*·/i.test(name)) return "Agent / tool-use task";
  if (/IFEval/i.test(name)) return "Instruction-following eval";
  if (/ARC-?AGI/i.test(name)) return "Novel-task abstract reasoning";
  if (/OSWorld/i.test(name)) return "Computer-use / desktop automation";
  if (/τ2|tau2/i.test(name)) return "Tool-use across domains";
  return "Standardized capability benchmark";
}
function benchVsLabel(vs?: string): string | null {
  if (!vs) return null;
  // Capture first competitor name + score
  const m = vs.match(/^\s*([^,]+?)\s+(\d+(?:\.\d+)?\s*%)/);
  if (!m) return vs.split(",")[0].trim();
  return `vs ${m[1].trim()} (${m[2].trim()})`;
}

// ===== Context window timeline =====
// Each tick is bilingual — short English (1-2 words) + Chinese to match the
// design (which shows 聊天 / 长文档 / 长文档 / 本模型 / 整个代码库). Long
// English phrases like "Multi-doc RAG" overflowed when ticks were close in
// log-space; trimmed to single words.
const CTX_TICKS: Array<{
  v: number;
  label: string;
  note: string;
  noteZh: string;
}> = [
  { v: 4_000, label: "4k", note: "Chat", noteZh: "聊天" },
  { v: 32_000, label: "32k", note: "Long docs", noteZh: "长文档" },
  { v: 128_000, label: "128k", note: "Books", noteZh: "整本书" },
  { v: 400_000, label: "400k", note: "Multi-doc", noteZh: "多文档" },
  { v: 1_000_000, label: "1M", note: "Codebase", noteZh: "整个代码库" },
  { v: 10_000_000, label: "10M", note: "", noteZh: "" },
];
const CTX_MIN_LOG = Math.log10(2_000);
const CTX_MAX_LOG = Math.log10(20_000_000);
function ctxLogPos(v: number): number {
  const lv = Math.log10(Math.max(v, 1));
  return Math.max(
    0,
    Math.min(100, ((lv - CTX_MIN_LOG) / (CTX_MAX_LOG - CTX_MIN_LOG)) * 100),
  );
}
const ctxValue = spec?.context_window;
const ctxThisModelPos = ctxValue ? ctxLogPos(ctxValue) : null;
const ctxThisModelHint = ctxValue ? ctxHint(ctxValue) : null;
// Active-tick detection: model is "on a tick" only if its log-distance to
// the nearest tick is within ON_TICK_TOLERANCE (≈ within 1.26× of the tick
// value). 128k model → on the 128k tick. 200k model → between 128k and 400k,
// no active tick → marker label visible above the axis.
const ON_TICK_TOLERANCE = 0.16; // log10 distance ≈ 45% multiplicative — 163.84k → 128k tick
function findActiveTickIdx(v: number): number {
  let bestI = -1;
  let bestD = Infinity;
  CTX_TICKS.forEach((t, i) => {
    const d = Math.abs(Math.log10(t.v) - Math.log10(v));
    if (d < bestD) {
      bestD = d;
      bestI = i;
    }
  });
  return bestD < ON_TICK_TOLERANCE ? bestI : -1;
}
const activeTickIdx = ctxValue ? findActiveTickIdx(ctxValue) : -1;
const isOnTick = activeTickIdx >= 0;

// ===== Availability matrix =====
// Source of truth: model_spec.availability[] (multi-channel array). When
// missing (older nodes not yet migrated), fall back to deriving from the
// single-valued release_type so the row never crashes on legacy data.
type AvailState = "available" | "not-released" | "not-available" | "contact";
type AvailRow = { key: string; label: string; status: AvailState; sub: string };

const availChannels = new Set<string>(spec?.availability ?? []);
// Back-compat fallback: if the new field is absent, project release_type
// onto a minimal channel set (api → api; open_weights → open_weights;
// product → product; etc.) so older nodes still render something useful.
if (!availChannels.size && releaseType) {
  if (releaseType === "api") availChannels.add("api");
  else if (releaseType === "open_weights") availChannels.add("open_weights");
  else if (releaseType === "product") availChannels.add("product");
  else if (releaseType === "paper") availChannels.add("research");
  else if (releaseType === "demo") availChannels.add("demo");
}

const availability: AvailRow[] = [
  {
    key: "api",
    label: "API",
    status: availChannels.has("api") ? "available" : "not-available",
    sub: availChannels.has("api") ? "Available" : "Not available",
  },
  {
    key: "product",
    label: "Product / App",
    status: availChannels.has("product") ? "available" : "not-available",
    sub: availChannels.has("product") ? "Available" : "Not available",
  },
  {
    key: "open-source",
    label: "Open Source",
    status: availChannels.has("open_weights") ? "available" : "not-released",
    sub: availChannels.has("open_weights") ? "Released" : "Not released",
  },
  {
    key: "enterprise",
    label: "Enterprise",
    status: availChannels.has("enterprise")
      ? "available"
      : (availChannels.has("api") || availChannels.has("product"))
        ? "contact"
        : "not-available",
    sub: availChannels.has("enterprise")
      ? "Available"
      : (availChannels.has("api") || availChannels.has("product"))
        ? "Contact sales"
        : "—",
  },
];

// ===== Pricing model =====
const pricingModel = (() => {
  if (releaseType === "api") {
    return { title: "Pay per token", body: "Input and output billed separately.", pill: "Pay-per-token" };
  }
  if (releaseType === "open_weights") {
    return { title: "Free / self-host", body: "Open weights — pay only for compute.", pill: "Self-host" };
  }
  if (releaseType === "product") {
    return { title: "Subscription", body: "Bundled inside the host product.", pill: "Subscription" };
  }
  if (releaseType === "paper") {
    return { title: "Research artifact", body: "Not commercially released.", pill: "Research" };
  }
  if (releaseType === "demo") {
    return { title: "Demo access", body: "Limited / waitlisted.", pill: "Demo" };
  }
  return { title: "Not disclosed", body: "Pricing not disclosed.", pill: null };
})();

const heroDescription = summary;
const heroDescriptionZh = summaryZh;

// ===== Media samples — drives the "Listen / View / Watch" block for
// audio / image / video output models. Pulled from MDX; no auto-fetch.
type MediaSample = {
  kind: "audio" | "image" | "video";
  title: string;
  url: string;
  poster?: string;
  duration?: string;
  caption?: string;
};
const allSamples = (spec?.media_samples ?? []) as MediaSample[];
// Pick the dominant kind from modalities_out, then filter samples to that
// kind so the block renders one consistent media type.
const mediaKind: "audio" | "image" | "video" | null = (() => {
  if (outMods.has("audio")) return "audio";
  if (outMods.has("video")) return "video";
  if (outMods.has("image")) return "image";
  return null;
})();
const mediaSamples = mediaKind
  ? allSamples.filter((s) => s.kind === mediaKind).slice(0, 6)
  : [];
const mediaHeading = (() => {
  if (mediaKind === "audio") return `Listen to ${titleName}`;
  if (mediaKind === "image") return `${titleName} Gallery`;
  if (mediaKind === "video") return `Watch ${titleName}`;
  return null;
})();

// ===== Demo CTA — prefer the org's chat product over the model's marketing
// page. Anthropic/OpenAI/Google/etc. each have a 1:1 chat surface that's a
// better landing target than the announcement blog post (which is what
// `homepage` typically points at).
const demoUrl = ORG_CHAT_URL[d.org] ?? officialUrl ?? null;
const demoProductName = ORG_PRODUCT_NAME[d.org] ?? null;
const demoLabel = demoProductName ? `Try ${demoProductName}` : "Try demo";

// API Docs CTA — third hero button next to "Try X" and "Compare". Only
// shown when the org has a documented API surface.
const apiDocsUrl = ORG_API_DOCS[d.org] ?? null;

// "Tools to try" — small list of developer tools / IDEs that wrap or
// integrate this org's models. Surfaced inside the right "Best use
// cases" panel so a reader sees use cases AND actionable tools side
// by side. Skipped when no entry exists for the org.
const devTools: DevTool[] = (ORG_DEV_TOOLS[d.org] ?? []).slice(0, 5);

// ===== NEW pill — show when the model was released within the last 90
// days. Skipped when the MDX date is an auto-fill artifact (sub-second
// precision = `Date().toISOString()` placeholder, almost certainly not
// the real release date) since those would otherwise mark old models
// like Claude 3.5 / Gemini 1.5 / Llama 3.1 as "NEW".
const NOW = new Date();
const ageDays = (NOW.getTime() - d.date.getTime()) / (1000 * 60 * 60 * 24);
const dateLooksAutoFilled =
  d.date.getUTCHours() !== 0 ||
  d.date.getUTCMinutes() !== 0 ||
  d.date.getUTCSeconds() !== 0 ||
  d.date.getUTCMilliseconds() !== 0;
const isNew = !dateLooksAutoFilled && ageDays >= 0 && ageDays <= 90;

// ===== Model-kind pill (e.g. "AUDIO MODEL", "LANGUAGE MODEL") shown
// above the title in the example layout.
const kindPillLabel = (() => {
  const k = modelKind.label.toUpperCase();
  // Model.kind labels like "Language model" → "LANGUAGE MODEL"
  return k;
})();

// ===== Breadcrumb category — one of "Language Models" / "Audio Models" /
// "Image Models" / "Video Models" / "Embedding Models" / "Models" keyed
// off modelKind.key. Used in the breadcrumb mid-link so a reader sees
// the model's category instead of generic "Graph".
const breadcrumbCategory = (() => {
  switch (modelKind.key) {
    case "audio": return "Audio Models";
    case "image": return "Image Models";
    case "video": return "Video Models";
    case "embedding": return "Embedding Models";
    case "llm": return "Language Models";
    default: return "Models";
  }
})();

// ===== Model Evolution timeline =====
// Linear horizontal strip of models in the same family, sorted by date.
// Source priority: model_spec.family (explicit family tag, ~80%
// coverage on frontier nodes) → fallback to walking builds_on parents
// + children one level deep. Window of up to 5 models centered on
// the current one so the strip stays scannable.
type FamilyCard = { slug: string; title: string; date: Date; isCurrent: boolean };
const familyTimeline: FamilyCard[] = (() => {
  const family = spec?.family;
  let pool: typeof allNodes = [];
  if (family) {
    pool = allNodes.filter((n) => n.data.model_spec?.family === family);
  } else {
    // Fallback: 1-hop neighborhood via builds_on relationships.
    // Restricted to nodes from the SAME ORG so cross-lab descendants
    // (ChatGLM, Llama, etc. that inherited RLHF from InstructGPT)
    // don't get pulled into an OpenAI family timeline.
    const sameOrg = (n: typeof allNodes[number]) =>
      n.data.org === d.org ||
      normalizeOrg(n.data.org) === normalizeOrg(d.org);
    const parentSlugs = new Set(
      d.relationships
        .filter((r) => r.type === "builds_on")
        .map((r) => r.to),
    );
    const childSlugs = new Set(
      allNodes
        .filter((n) =>
          sameOrg(n) &&
          n.data.relationships.some(
            (r) => r.type === "builds_on" && r.to === d.slug,
          ),
        )
        .map((n) => n.data.slug),
    );
    pool = allNodes.filter(
      (n) =>
        n.data.slug === d.slug ||
        (parentSlugs.has(n.data.slug) && sameOrg(n)) ||
        childSlugs.has(n.data.slug),
    );
  }
  if (pool.length < 2) return []; // need at least 2 cards to show a timeline

  // Drop hidden / template / paper / placeholder-date nodes:
  //   • graph_hidden — not part of the public tree
  //   • _ prefix — template files
  //   • release_type: paper — research papers (Transformer, Scaling
  //     Laws, RLHF, Constitutional AI) pollute family chains via the
  //     builds_on fallback walk
  //   • date 2026-01-01 exactly — placeholder timestamp on ~330
  //     bulk-added variant SKUs; would sort wrong in chronology
  // The current model is always kept regardless.
  const PLACEHOLDER_DATE_MS = new Date("2026-01-01T00:00:00.000Z").getTime();
  const isAutoFillTimestamp = (dt: Date) => {
    // Hand-edited dates land at exactly midnight UTC (the YAML loader
    // parses "2024-09-15" → 00:00:00.000Z). Auto-fill timestamps from
    // `new Date().toISOString()` always carry non-zero hour/min/sec.
    // We use that asymmetry to reject ~28 series-headline nodes whose
    // dates were filled programmatically and would otherwise pollute
    // the chronology of every family timeline they appear in.
    return (
      dt.getUTCHours() !== 0 ||
      dt.getUTCMinutes() !== 0 ||
      dt.getUTCSeconds() !== 0 ||
      dt.getUTCMilliseconds() !== 0
    );
  };
  const cleaned = pool.filter((n) => {
    if (n.data.slug === d.slug) return true;
    if (n.data.graph_hidden) return false;
    if (/^_/.test(n.data.slug)) return false;
    if (n.data.model_spec?.release_type === "paper") return false;
    if (n.data.date.getTime() === PLACEHOLDER_DATE_MS) return false;
    if (isAutoFillTimestamp(n.data.date)) return false;
    return true;
  });

  const sorted = cleaned
    .map((n) => ({
      slug: n.data.slug,
      title: (n.data.title.match(/^(.+?)\s+[—–-]\s+/) || [, n.data.title])[1] as string,
      date: n.data.date,
      isCurrent: n.data.slug === d.slug,
    }))
    .sort((a, b) => a.date.getTime() - b.date.getTime());

  // Window of up to 5 cards centered on the current model's index.
  const myIdx = sorted.findIndex((c) => c.isCurrent);
  if (myIdx < 0 || sorted.length <= 5) return sorted.slice(0, 5);
  const start = Math.max(0, Math.min(sorted.length - 5, myIdx - 2));
  return sorted.slice(start, start + 5);
})();
const familyName = (() => {
  const fam = spec?.family;
  if (!fam) return null;
  // "Alibaba qwen" → "Qwen"; "OpenAI GPT" → "GPT"; "Anthropic Claude" → "Claude"
  const parts = fam.split(/\s+/);
  return parts.length > 1 ? parts.slice(1).join(" ") : fam;
})();
const familySubtitle = (() => {
  if (!familyName) return null;
  const orgLabel = normalizeOrg(d.org);
  return `${familyName} is ${orgLabel}'s ${modelKind.label.toLowerCase()} family.`;
})();
---

<Base title={`${d.title} · AI Evolution Tree`} description={d.public_view.plain_english}>
