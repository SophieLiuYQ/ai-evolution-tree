// Extract a CapBar score-set for any node's spec, using the same
// formulas the current model uses. Reused by the global min/max sweep
// below and by `capBars`. Each entry is null when the source benchmark
// isn't available for that node.
type CapScores = {
  reasoning: number | null;
  coding: number | null;
  agentic: number | null;
  context: number | null;
  cost: number | null;
};
function capScoresForSpec(s: typeof spec | undefined): CapScores {
  if (!s) return { reasoning: null, coding: null, agentic: null, context: null, cost: null };
  const benches = (s.benchmarks ?? []) as Bench[];
  const map = byBenchName(benches);
  const num = (name: string): number | null => {
    const v = map.get(name.toLowerCase())?.scoreMeta?.value ?? null;
    return typeof v === "number" && Number.isFinite(v) ? v : null;
  };
  const pct = (name: string): number | null => {
    const b = map.get(name.toLowerCase());
    if (!b || b.scoreMeta.unit !== "pct") return null;
    return typeof b.scoreMeta.value === "number" && Number.isFinite(b.scoreMeta.value) ? b.scoreMeta.value : null;
  };
  const aaI = num("Intelligence · AA Intelligence Index");
  const sci = pct("Coding · SciCode");
  const aaC = num("Coding · AA Coding Index");
  const terH = pct("Agentic · Terminal-Bench Hard");
  const priceS = map.get("price ($/m tokens)")?.score ?? null;

  return {
    reasoning: aaI !== null ? clamp10((aaI / 70) * 10) : null,
    coding: sci !== null ? clamp10(sci / 10) : aaC !== null ? clamp10((aaC / 70) * 10) : null,
    agentic: terH !== null ? clamp10(terH / 10) : null,
    context: ctxScore10(s.context_window),
    cost: priceTierScore10(priceS ?? undefined),
  };
}

// Sweep the entire tree once to compute per-capability percentile
// reference points (20th and 80th) plus this model's rank. Using
// percentile boundaries instead of absolute min/max strips out the
// long-tail of historical / mis-tagged nodes (e.g. AlexNet rated on
// the AA Intelligence Index) so the visible range reflects the
// middle-60% of the field.
type CapStat = {
  p20: number;          // 20th percentile (lower boundary)
  p20Title: string;     // representative model AT or just below p20
  p20Slug: string;
  p80: number;          // 80th percentile (upper boundary)
  p80Title: string;     // representative model AT or just above p80
  p80Slug: string;
  total: number;        // count of nodes that report this capability
  rank: number | null;  // this model's rank (1 = best); null when this model has no value for this cap
};
const globalCapStats: Record<keyof CapScores, CapStat> = (() => {
  // First pass: collect per-cap value lists.
  const lists: Record<string, Array<{ value: number; title: string; slug: string }>> = {};
  for (const n of allNodes) {
    const s = n.data.model_spec;
    if (!s) continue;
    const sc = capScoresForSpec(s);
    const titleSplit = n.data.title.match(/^(.+?)\s+[—–-]\s+/);
    const shortTitle = titleSplit ? titleSplit[1] : n.data.title;
    (Object.keys(sc) as (keyof CapScores)[]).forEach((k) => {
      const v = sc[k];
      if (v === null) return;
      if (!lists[k]) lists[k] = [];
      lists[k].push({ value: v, title: shortTitle, slug: n.data.slug });
    });
  }
  // Second pass: derive p20 / p80 / rank per cap.
  const thisSlug = d.slug;
  const acc: Record<string, CapStat> = {};
  for (const k of Object.keys(lists)) {
    // Ascending so index 0 is the lowest score.
    const sorted = lists[k].slice().sort((a, b) => a.value - b.value);
    const n = sorted.length;
    if (n === 0) continue;
    const i20 = Math.min(n - 1, Math.floor(0.20 * n));
    const i80 = Math.min(n - 1, Math.floor(0.80 * n));
    // Rank: how many models score strictly above this one + 1.
    const me = sorted.find((e) => e.slug === thisSlug);
    const rank = me
      ? sorted.filter((e) => e.value > me.value).length + 1
      : null;
    acc[k] = {
      p20: sorted[i20].value,
      p20Title: sorted[i20].title,
      p20Slug: sorted[i20].slug,
      p80: sorted[i80].value,
      p80Title: sorted[i80].title,
      p80Slug: sorted[i80].slug,
      total: n,
      rank,
    };
  }
  return acc as Record<keyof CapScores, CapStat>;
})();

// Methodology constants — one per source benchmark. The `formula` field
// is a short plain-English descriptor of how the 0–10 score was derived
// (no math notation; just enough so a reader knows the source + shape).
const METHOD_AA_INT     = { source: "AA Intelligence Index",   formula: "scaled to 10",                url: "https://artificialanalysis.ai/" };
const METHOD_SCICODE    = { source: "SciCode",                  formula: "scaled to 10",               url: "https://scicode-bench.github.io/" };
const METHOD_AA_CODE    = { source: "AA Coding Index",          formula: "scaled to 10",               url: "https://artificialanalysis.ai/" };
const METHOD_TERMBENCH  = { source: "Terminal-Bench Hard",      formula: "scaled to 10",               url: "https://www.tbench.ai/" };
const METHOD_CONTEXT    = { source: "Context window size",      formula: "log-scaled" };
const METHOD_PRICE      = { source: "Input price ($/M tokens)", formula: "cheaper scores higher",       url: "https://artificialanalysis.ai/" };
const METHOD_SPEED      = { source: "Output throughput",        formula: "log-scaled",                  url: "https://artificialanalysis.ai/" };

const capBars: CapBar[] = (() => {
  const out: CapBar[] = [];
  if (isLLM) {
    if (aaInt !== null) out.push({ key: "reasoning", label: "Reasoning", score: clamp10((aaInt / 70) * 10), method: METHOD_AA_INT });
    if (sciCode !== null) out.push({ key: "coding", label: "Coding", score: clamp10(sciCode / 10), method: METHOD_SCICODE });
    else if (aaCodingIdx !== null) out.push({ key: "coding", label: "Coding", score: clamp10((aaCodingIdx / 70) * 10), method: METHOD_AA_CODE });
    if (terminalHard !== null) out.push({ key: "agentic", label: "Agentic tasks", score: clamp10(terminalHard / 10), method: METHOD_TERMBENCH });
    const ctx10 = ctxScore10(spec?.context_window);
    if (ctx10 !== null) out.push({ key: "context", label: "Context / memory", score: ctx10, method: METHOD_CONTEXT });
    const cost10 = priceTierScore10(priceStr ?? undefined);
    if (cost10 !== null) out.push({ key: "cost", label: "Cost efficiency", score: cost10, method: METHOD_PRICE });
    return out.slice(0, 5);
  }
  // Media: show a compact generic set if we have any signals.
  if (isMediaOutput) {
    if (aaInt !== null) out.push({ key: "quality", label: "Quality", score: clamp10((aaInt / 70) * 10), method: METHOD_AA_INT });
    if (speedTok !== null) out.push({ key: "speed", label: "Speed", score: clamp10((Math.log10(Math.max(1, speedTok)) / 2) * 10), method: METHOD_SPEED });
    const cost10 = priceTierScore10(priceStr ?? undefined);
    if (cost10 !== null) out.push({ key: "cost", label: "Cost efficiency", score: cost10, method: METHOD_PRICE });
    // Placeholders when missing — no source citation since these are filler.
    while (out.length < 4) out.push({
      key: `p${out.length}`,
      label: out.length === 0 ? "Quality" : out.length === 1 ? "Speed" : out.length === 2 ? "Control" : "Consistency",
      score: 5,
      method: { source: "No data reported", formula: "placeholder" },
    });
    return out.slice(0, 5);
  }
  return out;
})();

