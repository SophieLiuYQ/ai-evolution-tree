    margin-bottom: 16px;
  }
  .dual-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 0;
    align-items: start; /* let panels keep their natural heights */
  }
  .dual-row > .panel { margin-bottom: 16px; }
  @media (max-width: 880px) {
    .dual-row { grid-template-columns: 1fr; gap: 0; }
  }
  .dual-row.avail-pricing { grid-template-columns: 2fr 1fr; }
  @media (max-width: 880px) {
    .dual-row.avail-pricing { grid-template-columns: 1fr; }
  }

  /* ============== Media block ============== */
  .media-panel { margin-bottom: 16px; }
  .media-heading {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--fg);
    font-size: 16px;
    font-weight: 800;
    text-transform: none;
    letter-spacing: -0.01em;
  }
  .audio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  @media (max-width: 880px) { .audio-grid { grid-template-columns: 1fr; } }
  .audio-card {
    margin: 0;
    display: grid;
    grid-template-columns: 36px 1fr auto;
    grid-template-rows: auto auto;
    align-items: center;
    gap: 6px 12px;
    padding: 12px 14px;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: white;
  }
  .audio-play {
    grid-row: 1 / 3;
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 999px;
    background: rgba(99, 102, 241, 0.10);
    color: rgb(67, 56, 202);
    border: 1px solid rgba(99, 102, 241, 0.25);
    cursor: pointer;
    padding: 0;
    transition: background 0.15s ease;
  }
  .audio-play:hover { background: rgba(99, 102, 241, 0.18); }
  .audio-play.is-playing {
    background: rgb(67, 56, 202);
    color: white;
  }
  .audio-meta { min-width: 0; grid-column: 2 / 3; grid-row: 1 / 2; }
  .audio-title { font-size: 13px; font-weight: 800; color: var(--fg); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .audio-cap { margin-top: 2px; font-size: 11.5px; color: var(--fg-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .audio-wave {
    grid-column: 2 / 3;
    grid-row: 2 / 3;
    display: block;
  }
  .audio-wave svg { width: 100%; height: 22px; fill: rgba(99, 102, 241, 0.55); }
  .audio-dur {
    grid-row: 1 / 2;
    grid-column: 3 / 4;
    font-size: 11.5px;
    font-weight: 800;
    color: var(--fg-muted);
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
  }

  .image-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  @media (max-width: 880px) { .image-grid { grid-template-columns: repeat(2, 1fr); } }
  .image-card {
    margin: 0;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: white;
    display: flex;
    flex-direction: column;
  }
  .image-card a { display: block; }
  .image-card img { display: block; width: 100%; aspect-ratio: 4 / 3; object-fit: cover; }
  .image-cap { padding: 10px 12px 12px; display: flex; flex-direction: column; gap: 2px; }
  .image-title { font-size: 13px; font-weight: 800; color: var(--fg); }
  .image-prompt { font-size: 11.5px; color: var(--fg-muted); line-height: 1.4; }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  @media (max-width: 880px) { .video-grid { grid-template-columns: 1fr; } }
  .video-card {
    margin: 0;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: white;
  }
  .video-link { position: relative; display: block; aspect-ratio: 16 / 9; }
  .video-poster {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
  }
  .video-poster-empty {
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.18), rgba(34, 197, 94, 0.18));
  }
  .video-play {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 48px; height: 48px;
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.7);
    color: white;
    display: grid;
    place-items: center;
    backdrop-filter: blur(2px);
  }
  .video-dur {
    position: absolute;
    right: 8px; bottom: 8px;
    background: rgba(15, 23, 42, 0.78);
    color: white;
    font-size: 11px;
    font-weight: 800;
    padding: 3px 6px;
    border-radius: 6px;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
  }
  .video-meta { padding: 10px 12px 12px; display: flex; flex-direction: column; gap: 2px; }
  .video-title { font-size: 13px; font-weight: 800; color: var(--fg); }
  .video-cap { font-size: 11.5px; color: var(--fg-muted); line-height: 1.4; }
  .block-heading {
    font-size: 14px;
    font-weight: 700;
    color: var(--fg-muted);
    margin: 0 0 14px;
    letter-spacing: 0.02em;
  }
  .block-sub-inline {
    font-size: 12px;
    color: var(--fg-faint);
    margin-left: 8px;
    font-weight: 400;
  }
  .block-empty {
    font-size: 13px;
    color: var(--fg-muted);
    font-style: italic;
  }

  /* ============== Capabilities ============== */
  .capability-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }
  .capability-card {
    background: var(--bg-sunk);
    border-radius: 10px;
    padding: 14px 14px 14px;
    text-align: center;
  }
  .capability-icon {
    width: 28px;
    height: 28px;
    margin: 0 auto 8px;
  }
  .capability-icon svg { width: 100%; height: 100%; }
  .icon-color-blue { color: #2563eb; }
  .icon-color-purple { color: #7c3aed; }
  .icon-color-green { color: #047857; }
  .icon-color-pink { color: #db2777; }
  .icon-color-amber { color: #d97706; }
  .icon-color-cyan { color: #0891b2; }
  .icon-color-indigo { color: #4f46e5; }
  .icon-color-slate { color: #475569; }
  .icon-color-teal { color: #0d9488; }
  .capability-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--fg);
    margin-bottom: 4px;
  }
  .capability-desc {
    font-size: 11.5px;
    color: var(--fg-muted);
    line-height: 1.4;
  }

  /* ============== Context Window panel ============== */
  .ctx-panel { display: flex; flex-direction: column; }
  .ctx-bigvalue {
    text-align: center;
    margin-top: 6px;
  }
  .ctx-bignum {
    font-size: 38px;
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .ctx-bigunit {
    font-size: 18px;
    font-weight: 600;
    color: var(--accent);
    margin-left: 6px;
  }
  .ctx-bighint {
    text-align: center;
    font-size: 12.5px;
    color: var(--fg-muted);
    margin-top: 4px;
    margin-bottom: 16px;
  }
  .ctx-timeline {
    position: relative;
    height: 100px;
    margin: 30px 0 4px;
    padding: 0 4px;
  }
  .ctx-axis {
    position: absolute;
    left: 4px;
    right: 4px;
    top: 18px;
    height: 1px;
    background: var(--border-strong);
  }
  .ctx-tick {
    position: absolute;
    top: 10px;
    transform: translateX(-50%);
    text-align: center;
    color: var(--fg-muted);
    /* Wider band — adjacent ticks alternate row-0/row-1 so they can each
       claim 110px without colliding (only same-row neighbors compete,
       and those are 2 stops apart in log-space). */
    width: 110px;
  }
  .ctx-tick-mark {
    display: block;
    width: 1px;
    height: 8px;
    background: var(--border-strong);
    margin: 0 auto;
  }
  .ctx-tick-label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    color: var(--fg-muted);
    margin-top: 8px;
    line-height: 1.1;
  }
  .ctx-tick.ctx-tick-active .ctx-tick-label {
    color: var(--marker-color, #047857);
    font-weight: 700;
  }
  .ctx-tick-note {
    display: block;
    font-size: 11px;
    color: var(--fg-faint);
    margin-top: 4px;
    line-height: 1.2;
    white-space: nowrap;
  }
  /* Two-row stagger: even-index ticks (0, 2, 4 → 4k / 128k / 1M) use the
     top note row; odd-index (1, 3, 5 → 32k / 400k / 10M) drop to row 2.
     This doubles available horizontal width per row — same-row neighbors
     are 2 stops apart in log-space (e.g. 4k → 128k = 38%) so 110px bands
     never overlap. */
  .ctx-tick-row-1 .ctx-tick-note {
    margin-top: 22px;
  }
  .ctx-tick-note-active {
    color: var(--marker-color, #047857);
    font-weight: 700;
  }
  /* Active tick gets a slightly taller mark so the active position pops
     visually even before the marker dot above is parsed. */
  .ctx-tick.ctx-tick-active .ctx-tick-mark {
    height: 12px;
    width: 2px;
    background: var(--marker-color, #047857);
  }
  .ctx-marker {
    position: absolute;
    top: -4px;
    transform: translateX(-50%);
    text-align: center;
    z-index: 2;
  }
  .ctx-marker-label {
    display: block;
    font-size: 11px;
    font-weight: 700;
    color: var(--marker-color, #047857);
    margin-bottom: 2px;
    white-space: nowrap;
  }
  .ctx-marker-dot {
    display: block;
    width: 14px;
    height: 14px;
    background: var(--marker-color, #047857);
    border: 3px solid var(--surface);
    border-radius: 50%;
    margin: 0 auto;
    box-shadow: 0 0 0 1px var(--marker-color, #047857);
  }

  /* ============== Capability / performance ============== */
  .cap-panel { padding-bottom: 14px; }
  .cap-head-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }
  .cap-head-row .block-heading { margin-bottom: 0; }
  .perf-see-all {
    margin-left: auto;
    font-size: 12.5px;
    color: var(--accent-2);
    text-decoration: none;
  }
  .perf-see-all:hover { text-decoration: underline; }
  /* ============== Capability / Performance — Range View ============== */
  .cap-heading {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 18px;
    font-weight: 850;
    color: var(--fg);
    text-transform: none;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .cap-heading-pill {
    font-size: 11px;
    font-weight: 800;
    color: rgb(67, 56, 202);
    background: rgba(99, 102, 241, 0.12);
    border: 1px solid rgba(99, 102, 241, 0.18);
    padding: 3px 9px;
    border-radius: 999px;
  }
  .cap-sub {
    margin: 4px 0 14px;
    font-size: 12.5px;
    color: var(--fg-muted);
    line-height: 1.5;
    max-width: 78ch;
  }
  .cap-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 0;
  }
  .cap-row {
    display: grid;
    grid-template-columns: 150px 80px minmax(160px, 2fr) 80px 92px;
    align-items: center;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid rgba(15, 23, 42, 0.06);
  }
  .cap-row:last-child { border-bottom: none; }
  .cap-row-head {
    padding: 0 0 8px;
    border-bottom: 1px solid var(--border);
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg-muted);
    white-space: nowrap;
  }
  .cap-row-head .cap-cell-min,
  .cap-row-head .cap-cell-max,
  .cap-row-head .cap-cell-typical,
  .cap-row-head .cap-cell-rank { text-align: center; }
  @media (max-width: 880px) {
    .cap-row {
      grid-template-columns: 1fr;
      gap: 6px;
      padding: 14px 0;
    }
    .cap-row-head { display: none; }
    .cap-cell-min, .cap-cell-max { display: inline-block; min-width: 50px; }
  }
  .cap-name {
    min-width: 0;
  }
  .cap-name-main {
    font-size: 13.5px;
    font-weight: 800;
    color: var(--fg);
    line-height: 1.25;
  }
  .cap-name-method {
    margin-top: 2px;
    font-size: 11px;
    color: var(--fg-muted);
    font-weight: 600;
    line-height: 1.35;
  }
  .cap-name-method a {
    color: var(--accent-2);
    text-decoration: none;
    font-weight: 700;
  }
  .cap-name-method a:hover { text-decoration: underline; }
  .cap-name-formula {
    color: var(--fg-muted);
    font-size: 11px;
    font-style: italic;
    opacity: 0.85;
  }
  .cap-cell-min {
    text-align: center;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 12.5px;
    font-weight: 700;
    color: rgb(220, 38, 38);
  }
  .cap-cell-max {
    text-align: center;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 12.5px;
    font-weight: 700;
    color: rgb(21, 128, 61);
  }
  .cap-cell-typical {
    text-align: center;
  }
  .cap-cell-rank {
    text-align: center;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 12.5px;
    color: var(--fg-muted);
  }
  .cap-typical-num {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 14px;
    font-weight: 850;
    color: rgb(67, 56, 202);
  }
  .cap-rank-num { color: rgb(67, 56, 202); font-weight: 800; }
  .cap-rank-of { color: var(--fg-muted); }
  .cap-rank-empty { color: var(--fg-muted); }
  .cap-ref-link {
    color: inherit;
    text-decoration: none;
  }
  .cap-ref-link:hover { text-decoration: underline; }
  .cap-bar {
    position: relative;
    height: 14px;
    width: 100%;
  }
  .cap-track {
    position: absolute;
    inset: 5px 0;
    border-radius: 999px;
    background: var(--bg-sunk);
    border: 1px solid var(--border);
  }
  .cap-segment {
    position: absolute;
    top: 5px;
    bottom: 5px;
    border-radius: 999px;
    /* Red → amber → green, skipping blue/purple. Uses two stops near the
       middle so the transition feels natural without a muddy mid-tone. */
    background: linear-gradient(90deg,
      rgba(220, 38, 38, 0.55) 0%,
      rgba(245, 158, 11, 0.50) 50%,
      rgba(34, 197, 94, 0.55) 100%);
  }
  .cap-dot-range {
    position: absolute;
    top: 50%;
    width: 11px;
    height: 11px;
    margin-top: -5.5px;
    border-radius: 999px;
    border: 2px solid white;
    transform: translateX(-50%);
    box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.15);
    z-index: 1;
    cursor: help;
  }
  .cap-dot-min { background: rgb(220, 38, 38); }
  .cap-dot-typical { background: rgb(99, 102, 241); z-index: 2; }
  .cap-dot-max { background: rgb(34, 197, 94); }

  .cap-legend {
    margin-top: 16px;
    padding: 12px 14px;
    background: var(--bg-sunk);
    border-radius: 12px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px 22px;
    align-items: flex-start;
    font-size: 12px;
    color: var(--fg);
    line-height: 1.4;
  }
  .cap-legend-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .cap-legend-item .cap-dot-range {
    position: static;
    transform: none;
    margin: 0;
    cursor: default;
  }
  .cap-legend-item strong {
    margin-right: 4px;
    font-weight: 800;
    color: var(--fg);
  }
  .cap-legend-note {
    flex-basis: 100%;
    color: var(--fg-muted);
    font-size: 11.5px;
    font-style: italic;
  }
  .cap-signals {
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px solid var(--border);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  @media (max-width: 880px) {
    .cap-signals { grid-template-columns: 1fr; }
  }
  .cap-signal {
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--surface);
    padding: 10px 12px;
  }
  .cap-signal-k {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
    font-weight: 800;
  }
  .cap-signal-v {
    margin-top: 6px;
    font-size: 13px;
    font-weight: 750;
    color: var(--fg);
  }


  /* ============== Reviews: feels-like + use-cases (2-up) ============== */
  /* `align-items: start` so the two panels keep their natural heights;
     otherwise the grid stretches the shorter "What it feels like" to
     match the taller "Best use cases" (which now has tools + not-ideal
     subsections), leaving awkward trailing whitespace inside the left
     panel. */
  .review-row { grid-template-columns: 1fr 1fr; align-items: start; }
  @media (max-width: 880px) { .review-row { grid-template-columns: 1fr; } }
  .review-panel {
    background: white;
    padding: 22px 24px 24px;
  }
  .review-heading {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0 0 14px;
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -0.01em;
  }
  .review-icon {
    display: inline-grid;
    place-items: center;
    width: 28px;
    height: 28px;
  }
  .review-icon svg { width: 24px; height: 24px; }
  .review-heading-quote { color: rgb(21, 128, 61); }
  .review-heading-quote .review-icon { color: rgb(34, 197, 94); }
  .review-heading-target { color: rgb(8, 145, 178); }
  .review-heading-target .review-icon { color: rgb(8, 145, 178); }
  .review-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .review-list > li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: var(--fg);
    font-size: 13.5px;
    line-height: 1.5;
  }
  .review-tick {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    color: rgb(34, 197, 94);
    margin-top: 1px;
  }
  .review-cross {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    color: rgb(244, 63, 94);
    margin-top: 1px;
  }
  .review-divider {
    height: 1px;
    background: var(--border);
    margin: 18px 0 14px;
  }
  .tools-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 4px;
  }
  .tools-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 5px 10px;
    border-radius: 999px;
    border: 1px solid rgba(34, 197, 94, 0.30);
    background: rgba(34, 197, 94, 0.08);
    color: rgb(21, 128, 61);
    font-size: 12px;
    font-weight: 750;
    text-decoration: none;
    transition: background 0.12s ease;
  }
  .tools-chip:hover { background: rgba(34, 197, 94, 0.16); }
  .tools-chip-ext { font-size: 10px; opacity: 0.7; }
  .review-subheading {
    margin: 0 0 12px;
    font-size: 14px;
    font-weight: 800;
    color: var(--fg);
    letter-spacing: -0.005em;
  }
  .review-sources {
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px dashed var(--border);
    font-size: 11.5px;
    color: var(--fg-muted);
    font-weight: 650;
  }
  .review-sources a {
    color: var(--accent-2);
    text-decoration: none;
    font-weight: 750;
  }
  .review-sources a:hover { text-decoration: underline; }

  /* legacy classes kept as no-ops so older Astro caches don't break */
  .feel-list, .use-grid, .use-sub, .use-list { all: unset; }
  .cmp-note {
    margin-top: 6px;
    font-size: 12.5px;
    color: var(--fg-muted);
    font-weight: 650;
  }
  .cmp-table {
    margin-top: 12px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .cmp-row {
    display: grid;
    grid-template-columns: 1.4fr 0.8fr 2fr;
    gap: 12px;
    padding: 10px 12px;
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    background: var(--surface);
    color: var(--fg);
  }
  @media (max-width: 880px) {
    .cmp-row { grid-template-columns: 1fr; gap: 6px; }
  }
  .cmp-row:hover { background: var(--bg-sunk); }
  .cmp-name { font-weight: 800; }
  .cmp-org {
    font-size: 12px;
    color: var(--fg-muted);
    font-weight: 700;
  }
  .cmp-why {
    font-size: 12.5px;
    color: var(--fg-muted);
    line-height: 1.35;
  }
  .perf-bucket-title {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.04em;
    color: var(--fg-faint);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .perf-bucket-row {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    padding: 6px 0;
    border-bottom: 1px dashed var(--border);
    font-size: 12px;
