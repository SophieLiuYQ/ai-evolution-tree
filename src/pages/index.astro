---
import Base from "../layouts/Base.astro";
import { readFile } from "node:fs/promises";
import { fileURLToPath } from "node:url";
import { dirname, join } from "node:path";

const __dirname = dirname(fileURLToPath(import.meta.url));
const ASCII_PATH = join(__dirname, "..", "..", "ascii-art.txt");
const asciiArt = await readFile(ASCII_PATH, "utf-8");

// Floating model labels — anchored close to the tree art so their leader
// lines stay short and the labels read as "annotating" the canvas, not
// floating in negative space. `side` governs which edge gets the leader
// stub.
type FloatingLabel = {
  name: string;
  top: number;
  left: number;
  side: "top" | "right" | "bottom" | "left";
  /** Leader-line length in px. Hand-picked organic-feeling lengths so
   *  each label has its own reach into the tree without looking
   *  uniform — frozen from a randomized 20-60 range that the team
   *  liked enough to keep. */
  leader: number;
};

const FLOATING_LABELS: FloatingLabel[] = [
  { name: "GPT-5", top: 30, left: 45, side: "bottom", leader: 41 },
  { name: "HunyuanVideo 1.5", top: 28, left: 64, side: "bottom", leader: 51 },
  { name: "Claude Opus 4.6", top: 42, left: 14, side: "right", leader: 42 },
  { name: "Gemini 3.1 Pro", top: 42, left: 82, side: "left", leader: 29 },
  { name: "MiniMax M2", top: 57, left: 12, side: "right", leader: 38 },
  { name: "DeepSeek V3.2", top: 65, left: 76, side: "left", leader: 34 },
];

const FEATURES = [
  { icon: "tree", key: "landing.feat.tree", text: "Tree view of model lineage and descendants" },
  { icon: "chart", key: "landing.feat.compare", text: "Compare models across benchmarks and capabilities" },
  { icon: "clock", key: "landing.feat.timeline", text: "Timeline of key releases and breakthroughs" },
  { icon: "search", key: "landing.feat.profiles", text: "Detailed model profiles and technical specs" },
];
---

<Base title="AI Evolution Tree — Understand how models evolve">
  <div class="landing-fullbleed">
    {/* ============== LEFT — ASCII tree canvas ============== */}
    <div class="tree-side">
      <div class="tree-stage">
        {/* Boot log (top-left) — each line gets a ✓ check on the right */}
        <div class="boot-log">
          <p><span class="boot-text" data-i18n="landing.boot.1">{"> Inittializing tree..."}</span><span class="boot-check">✓</span></p>
          <p><span class="boot-text" data-i18n="landing.boot.2">{"> Fetching models..."}</span><span class="boot-check">✓</span></p>
          <p><span class="boot-text" data-i18n="landing.boot.3">{"> Building relationships..."}</span><span class="boot-check">✓</span></p>
          <p><span class="boot-text" data-i18n="landing.boot.4">{"> Rendering evolution..."}</span><span class="boot-cursor" aria-hidden="true">▌</span></p>
        </div>

        {/* The ASCII tree itself — black/charcoal, monospace, calm. */}
        <pre class="ascii-tree" aria-hidden="true">{asciiArt}</pre>

        {/* Floating model name labels with leader lines into the tree. */}
        {FLOATING_LABELS.map((l) => (
          <span
            class={`float-label float-label-${l.side}`}
            style={`top: ${l.top}%; left: ${l.left}%; --leader-length: ${l.leader}px;`}
          >
            {l.name}
          </span>
        ))}

        {/* Faint dust */}
        <span class="dust dust-1" aria-hidden="true"></span>
        <span class="dust dust-2" aria-hidden="true"></span>
        <span class="dust dust-3" aria-hidden="true"></span>
        <span class="dust dust-4" aria-hidden="true"></span>
      </div>
    </div>

    {/* ============== RIGHT — editorial hero copy ============== */}
    <section class="text-side">
      <div class="text-inner">
        <h1 class="hero-headline">
          <span data-i18n="landing.headline.a">Map the evolution</span><br />
          <span data-i18n="landing.headline.b">of artificial</span>{" "}
          <span class="hero-accent" data-i18n="landing.headline.accent">intelligence</span>
        </h1>

        <p class="hero-lede" data-i18n="landing.lede">
          AI Evolution Tree visualizes the ancestry, branching, and
          relationships of AI models — so you can understand how we got
          here, and where it's going.
        </p>

        {/* Feature checklist — 4 icon rows */}
        <ul class="feat-list" role="list">
          {FEATURES.map((f) => (
            <li class="feat-row">
              <span class="feat-icon" aria-hidden="true">
                {f.icon === "tree" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M12 3l4 5h-3v6h-2V8H8l4-5z"/><path d="M5 19c1.5-3 4-5 7-5s5.5 2 7 5"/></svg>
                )}
                {f.icon === "chart" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M4 19V5 M4 19h16 M8 15v-4 M12 15V8 M16 15v-6"/></svg>
                )}
                {f.icon === "clock" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
                )}
                {f.icon === "search" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="11" cy="11" r="6"/><path d="M16 16l4 4"/></svg>
                )}
              </span>
              <span data-i18n={f.key}>{f.text}</span>
            </li>
          ))}
        </ul>

        <a href="/tree/" class="landing-cta">
          <span data-i18n="landing.cta">Enter the Tree</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7"/>
          </svg>
        </a>

        <p class="footnote" data-i18n="landing.footnote">
          Free &amp; open · Data sources linked · Community driven
        </p>
      </div>
    </section>
  </div>
</Base>

<style is:global>
  /* Editorial cream background, no card chrome — page reads as one paper */
  body:has(.landing-fullbleed) {
    background: #f7f4ec;
  }
  body:has(.landing-fullbleed) > header {
    background: rgba(247, 244, 236, 0.92) !important;
    border-bottom: 1px solid rgba(15, 23, 42, 0.06);
    backdrop-filter: blur(8px);
  }
  body:has(.landing-fullbleed) main {
    max-width: none !important;
    padding: 0 !important;
  }
</style>

<style>
  /* ============== Page shell — 2-col grid ============== */
  .landing-fullbleed {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: calc(100vh - 53px);
    background: #f7f4ec;
  }
  @media (max-width: 980px) {
    .landing-fullbleed { grid-template-columns: 1fr; }
  }
  .tree-side {
    position: relative;
    border-right: 1px solid rgba(15, 23, 42, 0.08);
    overflow: hidden;
  }
  @media (max-width: 980px) {
    .tree-side { border-right: none; border-bottom: 1px solid rgba(15, 23, 42, 0.08); }
  }

  /* ============== LEFT — boot log + ASCII tree + labels ============== */
  .tree-stage {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 760px;
    padding: 24px 32px;
  }
  .boot-log {
    position: absolute;
    top: 26px;
    left: 32px;
    z-index: 5;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 13px;
    line-height: 1.7;
    color: #1f2937;
  }
  .boot-log p {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .boot-text { display: inline-block; min-width: 220px; }
  .boot-check {
    color: #15803d;
    font-weight: 700;
  }
  .boot-cursor {
    color: #1f2937;
    animation: blink 1s steps(2, start) infinite;
  }
  @keyframes blink {
    to { visibility: hidden; }
  }

  /* ASCII tree — charcoal-on-cream, calm and book-like (NOT loud green) */
  .ascii-tree {
    position: absolute;
    inset: 0;
    margin: auto;
    width: max-content;
    max-width: 96%;
    height: max-content;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: clamp(7px, 0.85vw, 11px);
    line-height: 1.05;
    color: #1f2937;
    opacity: 0.78;
    white-space: pre;
    text-align: center;
    z-index: 1;
    user-select: none;
    pointer-events: none;
    padding-top: 80px;
  }

  /* Floating model labels — outlined boxes with green border + leader line.
     Pseudo-element ::after draws the connector stub on the side facing
     the tree (green hairline + small dot). */
  .float-label {
    position: absolute;
    transform: translate(-50%, -50%);
    z-index: 4;
    background: #f7f4ec;
    color: #166534;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 12px;
    font-weight: 600;
    padding: 5px 11px;
    border: 1px solid #166534;
    border-radius: 4px;
    white-space: nowrap;
    letter-spacing: 0.02em;
  }
  .float-label::after {
    content: "";
    position: absolute;
    background: #166534;
  }
  .float-label::before {
    content: "";
    position: absolute;
    width: 5px;
    height: 5px;
    background: #166534;
    border-radius: 50%;
  }
  /* Leader line length is per-label via the --leader-length CSS variable
     set inline in the template; defaults to 10px when unset. Allows one-off
     overrides (e.g. o3 reaching deep into the tree crown) without
     duplicating CSS rules per label. */
  .float-label-bottom::after {
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: var(--leader-length, 10px);
  }
  .float-label-bottom::before {
    top: calc(100% + var(--leader-length, 10px));
    left: 50%;
    transform: translate(-50%, -50%);
  }
  /* Leader line points RIGHT from labels on the LEFT side of the tree */
  .float-label-right::after {
    left: 100%;
    top: 50%;
    transform: translateY(-50%);
    height: 1px;
    width: var(--leader-length, 10px);
  }
  .float-label-right::before {
    left: calc(100% + var(--leader-length, 10px));
    top: 50%;
    transform: translate(-50%, -50%);
  }
  /* Leader line points LEFT from labels on the RIGHT side of the tree */
  .float-label-left::after {
    right: 100%;
    top: 50%;
    transform: translateY(-50%);
    height: 1px;
    width: var(--leader-length, 10px);
  }
  .float-label-left::before {
    right: calc(100% + var(--leader-length, 10px));
    top: 50%;
    transform: translate(50%, -50%);
  }

  /* Faint dust dots */
  .dust {
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #15803d;
    opacity: 0.35;
    z-index: 2;
    pointer-events: none;
  }
  .dust-1 { top: 18%; left: 92%; }
  .dust-2 { top: 50%; left: 4%; opacity: 0.22; }
  .dust-3 { top: 70%; left: 90%; opacity: 0.25; }
  .dust-4 { top: 8%; left: 60%; opacity: 0.18; }

  /* ============== RIGHT — editorial hero ============== */
  .text-side {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 70px 64px;
  }
  @media (max-width: 980px) {
    .text-side { padding: 48px 28px; }
  }
  .text-inner {
    width: 100%;
    max-width: 600px;
  }

  .hero-headline {
    font-family: "Iowan Old Style", "Source Serif Pro", "Playfair Display", Georgia, "Times New Roman", serif;
    font-size: clamp(2.6rem, 5.4vw, 4.4rem);
    font-weight: 600;
    line-height: 1.04;
    letter-spacing: -0.025em;
    color: #0f172a;
    margin: 0 0 18px;
  }
  .hero-accent { color: #1f5f3f; }

  .hero-lede {
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 17px;
    line-height: 1.55;
    color: #475569;
    margin: 0 0 32px;
    max-width: 30em;
  }

  /* 4 icon rows — soft-circle icon + plain label */
  .feat-list {
    list-style: none;
    margin: 0 0 32px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .feat-row {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 14.5px;
    color: #334155;
    line-height: 1.4;
  }
  .feat-icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    /* Cream-aware sage tint — pulled from the same dark-forest-green
       (#1f5f3f) as the headline "intelligence" + float-label borders,
       at 14% alpha so it blends with the #f7f4ec paper bg instead of
       fighting it like the previous mint #d1fae5 did. */
    background: rgba(31, 95, 63, 0.14);
    color: #1f5f3f;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .feat-icon svg { width: 18px; height: 18px; }

  /* Big dark CTA — pill, charcoal/black */
  .landing-cta {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    background: #111827;
    color: white;
    padding: 16px 32px;
    border-radius: 6px;
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    margin-bottom: 22px;
    transition: background 0.15s ease, transform 0.1s ease;
  }
  .landing-cta:hover {
    background: #000000;
    text-decoration: none;
  }
  .landing-cta:active { transform: translateY(1px); }

  .footnote {
    font-size: 13px;
    color: #64748b;
    margin: 0;
  }

</style>
