---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Graph from "../components/Graph.astro";

const nodes = await getCollection("nodes");
---

<Base title="AI Evolution Tree · A living tree of ML/LLM/AI advancement">
  {/* Full-bleed: break out of <main>'s max-width so the graph fills
      the viewport. The negative-margin trick pulls the wrapper to
      100vw and aligns it back under the page-content padding. */}
  <div class="graph-fullbleed">
    <Graph nodes={nodes} />
  </div>
</Base>

<style is:global>
  /* === Full-bleed graph page: kill page scroll, only the inner
     orient-pane should scroll. Otherwise the user sees TWO vertical
     scrollbars (page + pane). ===
     Strategy:
     - body/html overflow:hidden (no page scroll)
     - footer hidden (would push body past 100vh)
     - main: no padding, no max-width, exact viewport-minus-header height
     - .graph-fullbleed fills main 100% (no negative-margin trick needed) */
  body:has(.graph-fullbleed),
  html:has(.graph-fullbleed) {
    overflow: hidden;
    height: 100vh;
  }
  body:has(.graph-fullbleed) > footer { display: none; }

  main:has(> .graph-fullbleed) {
    max-width: none !important;
    padding: 0 !important;
    height: calc(100vh - 53px); /* sticky nav is ~53px */
    overflow: hidden;
  }
  .graph-fullbleed {
    width: 100%;
    height: 100%;
    padding: 0.5rem 0.75rem;
  }
</style>
