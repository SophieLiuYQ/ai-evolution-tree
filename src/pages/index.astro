---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Graph from "../components/Graph.astro";

const nodes = await getCollection("nodes");
---

<Base title="AI Evolution Tree · A living tree of ML/LLM/AI advancement">
  {/* Full-bleed: break out of <main>'s max-width so the graph fills
      the viewport. The negative-margin trick pulls the wrapper to
      100vw and aligns it back under the page-content padding. */}
  <div class="graph-fullbleed">
    <Graph nodes={nodes} />
  </div>
</Base>

<style is:global>
  .graph-fullbleed {
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    width: 100vw;
    /* Fill from just below top nav to bottom of viewport. Top nav
       is sticky and ~52px tall; main has py-8 (=2rem) above us. */
    height: calc(100vh - 6.5rem);
    padding: 0 1rem;
  }
  /* Cancel the parent <main>'s py-8 so the figure sits flush */
  main:has(> .graph-fullbleed) {
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
  }
</style>
