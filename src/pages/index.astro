---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
const nodes = await getCollection("nodes");
const nodeCount = nodes.length;
const yearSpan = (() => {
  const ys = nodes.map((n) => n.data.date.getFullYear());
  return [Math.min(...ys), Math.max(...ys)];
})();
---

<Base title="AI Evolution Tree — every breakthrough, one branch at a time">
  <div class="landing-fullbleed">
    {/* LEFT: full-height bonsai canvas (3D parallax — 2 background ghost
        trees + 1 foreground main tree that cycles every 3s) */}
    <div class="tree-side">
      <canvas class="binary-tree"></canvas>
      <div class="tree-vignette"></div>
    </div>

    {/* RIGHT: text content */}
    <section class="text-side">
      <h1 class="landing-title">
        <span class="title-line title-line--small">A living tree of</span>
        <span class="title-line title-line--big">AI&nbsp;Evolution</span>
      </h1>
      <p class="landing-tagline">
        Every load-bearing breakthrough in machine intelligence —
        rooted, branched, and connected. From the {yearSpan[0]} Perceptron
        to the {yearSpan[1]} frontier.
      </p>
      <div class="landing-stats">
        <div class="stat"><span class="stat-num">{nodeCount}</span><span class="stat-lbl">nodes</span></div>
        <div class="stat"><span class="stat-num">{yearSpan[1] - yearSpan[0] + 1}</span><span class="stat-lbl">years</span></div>
        <div class="stat"><span class="stat-num">28+</span><span class="stat-lbl">orgs</span></div>
      </div>
      <a href="/tree/" class="landing-cta">
        Explore the tree
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 5l7 7-7 7"/>
        </svg>
      </a>
      <div class="landing-meta">
        <a href="/about/">How this works</a>
        <span class="dot">·</span>
        <a href="/timeline/">Timeline</a>
        <span class="dot">·</span>
        <a href="https://github.com/SophieLiuYQ/ai-evolution-tree" target="_blank" rel="noopener">GitHub ↗</a>
      </div>
    </section>
  </div>
</Base>

<style is:global>
  body:has(.landing-fullbleed),
  html:has(.landing-fullbleed) {
    overflow: hidden;
    height: 100vh;
    background: #f8fafc;
  }
  body:has(.landing-fullbleed) > footer { display: none; }
  /* Sticky nav over the light canvas */
  body:has(.landing-fullbleed) > header {
    background: rgba(255, 255, 255, 0.7) !important;
    border-bottom: 1px solid rgba(15, 23, 42, 0.06);
    backdrop-filter: blur(10px);
  }

  main:has(> .landing-fullbleed) {
    max-width: none !important;
    padding: 0 !important;
    height: calc(100vh - 53px);
    overflow: hidden;
  }
</style>

<style>
  .landing-fullbleed {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    display: flex;
    align-items: stretch;
    background: radial-gradient(
      ellipse at 30% 50%,
      #ffffff 0%,
      #f1f5f9 60%,
      #e2e8f0 100%
    );
  }

  .tree-side {
    position: relative;
    flex: 0 0 50%;
    height: 100%;
    overflow: hidden;
    background: linear-gradient(135deg, #fafafa 0%, #f1f5f9 100%);
    border-right: 1px solid rgba(15, 23, 42, 0.06);
  }
  .binary-tree {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    /* Subtle 3D perspective tilt — tree feels like it's leaning into the page */
    transform: perspective(1400px) rotateY(4deg);
    transform-origin: right center;
  }
  /* Soft inner-shadow vignette to add depth — anchors the bonsai in space */
  .tree-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      ellipse at 50% 65%,
      rgba(0, 0, 0, 0) 50%,
      rgba(15, 23, 42, 0.10) 100%
    );
    z-index: 1;
  }

  .text-side {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 0 clamp(2rem, 6vw, 5rem);
  }

  .landing-title {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    line-height: 1;
  }
  .title-line--small {
    font-size: clamp(0.95rem, 1.6vw, 1.2rem);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #475569; /* slate-600 — grayscale accent */
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
  }
  .title-line--big {
    font-size: clamp(3rem, 6.5vw, 6.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #0f172a;
    background: linear-gradient(180deg, #0f172a 0%, #1e293b 60%, #334155 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: title-glow 4s ease-in-out infinite;
  }

  @keyframes title-glow {
    0%, 100% { filter: drop-shadow(0 4px 18px rgba(15, 23, 42, 0.10)); }
    50% { filter: drop-shadow(0 4px 26px rgba(15, 23, 42, 0.18)); }
  }

  .landing-tagline {
    margin: 0;
    max-width: 36rem;
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    line-height: 1.55;
    color: #475569;
    opacity: 0;
    animation: fade-up 1.1s 0.6s ease-out forwards;
  }

  .landing-stats {
    display: flex;
    gap: 1.6rem;
    margin-top: 0.4rem;
    opacity: 0;
    animation: fade-up 1.1s 1s ease-out forwards;
  }
  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    font-family: ui-monospace, monospace;
  }
  .stat-num {
    font-size: 1.6rem;
    font-weight: 700;
    color: #0f172a; /* slate-900 */
  }
  .stat-lbl {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #64748b;
    margin-top: 0.15rem;
  }

  .landing-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 0.8rem;
    padding: 0.85rem 1.6rem;
    border-radius: 999px;
    background: #0f172a; /* solid slate-900 — terminal feel */
    color: #f1f5f9;
    font-weight: 700;
    font-size: 1rem;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    text-decoration: none;
    box-shadow:
      0 0 0 1px rgba(15, 23, 42, 0.85),
      0 8px 24px -6px rgba(15, 23, 42, 0.35);
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
    opacity: 0;
    animation: fade-up 1.1s 1.4s ease-out forwards;
  }
  .landing-cta:hover {
    transform: translateY(-2px);
    background: #000;
    box-shadow:
      0 0 0 1px #000,
      0 14px 36px -6px rgba(15, 23, 42, 0.55);
  }

  .landing-meta {
    display: flex;
    gap: 0.7rem;
    align-items: center;
    margin-top: 0.4rem;
    font-size: 0.85rem;
    color: #94a3b8;
    opacity: 0;
    animation: fade-up 1.1s 1.8s ease-out forwards;
  }
  .landing-meta a {
    color: #475569;
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .landing-meta a:hover { color: #0f172a; }
  .landing-meta .dot { color: #cbd5e1; }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Stack vertically on narrow viewports — tree on top (40% height),
     text below (60%) */
  @media (max-width: 880px) {
    .landing-fullbleed { flex-direction: column; }
    .tree-side {
      flex: 0 0 38%;
      border-right: none;
      border-bottom: 1px solid rgba(15, 23, 42, 0.08);
    }
    .binary-tree { transform: none; }
    .text-side {
      flex: 1;
      align-items: center;
      text-align: center;
      padding: 1.5rem;
    }
    .landing-title { align-items: center; }
  }
</style>
<script>
  // ===== Pythagoras fractal tree → ASCII, growing bottom → top =====
  // Pure recursive binary fractal. At each split: two children at fixed
  // (left, right) angle offsets, length scaled by RATIO. NO random walk
  // → no drift, the tree is deterministic in shape per cycle. Per-cycle
  // randomization of (leftAngle, rightAngle, ratio) gives variety.
  //
  // Pipeline:
  //   1. Render fractal to off-screen canvas as stroked lines + light blur
  //   2. Sample brightness per ~7×12 cell → ASCII glyph
  //   3. bottom→top reveal of cells, brief hold, fade, repeat

  type Cell = { col: number; row: number; ch: string; b: number };

  const RAMP = " .'\",:;-+=*ox#%@&MW8B";
  const CELL_W = 7;
  const CELL_H = 12;
  const FONT_PX = 11;

  const MAX_DEPTH = 14;

  const canvas = document.querySelector<HTMLCanvasElement>(".binary-tree");
  if (canvas) {
    const ctx = canvas.getContext("2d")!;
    const off = document.createElement("canvas");
    const offCtx = off.getContext("2d")!;
    const DPR = Math.min(window.devicePixelRatio || 1, 2);

    const GROW_MS = 3400;
    const HOLD_MS = 1200;
    const FADE_MS = 500;
    const CYCLE_MS = GROW_MS + HOLD_MS + FADE_MS;

    let W = 0, H = 0, COLS = 0, ROWS = 0;
    let cells: Cell[] = [];
    let cycleStart = performance.now();

    function resize() {
      const rect = canvas.getBoundingClientRect();
      W = Math.max(1, Math.floor(rect.width));
      H = Math.max(1, Math.floor(rect.height));
      canvas.width = W * DPR;
      canvas.height = H * DPR;
      canvas.style.width = `${W}px`;
      canvas.style.height = `${H}px`;
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
      off.width = W;
      off.height = H;
      offCtx.setTransform(1, 0, 0, 1, 0, 0);
      COLS = Math.floor(W / CELL_W);
      ROWS = Math.floor(H / CELL_H);
      rebuild();
      cycleStart = performance.now();
    }

    function rebuild() {
      offCtx.clearRect(0, 0, W, H);
      offCtx.fillStyle = "#000";
      offCtx.strokeStyle = "#000";
      offCtx.lineCap = "round";
      offCtx.lineJoin = "round";
      offCtx.filter = "blur(0.7px)";

      // Higher ratio + tighter angles → taller tree, canopy reaches near top
      const ratio = 0.79 + Math.random() * 0.04;        // 0.79–0.83
      const leftA = 0.28 + Math.random() * 0.14;        // 16°–24°
      const rightA = 0.28 + Math.random() * 0.14;
      // Bumped trunkLen — total tree H ≈ trunkLen·5 (ratio 0.81),
      // so 0.21·H trunk → tree fills ~95% of viewport.
      const trunkLen = Math.min(H * 0.21, W * 0.20);
      const baseW = Math.max(24, Math.min(W, H) * 0.045);

      // Tapered trapezoid renderer: each segment narrows w1→w2 along
      // its length, with round end-caps so adjacent segments join
      // smoothly. This is what gives the visible bottom-to-top trunk
      // taper inside a single trunk segment (a uniform stroke can't).
      function taperedSeg(x1: number, y1: number, x2: number, y2: number, w1: number, w2: number) {
        const dx = x2 - x1, dy = y2 - y1;
        const len = Math.hypot(dx, dy);
        if (len < 0.3) return;
        const nx = -dy / len, ny = dx / len;
        const hw1 = w1 / 2, hw2 = w2 / 2;
        offCtx.beginPath();
        offCtx.moveTo(x1 + nx * hw1, y1 + ny * hw1);
        offCtx.lineTo(x2 + nx * hw2, y2 + ny * hw2);
        offCtx.lineTo(x2 - nx * hw2, y2 - ny * hw2);
        offCtx.lineTo(x1 - nx * hw1, y1 - ny * hw1);
        offCtx.closePath();
        offCtx.fill();
        offCtx.beginPath();
        offCtx.arc(x1, y1, hw1, 0, Math.PI * 2);
        offCtx.fill();
        offCtx.beginPath();
        offCtx.arc(x2, y2, hw2, 0, Math.PI * 2);
        offCtx.fill();
      }

      function branch(x: number, y: number, angle: number, length: number, thick: number, depth: number) {
        if (depth > MAX_DEPTH || length < 1.0) {
          // Bigger puffs + 3 per terminal + bigger jitter → fills the
          // empty space between branches with leaf mass.
          if (depth >= 5) {
            const N = 3;
            for (let p = 0; p < N; p++) {
              const lr = 6.5 + Math.random() * 4.0;
              const jx = (Math.random() - 0.5) * 9;
              const jy = (Math.random() - 0.5) * 9;
              offCtx.globalAlpha = 0.65 + Math.random() * 0.28;
              offCtx.beginPath();
              offCtx.arc(x + jx, y + jy, lr, 0, Math.PI * 2);
              offCtx.fill();
            }
            offCtx.globalAlpha = 1;
          }
          return;
        }
        const x2 = x + Math.cos(angle) * length;
        const y2 = y + Math.sin(angle) * length;
        // Each segment tapers within itself: thick → thick·0.78
        // Children inherit the segment's END thickness so joints are
        // continuous (no width jumps at branching points).
        const endThick = Math.max(1.4, thick * 0.78);
        taperedSeg(x, y, x2, y2, thick, endThick);
        const newLen = length * ratio;
        branch(x2, y2, angle - leftA, newLen, endThick, depth + 1);
        branch(x2, y2, angle + rightA, newLen, endThick, depth + 1);
      }

      const baseX = W / 2;
      const baseY = H - 24;
      branch(baseX, baseY, -Math.PI / 2, trunkLen, baseW, 0);
      offCtx.filter = "none";

      sampleCells();
    }

    function sampleCells() {
      const data = offCtx.getImageData(0, 0, W, H).data;
      const out: Cell[] = [];
      for (let r = 0; r < ROWS; r++) {
        for (let c = 0; c < COLS; c++) {
          const x0 = c * CELL_W, y0 = r * CELL_H;
          let sum = 0, cnt = 0;
          for (let sy = 1; sy < CELL_H; sy += 2) {
            for (let sx = 1; sx < CELL_W; sx += 2) {
              const xi = x0 + sx, yi = y0 + sy;
              if (xi >= W || yi >= H) continue;
              sum += data[(yi * W + xi) * 4 + 3];
              cnt++;
            }
          }
          const b = cnt ? sum / (cnt * 255) : 0;
          if (b < 0.05) continue;
          const idx = Math.min(RAMP.length - 1,
            Math.max(1, Math.floor(b * RAMP.length)));
          const ch = RAMP[idx];
          if (ch === " ") continue;
          out.push({ col: c, row: r, ch, b });
        }
      }
      // Bottom → Top reveal
      out.sort((a, b) => b.row - a.row);
      cells = out;
    }

    function frame(t: number) {
      let elapsed = t - cycleStart;
      if (elapsed >= CYCLE_MS) {
        rebuild();
        cycleStart = t;
        elapsed = 0;
      }

      let visible = cells.length;
      let alpha = 1;
      if (elapsed < GROW_MS) {
        visible = Math.floor(cells.length * (elapsed / GROW_MS));
      } else if (elapsed < GROW_MS + HOLD_MS) {
        // hold full
      } else {
        alpha = 1 - (elapsed - GROW_MS - HOLD_MS) / FADE_MS;
      }

      ctx.fillStyle = "#f5f7fa";
      ctx.fillRect(0, 0, W, H);
      ctx.font = `${FONT_PX}px ui-monospace, "SF Mono", Menlo, monospace`;
      ctx.textAlign = "left";
      ctx.textBaseline = "top";

      for (let i = 0; i < visible; i++) {
        const c = cells[i];
        const g = Math.floor(15 + 95 * (1 - c.b));
        const a = (0.4 + 0.6 * c.b) * alpha;
        ctx.fillStyle = `rgba(${g}, ${g + 8}, ${g + 24}, ${a.toFixed(2)})`;
        ctx.fillText(c.ch, c.col * CELL_W, c.row * CELL_H);
      }

      const grad = ctx.createRadialGradient(W / 2, H, 20, W / 2, H, H * 0.5);
      grad.addColorStop(0, "rgba(15, 23, 42, 0.08)");
      grad.addColorStop(1, "rgba(255, 255, 255, 0)");
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, W, H);

      requestAnimationFrame(frame);
    }

    resize();
    window.addEventListener("resize", resize);
    requestAnimationFrame(frame);
  }
</script>
