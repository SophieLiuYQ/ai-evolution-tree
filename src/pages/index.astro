---
import Base from "../layouts/Base.astro";
---

<Base title="AI Evolution Tree — every breakthrough, one branch at a time">
  <div class="landing-fullbleed">
    {/* LEFT: full-height bonsai canvas (3D parallax — 2 background ghost
        trees + 1 foreground main tree that cycles every 3s) */}
    <div class="tree-side">
      <canvas class="binary-tree"></canvas>
      <div class="tree-vignette"></div>
    </div>

    {/* RIGHT: text content */}
    <section class="text-side">
      <h1 class="landing-title">
        <span class="title-line title-line--big">AI&nbsp;Evolution&nbsp;Tree</span>
      </h1>
      <ul class="landing-bullets">
        <li data-i18n="landing.bullet1">Observe AI's evolution in a tree structure</li>
        <li data-i18n="landing.bullet2">Understand AI's ancestry and descendants</li>
        <li data-i18n="landing.bullet3">Branch, iterate, and compare model-to-model</li>
      </ul>

      {/* Prominent language toggle — lives here per user request so
          visitors choose their reading language before entering the
          tree. Uses the same global __i18nSet() as the nav-corner
          toggle, so the two stay in sync via the langchange event. */}
      <div
        class="landing-lang-toggle lang-toggle"
        role="tablist"
        aria-label="Language"
      >
        <button
          type="button"
          class="lang-toggle-btn"
          data-lang="en"
          aria-selected="true"
          onclick="window.__i18nSet('en')"
        >EN</button>
        <button
          type="button"
          class="lang-toggle-btn"
          data-lang="zh"
          aria-selected="false"
          onclick="window.__i18nSet('zh')"
        >中</button>
      </div>

      <a href="/tree/" class="landing-cta">
        <span data-i18n="landing.cta">Explore the tree</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 5l7 7-7 7"/>
        </svg>
      </a>
      <div class="landing-meta">
        <a href="/about/" data-i18n="landing.meta.how">How this works</a>
        <span class="dot">·</span>
        <a href="/timeline/" data-i18n="landing.meta.timeline">Timeline</a>
        <span class="dot">·</span>
        <a href="https://github.com/SophieLiuYQ/ai-evolution-tree" target="_blank" rel="noopener">GitHub ↗</a>
      </div>
    </section>
  </div>
</Base>

<style is:global>
  /* `:has()` is nice-to-have polish (header transparency, footer
     hiding). On browsers without :has() support these rules are
     skipped — page still works. The load-bearing fullscreen layout
     is on .landing-fullbleed itself via position:fixed (no parent-
     height dependency) so a missing :has() can't blank the page. */
  body:has(.landing-fullbleed) > footer { display: none; }
  body:has(.landing-fullbleed) > header {
    background: rgba(255, 255, 255, 0.7) !important;
    border-bottom: 1px solid rgba(15, 23, 42, 0.06);
    backdrop-filter: blur(10px);
  }
</style>

<style>
  .landing-fullbleed {
    /* Fixed-position fullscreen below the 53px header. Switched from
       width/height: 100% (which depended on `:has()` rules sizing
       <body>/<main>) to position:fixed so the layout is robust even
       on browsers without :has() — the missing parent-height chain
       was causing a visible body scrollbar + 0-height content. */
    position: fixed;
    top: 53px;
    left: 0;
    right: 0;
    bottom: 0;
    overflow: hidden;
    display: flex;
    align-items: stretch;
    background: radial-gradient(
      ellipse at 30% 50%,
      #ffffff 0%,
      #f1f5f9 60%,
      #e2e8f0 100%
    );
  }

  .tree-side {
    position: relative;
    flex: 0 0 50%;
    height: 100%;
    overflow: hidden;
    background: linear-gradient(135deg, #fafafa 0%, #f1f5f9 100%);
    border-right: 1px solid rgba(15, 23, 42, 0.06);
  }
  .binary-tree {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    /* Subtle 3D perspective tilt — tree feels like it's leaning into the page */
    transform: perspective(1400px) rotateY(4deg);
    transform-origin: right center;
  }
  /* Soft inner-shadow vignette to add depth — anchors the bonsai in space */
  .tree-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      ellipse at 50% 65%,
      rgba(0, 0, 0, 0) 50%,
      rgba(15, 23, 42, 0.10) 100%
    );
    z-index: 1;
  }

  .text-side {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 0 clamp(2rem, 6vw, 5rem);
  }

  .landing-title {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    line-height: 1;
  }
  .title-line--big {
    font-size: clamp(2.25rem, 4.5vw, 4.25rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #0f172a;
    background: linear-gradient(180deg, #0f172a 0%, #1e293b 60%, #334155 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: title-glow 4s ease-in-out infinite;
  }

  @keyframes title-glow {
    0%, 100% { filter: drop-shadow(0 4px 18px rgba(15, 23, 42, 0.10)); }
    50% { filter: drop-shadow(0 4px 26px rgba(15, 23, 42, 0.18)); }
  }

  .landing-bullets {
    margin: 0;
    padding: 0;
    max-width: 36rem;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    opacity: 0;
    animation: fade-up 1.1s 0.6s ease-out forwards;
  }
  .landing-bullets li {
    position: relative;
    padding-left: 1.4rem;
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    line-height: 1.5;
    color: #475569;
  }
  .landing-bullets li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.58em;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 2px;
    background: #0f172a;
    transform: rotate(45deg);
  }

  /* Prominent language toggle above the CTA — same look as the nav
     toggle but larger (readable from across the room). */
  .landing-lang-toggle {
    display: inline-flex;
    gap: 0;
    padding: 4px;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    background: white;
    font-size: 14px;
    font-weight: 600;
    opacity: 0;
    animation: fade-up 1.1s 1.2s ease-out forwards;
  }
  .landing-lang-toggle .lang-toggle-btn {
    padding: 6px 14px;
    border-radius: 5px;
    min-width: 48px;
  }

  .landing-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 0.8rem;
    padding: 0.85rem 1.6rem;
    border-radius: 999px;
    background: #0f172a; /* solid slate-900 — terminal feel */
    color: #f1f5f9;
    font-weight: 700;
    font-size: 1rem;
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    text-decoration: none;
    box-shadow:
      0 0 0 1px rgba(15, 23, 42, 0.85),
      0 8px 24px -6px rgba(15, 23, 42, 0.35);
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
    opacity: 0;
    animation: fade-up 1.1s 1.4s ease-out forwards;
  }
  .landing-cta:hover {
    transform: translateY(-2px);
    background: #000;
    box-shadow:
      0 0 0 1px #000,
      0 14px 36px -6px rgba(15, 23, 42, 0.55);
  }

  .landing-meta {
    display: flex;
    gap: 0.7rem;
    align-items: center;
    margin-top: 0.4rem;
    font-size: 0.85rem;
    color: #94a3b8;
    opacity: 0;
    animation: fade-up 1.1s 1.8s ease-out forwards;
  }
  .landing-meta a {
    color: #475569;
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .landing-meta a:hover { color: #0f172a; }
  .landing-meta .dot { color: #cbd5e1; }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Stack vertically on narrow viewports — tree on top (40% height),
     text below (60%) */
  @media (max-width: 880px) {
    .landing-fullbleed { flex-direction: column; }
    .tree-side {
      flex: 0 0 38%;
      border-right: none;
      border-bottom: 1px solid rgba(15, 23, 42, 0.08);
    }
    .binary-tree { transform: none; }
    .text-side {
      flex: 1;
      align-items: center;
      text-align: center;
      padding: 1.5rem;
    }
    .landing-title { align-items: center; }
  }
</style>
<script>
  // ===== Pythagoras fractal tree → ASCII, growing bottom → top =====
  // Pure recursive binary fractal. At each split: two children at fixed
  // (left, right) angle offsets, length scaled by RATIO. NO random walk
  // → no drift, the tree is deterministic in shape per cycle. Per-cycle
  // randomization of (leftAngle, rightAngle, ratio) gives variety.
  //
  // Pipeline (rewritten 2026-04-23 to kill the Safari canvas bug):
  //   1. Recurse the fractal; for each branch segment, walk the line
  //      analytically and accumulate brightness into a cell grid.
  //   2. Same for leaf puffs (2D Gaussian splat into nearby cells).
  //   3. Convert the brightness grid → ASCII glyph per cell.
  //   4. bottom→top reveal of cells, brief hold, fade, repeat.
  //
  // This used to render to an offscreen canvas then call getImageData
  // to sample — but Safari's canvas implementation repeatedly threw
  // InvalidStateError on getImageData (even with willReadFrequently
  // and no canvas filter). Going fully analytic means NO offscreen
  // canvas exists; the visible canvas is write-only and no browser
  // ever has to satisfy a pixel-readback call. The visual is
  // near-identical (grid is coarse enough that the raster blur from
  // the old path was barely distinguishable).

  type Cell = { col: number; row: number; ch: string; b: number };

  const RAMP = " .'\",:;-+=*ox#%@&MW8B";
  const CELL_W = 7;
  const CELL_H = 12;
  const FONT_PX = 11;

  const MAX_DEPTH = 14;

  const canvas = document.querySelector<HTMLCanvasElement>(".binary-tree");
  if (canvas) {
    const ctx = canvas.getContext("2d")!;
    const DPR = Math.min(window.devicePixelRatio || 1, 2);

    const GROW_MS = 3400;
    const HOLD_MS = 1200;
    const FADE_MS = 500;
    const CYCLE_MS = GROW_MS + HOLD_MS + FADE_MS;

    let W = 0, H = 0, COLS = 0, ROWS = 0;
    let cells: Cell[] = [];
    let cycleStart = performance.now();
    // Reusable brightness grid (Float32, COLS*ROWS). Indexed as
    // bright[row * COLS + col]. Cleared before each rebuild.
    let bright = new Float32Array(0);

    function resize() {
      const rect = canvas.getBoundingClientRect();
      W = Math.max(1, Math.floor(rect.width));
      H = Math.max(1, Math.floor(rect.height));
      canvas.width = W * DPR;
      canvas.height = H * DPR;
      canvas.style.width = `${W}px`;
      canvas.style.height = `${H}px`;
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
      COLS = Math.floor(W / CELL_W);
      ROWS = Math.floor(H / CELL_H);
      bright = new Float32Array(COLS * ROWS);
      rebuild();
      cycleStart = performance.now();
    }

    function clampCol(c: number) { return c < 0 ? 0 : c >= COLS ? COLS - 1 : c; }
    function clampRow(r: number) { return r < 0 ? 0 : r >= ROWS ? ROWS - 1 : r; }

    // Stamp a Gaussian-ish splat into the brightness grid at (x,y)
    // with radius r (pixels) and peak intensity `weight`. Used for
    // leaf puffs + also (repeatedly, stepping along the line) for
    // tapered branch segments.
    function splat(x: number, y: number, r: number, weight: number) {
      const cellR = Math.ceil(r / Math.min(CELL_W, CELL_H));
      const cx = x / CELL_W, cy = y / CELL_H;
      const c0 = clampCol(Math.floor(cx - cellR));
      const c1 = clampCol(Math.ceil(cx + cellR));
      const r0 = clampRow(Math.floor(cy - cellR));
      const r1 = clampRow(Math.ceil(cy + cellR));
      const rPx = Math.max(0.001, r);
      for (let rr = r0; rr <= r1; rr++) {
        for (let cc = c0; cc <= c1; cc++) {
          const pxX = (cc + 0.5) * CELL_W;
          const pxY = (rr + 0.5) * CELL_H;
          const d = Math.hypot(pxX - x, pxY - y);
          if (d > rPx * 1.5) continue;
          // Falloff: 1 at center, ~0 at 1.5r
          const f = Math.max(0, 1 - d / (rPx * 1.5));
          const v = f * f * weight;
          bright[rr * COLS + cc] += v;
        }
      }
    }

    function rebuild() {
      bright.fill(0);

      // Higher ratio + tighter angles → taller tree, canopy reaches near top
      const ratio = 0.79 + Math.random() * 0.04;        // 0.79–0.83
      const leftA = 0.28 + Math.random() * 0.14;        // 16°–24°
      const rightA = 0.28 + Math.random() * 0.14;
      const trunkLen = Math.min(H * 0.21, W * 0.20);
      const baseW = Math.max(24, Math.min(W, H) * 0.045);

      // Walk a tapered segment (thick w1 → w2) by stamping splats
      // every ~CELL_W/2 px along its length. Each splat's radius
      // linearly interpolates between w1/2 and w2/2 so the segment
      // reads as a tapering shape in the cell grid, same visual as
      // the old trapezoid draw.
      function taperedSeg(x1: number, y1: number, x2: number, y2: number, w1: number, w2: number) {
        const dx = x2 - x1, dy = y2 - y1;
        const len = Math.hypot(dx, dy);
        if (len < 0.3) return;
        const step = Math.max(1, Math.min(CELL_W, CELL_H) / 2);
        const n = Math.max(1, Math.ceil(len / step));
        for (let i = 0; i <= n; i++) {
          const t = i / n;
          const x = x1 + dx * t;
          const y = y1 + dy * t;
          const w = (w1 * (1 - t) + w2 * t) / 2; // radius
          splat(x, y, w, 1);
        }
      }

      function branch(x: number, y: number, angle: number, length: number, thick: number, depth: number) {
        if (depth > MAX_DEPTH || length < 1.0) {
          if (depth >= 5) {
            const N = 3;
            for (let p = 0; p < N; p++) {
              const lr = 6.5 + Math.random() * 4.0;
              const jx = (Math.random() - 0.5) * 9;
              const jy = (Math.random() - 0.5) * 9;
              const alpha = 0.65 + Math.random() * 0.28;
              splat(x + jx, y + jy, lr, alpha);
            }
          }
          return;
        }
        const x2 = x + Math.cos(angle) * length;
        const y2 = y + Math.sin(angle) * length;
        const endThick = Math.max(1.4, thick * 0.78);
        taperedSeg(x, y, x2, y2, thick, endThick);
        const newLen = length * ratio;
        branch(x2, y2, angle - leftA, newLen, endThick, depth + 1);
        branch(x2, y2, angle + rightA, newLen, endThick, depth + 1);
      }

      const baseX = W / 2;
      const baseY = H - 24;
      branch(baseX, baseY, -Math.PI / 2, trunkLen, baseW, 0);

      buildCells();
    }

    // Walk the brightness grid and emit one Cell per non-empty cell,
    // normalized to 0..1. Sorted bottom → top for the grow reveal.
    function buildCells() {
      if (bright.length === 0) { cells = []; return; }
      let max = 0;
      for (let i = 0; i < bright.length; i++) if (bright[i] > max) max = bright[i];
      if (max <= 0) { cells = []; return; }
      const out: Cell[] = [];
      const inv = 1 / max;
      for (let r = 0; r < ROWS; r++) {
        for (let c = 0; c < COLS; c++) {
          const v = bright[r * COLS + c] * inv;
          if (v < 0.05) continue;
          const idx = Math.min(
            RAMP.length - 1,
            Math.max(1, Math.floor(v * RAMP.length)),
          );
          const ch = RAMP[idx];
          if (ch === " ") continue;
          out.push({ col: c, row: r, ch, b: v });
        }
      }
      out.sort((a, b) => b.row - a.row);
      cells = out;
    }

    function frame(t: number) {
      let elapsed = t - cycleStart;
      if (elapsed >= CYCLE_MS) {
        rebuild();
        cycleStart = t;
        elapsed = 0;
      }

      let visible = cells.length;
      let alpha = 1;
      if (elapsed < GROW_MS) {
        visible = Math.floor(cells.length * (elapsed / GROW_MS));
      } else if (elapsed < GROW_MS + HOLD_MS) {
        // hold full
      } else {
        alpha = 1 - (elapsed - GROW_MS - HOLD_MS) / FADE_MS;
      }

      ctx.fillStyle = "#f5f7fa";
      ctx.fillRect(0, 0, W, H);
      ctx.font = `${FONT_PX}px ui-monospace, "SF Mono", Menlo, monospace`;
      ctx.textAlign = "left";
      ctx.textBaseline = "top";

      for (let i = 0; i < visible; i++) {
        const c = cells[i];
        const g = Math.floor(15 + 95 * (1 - c.b));
        const a = (0.4 + 0.6 * c.b) * alpha;
        ctx.fillStyle = `rgba(${g}, ${g + 8}, ${g + 24}, ${a.toFixed(2)})`;
        ctx.fillText(c.ch, c.col * CELL_W, c.row * CELL_H);
      }

      const grad = ctx.createRadialGradient(W / 2, H, 20, W / 2, H, H * 0.5);
      grad.addColorStop(0, "rgba(15, 23, 42, 0.08)");
      grad.addColorStop(1, "rgba(255, 255, 255, 0)");
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, W, H);

      requestAnimationFrame(frame);
    }

    resize();
    window.addEventListener("resize", resize);
    requestAnimationFrame(frame);
  }
</script>
